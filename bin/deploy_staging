#!/usr/bin/env bash
set -euo pipefail

ROOT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
cd "$ROOT_DIR"

source "$ROOT_DIR/bin/activate_shared_ruby"

DEPLOY_SHA="${DEPLOY_SHA:-$(git rev-parse HEAD)}"
DEPLOY_REF="${DEPLOY_REF:-deploy/${DEPLOY_SHA}}"
DEPLOY_USER="${DEPLOY_USER:?DEPLOY_USER must be set for staging deploys}"
DEPLOY_HOST="${DEPLOY_HOST:?DEPLOY_HOST must be set for staging deploys}"
DEPLOY_TO="${DEPLOY_TO:?DEPLOY_TO must be set for staging deploys}"
APP_HOST="${APP_HOST:?APP_HOST must be set for staging deploys}"
DATABASE_NAME="${DATABASE_NAME:-gotthekeys_staging}"
DEPLOY_REPO_URL="${DEPLOY_REPO_URL:?DEPLOY_REPO_URL must be set for staging deploys}"
DEPLOY_MIRROR_URL="${DEPLOY_MIRROR_URL:?DEPLOY_MIRROR_URL must be set for staging deploys}"
DEPLOY_MIRROR_REMOTE="${DEPLOY_MIRROR_REMOTE:-deploy-mirror}"

echo "Deploying ${DEPLOY_SHA} via ${DEPLOY_MIRROR_URL}"
ruby -v
bundle -v

if git remote get-url "$DEPLOY_MIRROR_REMOTE" >/dev/null 2>&1; then
  git remote set-url "$DEPLOY_MIRROR_REMOTE" "$DEPLOY_MIRROR_URL"
else
  git remote add "$DEPLOY_MIRROR_REMOTE" "$DEPLOY_MIRROR_URL"
fi

git push --no-verify --force "$DEPLOY_MIRROR_REMOTE" "${DEPLOY_SHA}:refs/heads/${DEPLOY_REF}"

export DEPLOY_USER DEPLOY_HOST DEPLOY_TO APP_HOST DEPLOY_REPO_URL
export DATABASE_URL DATABASE_NAME DATABASE_HOST DATABASE_PORT DATABASE_USERNAME DATABASE_PASSWORD
export DEPLOY_BRANCH="$DEPLOY_REF"
export APP_VERSION="${APP_VERSION:-}"
export APP_BUILD_SHA="${APP_BUILD_SHA:-$(git rev-parse --short "${DEPLOY_SHA}")}"
export APP_BUILD_NUMBER="${APP_BUILD_NUMBER:-}"

bundle exec cap staging deploy:check
bundle exec cap staging deploy
