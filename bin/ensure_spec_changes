#!/usr/bin/env ruby
# frozen_string_literal: true

require 'json'
require 'open3'
require_relative '../lib/ci/spec_change_guard'

def read_event_payload(path)
  return {} unless path && File.exist?(path)

  JSON.parse(File.read(path))
end

def git_changed_files(range)
  status_args =
    case range.diff_mode
    when :three_dot
      ['diff', '--name-status', "#{range.base_sha}...#{range.head_sha}"]
    when :two_dot
      ['diff', '--name-status', range.base_sha, range.head_sha]
    else
      ['diff-tree', '--no-commit-id', '--name-status', '--root', '-r', range.head_sha]
    end

  numstat_args =
    case range.diff_mode
    when :three_dot
      ['diff', '--numstat', "#{range.base_sha}...#{range.head_sha}"]
    when :two_dot
      ['diff', '--numstat', range.base_sha, range.head_sha]
    else
      ['diff-tree', '--no-commit-id', '--numstat', '--root', '-r', range.head_sha]
    end

  status_stdout, status_stderr, status_result = Open3.capture3('git', *status_args)
  unless status_result.success?
    warn status_stderr
    abort "Unable to determine changed files for spec coverage guard."
  end

  numstat_stdout, numstat_stderr, numstat_result = Open3.capture3('git', *numstat_args)
  unless numstat_result.success?
    warn numstat_stderr
    abort "Unable to determine changed file stats for spec coverage guard."
  end

  merge_change_metadata(
    status_stdout.lines.filter_map { |line| parse_changed_file_status(line) },
    numstat_stdout.lines.filter_map { |line| parse_changed_file_counts(line) }
  )
end

def parse_changed_file_status(line)
  parts = line.split("\t").map(&:strip).reject(&:empty?)
  return if parts.empty?

  status = parts.shift
  path = parts.last
  return if path.nil? || path.empty?

  { path: path, status: status }
end

def parse_changed_file_counts(line)
  parts = line.split("\t").map(&:strip).reject(&:empty?)
  return if parts.length < 3

  additions, deletions = parts.shift(2)
  path = parts.last
  return if path.nil? || path.empty?

  {
    path: path,
    additions: additions.match?(/\A\d+\z/) ? additions.to_i : nil,
    deletions: deletions.match?(/\A\d+\z/) ? deletions.to_i : nil
  }
end

def merge_change_metadata(status_entries, count_entries)
  counts_by_path = count_entries.each_with_object({}) do |entry, result|
    result[entry[:path]] = entry
  end

  status_entries.map do |entry|
    entry.merge(counts_by_path.fetch(entry[:path], {}))
  end
end

def git_file_exists_at?(sha, path)
  return false unless sha

  _stdout, _stderr, status = Open3.capture3("git", "cat-file", "-e", "#{sha}:#{path}")
  status.success?
end

def file_contents_at(sha, path)
  return unless git_file_exists_at?(sha, path)

  stdout, stderr, status = Open3.capture3("git", "show", "#{sha}:#{path}")
  return stdout if status.success?

  warn stderr
  abort "Unable to read #{path} from #{sha} for spec coverage guard."
end

def git_stdout(*args)
  stdout, stderr, status = Open3.capture3('git', *args)
  return stdout if status.success?

  warn stderr unless stderr.to_s.strip.empty?
  nil
end

def local_range_from_git
  head_sha = git_stdout('rev-parse', 'HEAD')&.strip
  return Ci::ChangeRange.new(base_sha: nil, head_sha: nil, diff_mode: :single_commit) if head_sha.to_s.empty?

  upstream = git_stdout('rev-parse', '--abbrev-ref', '--symbolic-full-name', '@{upstream}')&.strip
  if upstream && !upstream.empty?
    merge_base = git_stdout('merge-base', 'HEAD', upstream)&.strip
    return Ci::ChangeRange.new(base_sha: merge_base, head_sha: head_sha, diff_mode: :two_dot) if merge_base && !merge_base.empty?
  end

  previous = git_stdout('rev-parse', 'HEAD^')&.strip
  return Ci::ChangeRange.new(base_sha: previous, head_sha: head_sha, diff_mode: :two_dot) if previous && !previous.empty?

  Ci::ChangeRange.new(base_sha: nil, head_sha: head_sha, diff_mode: :single_commit)
end

payload = read_event_payload(ENV['GITHUB_EVENT_PATH'])
range = Ci::ChangeRange.from_github(env: ENV, payload: payload)

unless range.complete?
  range = local_range_from_git
  puts 'Using local git history for spec coverage guard.'
end

changed_files = git_changed_files(range)
results = []
results << Ci::SpecChangeGuard.new(changed_files: changed_files).evaluate
results << Ci::TopLevelControllerCoverageGuard.new(
  changed_files: changed_files,
  before_reader: ->(path) { file_contents_at(range.base_sha, path) },
  after_reader: ->(path) { File.exist?(path) ? File.read(path) : nil }
).evaluate

results.each { |result| puts result.message }

exit(results.all?(&:success?) ? 0 : 1)
