{
  "name": "rails_got_the_keys",
  "private": true,
  "scripts": {
    "build": "npm run build:css && npm run build:js",
    "build:css": "sass --no-source-map --silence-deprecation=import,global-builtin,color-functions,if-function --load-path=node_modules app/assets/stylesheets/public_bundle.scss:app/assets/builds/public.css app/assets/stylesheets/admin_bundle.scss:app/assets/builds/admin.css",
    "build:js": "esbuild public=app/javascript/public_bundle.js admin=app/javascript/admin_bundle.js --bundle --sourcemap --format=iife --outdir=app/assets/builds",
    "watch:css": "npm run build:css -- --watch",
    "watch:js": "npm run build:js -- --watch"
  },
  "dependencies": {
    "@hotwired/turbo-rails": "8.0.23",
    "foundation-sites": "6.9.0"
  },
  "devDependencies": {
    "allure": "3.3.1",
    "esbuild": "0.27.4",
    "sass": "1.98.0"
  }
}
