{
  "info": {
    "name": "GotTheKeys API v1",
    "_postman_id": "9b2f6a1e-0001-4f7e-8f8b-gotthekeys-api-v1",
    "description": "Buyer/renter API for GotTheKeys. See docs/api/v1-spec.md.\n\nSet `base_url` (e.g. http://localhost:3000) and use the Auth → Login request to populate `access_token` and `refresh_token`.",
