APP_HOST=homes.example.com
APP_BIND_ADDRESS=0.0.0.0
APP_PORT=3000

SYNOLOGY_APP_ROOT=/volume1/docker/gotthekeys

SECRET_KEY_BASE=replace_with_a_long_random_secret

POSTGRES_DB=gotthekeys_production
POSTGRES_USER=gotthekeys
POSTGRES_PASSWORD=replace_this_password
DATABASE_URL=postgres://gotthekeys:replace_this_password@db:5432/gotthekeys_production

RAILS_SERVE_STATIC_FILES=1
FORCE_SSL=true
ASSUME_SSL=true
RAILS_LOG_LEVEL=info
ACTIVE_JOB_QUEUE_ADAPTER=async
RAILS_MAX_THREADS=5
WEB_CONCURRENCY=1

# Optional SMTP settings
# SMTP_ADDRESS=smtp.example.com
# SMTP_PORT=587
# SMTP_DOMAIN=example.com
# SMTP_USERNAME=user
# SMTP_PASSWORD=password
# SMTP_AUTHENTICATION=plain
# SMTP_STARTTLS_AUTO=true
