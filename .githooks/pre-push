#!/usr/bin/env bash
set -euo pipefail

repo_root="$(git rev-parse --show-toplevel 2>/dev/null || pwd)"
cd "$repo_root"

if [ ! -x "bin/ensure_spec_changes" ]; then
  echo "Missing executable helper: bin/ensure_spec_changes" >&2
  exit 1
fi

if [ ! -x "bin/pre_push_rspec" ]; then
  echo "Missing executable helper: bin/pre_push_rspec" >&2
  exit 1
fi

if [ ! -x "bin/i18n_health" ]; then
  echo "Missing executable helper: bin/i18n_health" >&2
  exit 1
fi

echo "pre-push: running spec coverage guard..."

if ! ruby bin/ensure_spec_changes; then
  echo "pre-push: spec coverage guard failed. Push cancelled." >&2
  exit 1
fi

echo "pre-push: checking locale health..."

if ! bin/i18n_health; then
  echo "pre-push: locale health failed. Push cancelled." >&2
  exit 1
fi

echo "pre-push: running RSpec checks..."

if ! bin/pre_push_rspec; then
  echo "pre-push: RSpec failed. Push cancelled." >&2
  exit 1
fi

echo "pre-push: running Brakeman..."

if ! bundle exec brakeman --no-pager -q; then
  echo "pre-push: Brakeman failed. Push cancelled." >&2
  exit 1
fi

echo "pre-push: running bundler-audit..."

if ! bundle exec bundler-audit update && bundle exec bundler-audit check; then
  echo "pre-push: bundler-audit failed. Push cancelled." >&2
  exit 1
fi
