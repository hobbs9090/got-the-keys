#!/usr/bin/env bash
set -euo pipefail

repo_root="$(git rev-parse --show-toplevel 2>/dev/null || pwd)"
cd "$repo_root"

if [ ! -x "bin/ensure_spec_changes" ]; then
  echo "Missing executable helper: bin/ensure_spec_changes" >&2
  exit 1
fi

if [ ! -x "bin/pre_push_rspec" ]; then
  echo "Missing executable helper: bin/pre_push_rspec" >&2
  exit 1
fi

echo "pre-push: running spec coverage guard..."

if ! ruby bin/ensure_spec_changes; then
  echo "pre-push: spec coverage guard failed. Push cancelled." >&2
  exit 1
fi

echo "pre-push: running RSpec checks..."

if ! bin/pre_push_rspec; then
  echo "pre-push: RSpec failed. Push cancelled." >&2
  exit 1
fi
