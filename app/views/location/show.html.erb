<% title t("ui.legacy.location_details_title", address: @property.address_line_1) %>

<div class="row">

  <div class="large-9 columns">

    <h1 class="legacy-page-heading"><%= t('location.location_details_for') %> <%= link_to(@property.address_line_1, @property) %></h1>

    <div>
      <%= image_tag(
            "https://maps.googleapis.com/maps/api/staticmap?center=#{@property.postcode}&zoom=14&size=720x450&markers=#{@property.postcode}&sensor=false",
            alt: "Map showing the area around #{@property.address_line_1}",
            width: 720,
            height: 450
          ) %>
    </div>

  </div>

  <%= render "properties/property_sidebar" %>

</div>
