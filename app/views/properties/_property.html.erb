<% properties = local_assigns.fetch(:properties, @properties) %>
<% grid_class = local_assigns.fetch(:grid_class, "property-grid") %>

<% if properties.any? %>
  <div class="<%= grid_class %>" id="properties">
    <% properties.each do |property| %>
      <% card_documents = property_card_download_documents(property) %>
      <article class="<%= property_card_classes(property) %>" data-testid="property-card">
        <div class="property-card__media">
          <%= small_image_for(property) %>
          <div class="property-card__badges">
            <span class="<%= property_sale_status_badge_class(property.sale_status) %>"><%= translated_sale_status(property.sale_status) %></span>
            <% unless property.listing_state == "published" %>
              <span class="<%= listing_state_badge_class(property.listing_state) %>"><%= translated_listing_state(property.listing_state) %></span>
            <% end %>
          </div>
        </div>

        <div class="property-card__body">
          <div class="property-card__header">
            <p class="property-card__eyebrow"><%= property_location_label(property) %></p>
            <h3><%= link_to property.address_line_1, property_path(property), data: { testid: "property-card-link-#{property.id}" } %></h3>
          </div>

          <div class="property-card__price" data-testid="property-card-price">
            <strong><%= format_price(property) %></strong>
            <% if chinese_locale? %>
              <span class="property-price-secondary"><%= format_renminbi(property) %></span>
            <% end %>
          </div>

          <p class="property-card__headline"><%= property.headline %></p>
          <p class="property-card__description"><%= truncate(property.property_description, length: 130, separator: " ") %></p>
          <ul class="property-card__trust-list">
            <% property_trust_cues(property, include_response_time: false).first(3).each do |cue| %>
              <li><span class="badge badge--success property-card__trust-badge"><%= cue %></span></li>
            <% end %>
          </ul>
          <% if card_documents.any? %>
            <div class="property-card__downloads" data-testid="property-card-downloads">
              <% card_documents.each do |document| %>
                <%= link_to property_card_document_label(document), download_property_property_document_path(property, document), class: "button hollow secondary tiny", download: document.file_name, data: { turbo: false, testid: "property-card-document-download-#{property.id}-#{document.id}" } %>
              <% end %>
            </div>
          <% end %>
          <% if property.available_now? %>
            <p class="property-card__availability"><strong><%= t("ui.properties.card.available_now") %></strong></p>
          <% elsif property.available_from.present? %>
            <p class="property-card__availability"><%= t("ui.properties.card.available_from", date: l(property.available_from, format: :long)) %></p>
          <% end %>

          <dl class="property-card__meta">
            <div>
              <dt><%= t("properties.bedrooms") %></dt>
              <dd><%= format_bedrooms(property) %></dd>
            </div>
            <div>
              <dt><%= t("ui.common.bathrooms") %></dt>
              <dd><%= format_bathrooms(property.bathrooms) %></dd>
            </div>
            <div>
              <dt><%= t("ui.common.town") %></dt>
              <dd><%= property.town_city %></dd>
            </div>
            <% if property.floor_area_sq_ft.present? %>
              <div>
                <dt><%= t("ui.properties.card.area") %></dt>
                <dd><%= t("ui.properties.card.floor_area", area: property.floor_area_sq_ft) %></dd>
              </div>
            <% end %>
          </dl>
        </div>

        <footer class="property-card__footer">
          <div>
            <p class="property-card__availability"><%= property_update_label(property) %></p>
            <% next_slot = property.next_available_slots(limit: 1).first %>
            <% if next_slot.present? %>
              <p class="property-card__availability"><%= t("ui.properties.card.next_slot", time: formatted_public_date_time(next_slot.starts_at)) %></p>
            <% else %>
              <p class="property-card__availability property-card__availability--empty"><%= t("ui.properties.card.no_slots") %></p>
            <% end %>
          </div>

          <div class="property-card__actions">
            <%= link_to t("ui.common.view_property"), property_path(property), class: "button primary hollow" %>
            <% if user_signed_in? %>
              <%= link_to t("ui.common.book_a_viewing"), new_property_appointment_path(property), class: "button primary", data: { testid: "book-viewing-link-#{property.id}" } %>
            <% else %>
              <%= link_to t("ui.properties.show.booking_sign_in_cta", default: "Sign in to book a viewing"), new_user_session_path(return_to: property_path(property, anchor: "booking-panel")), class: "button primary", data: { testid: "book-viewing-sign-in-link-#{property.id}" } %>
            <% end %>
          </div>
        </footer>
      </article>
    <% end %>
  </div>
<% else %>
  <section class="site-card empty-state">
    <p class="section-heading__eyebrow"><%= t("ui.properties.empty.eyebrow") %></p>
    <h2><%= t("ui.properties.empty.title") %></h2>
    <p><%= t("ui.properties.empty.body") %></p>
  </section>
<% end %>
