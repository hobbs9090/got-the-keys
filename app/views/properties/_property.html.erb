<% properties = local_assigns.fetch(:properties, @properties) %>

<% if properties.any? %>
  <div class="property-grid" id="properties">
    <% properties.each do |property| %>
      <article class="<%= property_card_classes(property) %>" data-testid="property-card">
        <div class="property-card__media">
          <%= small_image_for(property) %>
          <span class="badge <%= property.sale_status == Property::SALE_STATUSES[:for_sale] ? 'badge--accent' : 'badge--success' %>"><%= property.sale_status %></span>
        </div>

        <div class="property-card__body">
          <div class="property-card__header">
            <div>
              <p class="property-card__eyebrow"><%= property.property_type %> in <%= property.location_line %></p>
              <h3><%= link_to property.address_line_1, property_path(property), data: { testid: "property-card-link-#{property.id}" } %></h3>
            </div>

            <div class="property-card__price">
              <strong><%= format_price(property) %></strong>
              <% if chinese_locale? %>
                <span class="property-price-secondary"><%= format_renminbi(property) %></span>
              <% end %>
            </div>
          </div>

          <p class="property-card__headline"><%= property.headline %></p>
          <p class="property-card__description"><%= truncate(property.property_description, length: 130, separator: " ") %></p>

          <dl class="property-card__meta">
            <div>
              <dt>Bedrooms</dt>
              <dd><%= format_bedrooms(property) %></dd>
            </div>
            <div>
              <dt>Bathrooms</dt>
              <dd><%= pluralize(property.bathrooms, "bathroom") %></dd>
            </div>
            <div>
              <dt>Town</dt>
              <dd><%= property.town_city %></dd>
            </div>
          </dl>
        </div>

        <footer class="property-card__footer">
          <div>
            <% next_slot = property.next_available_slots(limit: 1).first %>
            <% if next_slot.present? %>
              <p class="property-card__availability">Next slot: <%= formatted_date_time(next_slot.starts_at) %></p>
            <% else %>
              <p class="property-card__availability property-card__availability--empty">No upcoming public slots published</p>
            <% end %>
          </div>

          <div class="property-card__actions">
            <%= link_to "View property", property_path(property), class: "button primary hollow" %>
            <%= link_to "Book a viewing", new_property_appointment_path(property), class: "button primary", data: { testid: "book-viewing-link-#{property.id}" } %>
          </div>
        </footer>
      </article>
    <% end %>
  </div>
<% else %>
  <section class="site-card empty-state">
    <p class="section-heading__eyebrow">No matches</p>
    <h2>No properties match this search</h2>
    <p>Try widening the area, bedrooms, or price range, or reset the filters to browse the full catalogue again.</p>
  </section>
<% end %>
