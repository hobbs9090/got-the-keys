<% title t("ui.properties.mine.title") %>

<section class="property-workspace">
  <h1 class="visually-hidden"><%= t("ui.properties.mine.title") %></h1>
  <section class="site-card property-workspace-section <%= "property-workspace-section--empty-listings" if @properties.blank? %>" data-testid="owner-listings-section">
    <p class="section-heading__eyebrow"><%= t("ui.properties.mine.list_eyebrow") %></p>
    <h2><%= t("ui.properties.mine.list_title") %></h2>
    <p><%= t("ui.properties.mine.list_blurb") %></p>

    <% if @properties.blank? %>
      <h3 class="property-workspace-section__empty-title" data-testid="owner-listings-empty"><%= t("ui.properties.mine.empty_title") %></h3>
      <p><%= t("ui.properties.mine.empty_body") %></p>
      <div class="property-workspace-section__actions">
        <%= link_to t("ui.site_header.add_property"), new_property_path, class: "button primary" %>
      </div>
    <% else %>
      <div class="property-workspace-section__actions">
        <%= link_to t("ui.site_header.add_property"), new_property_path, class: "button primary" %>
      </div>
      <%= render "properties/owner_properties_section" %>
    <% end %>
  </section>

  <section class="site-card property-workspace-section" data-testid="customer-bookings-section">
    <p class="section-heading__eyebrow"><%= t("ui.properties.mine.customer_bookings_eyebrow") %></p>
    <h2><%= t("ui.properties.mine.customer_bookings_title") %></h2>
    <p><%= t("ui.properties.mine.customer_bookings_blurb") %></p>

    <% if @customer_appointment_buckets.values.any?(&:any?) %>
      <section class="site-card property-workspace-panel property-workspace-panel--appointments" data-testid="customer-bookings-panel">
        <div class="property-workspace-bookings">
          <% [
            [:upcoming, t("ui.properties.mine.upcoming_appointments"), t("ui.properties.mine.no_upcoming_appointments")],
            [:previous, t("ui.properties.mine.previous_appointments"), t("ui.properties.mine.no_previous_appointments")],
            [:cancelled, t("ui.properties.mine.cancelled_appointments"), t("ui.properties.mine.no_cancelled_appointments")]
          ].each do |bucket_key, heading, empty_copy| %>
            <% appointments = @customer_appointment_buckets.fetch(bucket_key) %>

            <section class="property-workspace-bookings__section">
              <div class="property-workspace-bookings__header">
                <p class="property-workspace-card__appointment-heading"><%= heading %></p>
                <span class="badge badge--neutral"><%= display_number(appointments.count) %></span>
              </div>

              <% if appointments.any? %>
                <div class="property-workspace-card__appointment-list">
                  <% appointments.each do |appointment| %>
                    <div class="property-workspace-card__appointment property-workspace-card__appointment--customer" data-testid="customer-booking-row">
                      <div class="property-workspace-bookings__details">
                        <span class="<%= property_sale_status_badge_class(appointment.property.sale_status) %>" data-testid="customer-booking-sale-status-<%= appointment.id %>"><%= translated_sale_status(appointment.property.sale_status) %></span>
                        <strong><%= link_to appointment.property.address_line_1, property_path(appointment.property) %></strong>
                        <p><%= formatted_date_time(appointment.scheduled_at) %></p>
                        <p><%= appointment.property.location_line %></p>
                      </div>
                      <div class="property-workspace-card__appointment-actions">
                        <span class="<%= appointment_status_badge_class(appointment.status) %>"><%= appointment.display_status %></span>
                        <%= link_to t("ui.properties.mine.open_details"), property_path(appointment.property), class: "button primary property-workspace-card__appointment-button" %>
                        <%= link_to t("ui.properties.mine.view_booking"), appointment_path(appointment, token: appointment.access_token), class: "button hollow primary property-workspace-card__appointment-button" %>
                      </div>
                    </div>
                  <% end %>
                </div>
              <% else %>
                <p class="empty-copy"><%= empty_copy %></p>
              <% end %>
            </section>
          <% end %>
        </div>
      </section>
    <% else %>
      <h3 class="property-workspace-section__empty-title" data-testid="customer-bookings-empty"><%= t("ui.properties.mine.customer_bookings_empty_title") %></h3>
      <p class="empty-copy"><%= t("ui.properties.mine.customer_bookings_empty") %></p>
    <% end %>
  </section>

  <section class="site-card property-workspace-section" data-testid="customer-offers-section">
    <p class="section-heading__eyebrow"><%= t("ui.properties.mine.customer_offers_eyebrow") %></p>
    <h2><%= t("ui.properties.mine.customer_offers_title") %></h2>
    <p><%= t("ui.properties.mine.customer_offers_blurb") %></p>

    <% if @customer_offers.any? %>
      <section class="site-card property-workspace-panel property-workspace-panel--appointments" data-testid="customer-offers-panel">
        <div class="property-workspace-bookings">
          <section class="property-workspace-bookings__section">
            <div class="property-workspace-bookings__header">
              <p class="property-workspace-card__appointment-heading"><%= t("ui.properties.mine.customer_offers_title") %></p>
              <span class="badge badge--neutral"><%= display_number(@customer_offers.count) %></span>
            </div>

            <div class="property-workspace-card__appointment-list">
              <% @customer_offers.each do |offer| %>
                <div class="property-workspace-card__appointment property-workspace-card__appointment--customer" data-testid="customer-offer-row">
                  <div class="property-workspace-bookings__details">
                    <span class="<%= property_sale_status_badge_class(offer.property.sale_status) %>" data-testid="customer-offer-sale-status-<%= offer.id %>"><%= translated_sale_status(offer.property.sale_status) %></span>
                    <strong><%= offer.property.address_line_1 %></strong>
                    <p><%= number_to_currency(offer.amount, unit: "£", precision: 0) %></p>
                    <p><%= t("ui.properties.mine.customer_offer_submitted", time: formatted_date_time(offer.created_at)) %></p>
                  </div>
                  <div class="property-workspace-card__appointment-actions">
                    <span class="<%= offer_status_badge_class(offer.status) %>"><%= t("ui.offers.statuses.#{offer.status}") %></span>
                    <%= link_to t("ui.properties.mine.open_details"), property_path(offer.property), class: "button primary property-workspace-card__appointment-button" %>
                    <% if offer.withdrawable? %>
                      <%= button_to t("ui.properties.mine.withdraw_offer"),
                                    withdraw_property_offer_path(offer.property, offer),
                                    method: :patch,
                                    class: "button hollow secondary property-workspace-card__appointment-button",
                                    data: { turbo_confirm: t("ui.properties.mine.withdraw_offer_confirm") } %>
                    <% end %>
                  </div>
                </div>
              <% end %>
            </div>
          </section>
        </div>
      </section>
    <% else %>
      <h3 class="property-workspace-section__empty-title" data-testid="customer-offers-empty"><%= t("ui.properties.mine.customer_offers_empty_title") %></h3>
      <p class="empty-copy"><%= t("ui.properties.mine.customer_offers_empty") %></p>
    <% end %>
  </section>

  <section class="site-card property-workspace-section" data-testid="customer-rental-applications-section">
    <p class="section-heading__eyebrow"><%= t("ui.properties.mine.customer_rental_applications_eyebrow") %></p>
    <h2><%= t("ui.properties.mine.customer_rental_applications_title") %></h2>
    <p><%= t("ui.properties.mine.customer_rental_applications_blurb") %></p>

    <% if @customer_rental_applications.any? %>
      <section class="site-card property-workspace-panel property-workspace-panel--appointments" data-testid="customer-rental-applications-panel">
        <div class="property-workspace-bookings">
          <section class="property-workspace-bookings__section">
            <div class="property-workspace-bookings__header">
              <p class="property-workspace-card__appointment-heading"><%= t("ui.properties.mine.customer_rental_applications_title") %></p>
              <span class="badge badge--neutral"><%= display_number(@customer_rental_applications.count) %></span>
            </div>

            <div class="property-workspace-card__appointment-list">
              <% @customer_rental_applications.each do |rental_application| %>
                <div class="property-workspace-card__appointment property-workspace-card__appointment--customer" data-testid="customer-rental-application-row">
                  <div class="property-workspace-bookings__details">
                    <span class="<%= property_sale_status_badge_class(rental_application.property.sale_status) %>" data-testid="customer-rental-application-sale-status-<%= rental_application.id %>"><%= translated_sale_status(rental_application.property.sale_status) %></span>
                    <strong><%= rental_application.property.address_line_1 %></strong>
                    <p><%= t("ui.properties.mine.customer_rental_application_move_in", date: l(rental_application.move_in_date, format: :long)) %></p>
                    <p><%= t("ui.properties.mine.customer_rental_application_submitted", time: formatted_date_time(rental_application.created_at)) %></p>
                  </div>
                  <div class="property-workspace-card__appointment-actions">
                    <span class="<%= rental_application_status_badge_class(rental_application.status) %>"><%= t("ui.rental_applications.statuses.#{rental_application.status}") %></span>
                    <%= link_to t("ui.properties.mine.open_details"), property_path(rental_application.property), class: "button primary property-workspace-card__appointment-button" %>
                    <% if rental_application.withdrawable? %>
                      <%= button_to t("ui.properties.mine.withdraw_rental_application"),
                                    withdraw_property_rental_application_path(rental_application.property, rental_application),
                                    method: :patch,
                                    class: "button hollow secondary property-workspace-card__appointment-button",
                                    data: { turbo_confirm: t("ui.properties.mine.withdraw_rental_application_confirm") } %>
                    <% end %>
                  </div>
                </div>
              <% end %>
            </div>
          </section>
        </div>
      </section>
    <% else %>
      <h3 class="property-workspace-section__empty-title" data-testid="customer-rental-applications-empty"><%= t("ui.properties.mine.customer_rental_applications_empty_title") %></h3>
      <p class="empty-copy"><%= t("ui.properties.mine.customer_rental_applications_empty") %></p>
    <% end %>
  </section>

  <section class="site-card property-workspace-section" data-testid="saved-homes-section">
      <p class="section-heading__eyebrow"><%= t("ui.properties.mine.saved_homes_eyebrow") %></p>
      <h2><%= t("ui.properties.mine.saved_homes_title") %></h2>
      <p><%= t("ui.properties.mine.saved_homes_blurb") %></p>

      <% if @saved_properties.any? %>
        <div class="property-workspace__grid">
          <% @saved_properties.each do |property| %>
          <article id="<%= dom_id(property, :saved_property_card) %>" class="site-card property-workspace-card" data-testid="saved-property-card">
            <div class="property-workspace-card__media">
              <%= small_image_for(property) %>
            </div>

            <div class="property-workspace-card__content">
              <div class="property-workspace-card__badges">
                <span class="<%= property_sale_status_badge_class(property.sale_status) %>"><%= translated_sale_status(property.sale_status) %></span>
                <% unless property.listing_state == "published" %>
                  <span class="<%= listing_state_badge_class(property.listing_state) %>"><%= translated_listing_state(property.listing_state) %></span>
                <% end %>
              </div>

              <div>
                <h2><%= link_to property.address_line_1, property_path(property) %></h2>
                <p><%= property.headline %></p>
              </div>

              <dl class="property-workspace-card__meta">
                <div>
                  <dt><%= t("ui.properties.mine.stats.location") %></dt>
                  <dd><%= property.location_line %></dd>
                </div>
                <div>
                  <dt><%= t("ui.properties.mine.stats.price") %></dt>
                  <dd><%= format_price(property) %></dd>
                </div>
                <div>
                  <dt><%= t("ui.properties.mine.stats.last_saved") %></dt>
                  <dd><%= formatted_date_time(property.updated_at) %></dd>
                </div>
                <div>
                  <dt><%= t("ui.properties.mine.stats.status") %></dt>
                  <dd><%= translated_listing_state(property.listing_state) %></dd>
                </div>
              </dl>

              <div class="property-workspace-card__actions">
                <%= link_to t("ui.properties.mine.open_details"), property_path(property), class: "button primary" %>
                <%= button_to t("ui.saved_properties.saved_button"), property_saved_property_path(property), method: :delete, class: "button primary hollow", form: { data: { turbo_stream: true } } %>
              </div>
            </div>
            </article>
          <% end %>
        </div>
      <% else %>
        <h3 class="property-workspace-section__empty-title" data-testid="saved-homes-empty"><%= t("ui.properties.mine.saved_homes_empty_title") %></h3>
        <p class="empty-copy"><%= t("ui.properties.mine.saved_homes_empty") %></p>
      <% end %>
    </section>

  <section class="site-card property-workspace-section" id="saved-searches" data-testid="workspace-saved-searches">
    <p class="section-heading__eyebrow"><%= t("ui.properties.mine.saved_searches_eyebrow") %></p>
    <h2><%= t("ui.properties.mine.saved_searches_title") %></h2>
    <p><%= t("ui.properties.mine.saved_searches_blurb") %></p>

    <% if @saved_searches.blank? %>
      <h3 class="property-workspace-section__empty-title" data-testid="saved-searches-empty"><%= t("ui.properties.mine.saved_searches_empty_title") %></h3>
      <p class="empty-copy"><%= t("ui.properties.mine.saved_searches_empty") %></p>
    <% else %>
      <%= render "properties/saved_searches_cards", saved_searches: @saved_searches %>
    <% end %>
  </section>

</section>
