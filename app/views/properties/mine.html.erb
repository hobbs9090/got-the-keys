<% title t("ui.properties.mine.title", default: "My listings") %>

<section class="page-hero property-workspace-hero">
  <div>
    <p class="page-hero__eyebrow"><%= t("ui.properties.mine.eyebrow", default: "Seller workspace") %></p>
    <h1><%= t("ui.properties.mine.title", default: "My listings") %></h1>
    <p><%= t("ui.properties.mine.body", default: "Open the listings you have saved, jump back into drafts, and review the property details you have already created.") %></p>
  </div>

  <div class="page-hero__meta">
    <span class="badge badge--neutral"><%= t("ui.properties.mine.total_label", count: @workspace_counts[:total], default: "%{count} saved listings") %></span>
    <strong><%= number_with_delimiter(@workspace_counts[:total], delimiter: ",") %></strong>
    <span><%= t("ui.properties.mine.state_summary", drafts: @workspace_counts[:drafts], live: @workspace_counts[:live], default: "%{drafts} draft or in review · %{live} live") %></span>
  </div>
</section>

<section class="property-workspace">
  <% if @customer_appointment_buckets.values.any?(&:any?) %>
    <div class="section-heading">
      <div>
        <p class="section-heading__eyebrow"><%= t("ui.properties.mine.customer_bookings_eyebrow", default: "Your viewings") %></p>
        <h2><%= t("ui.properties.mine.customer_bookings_title", default: "Your bookings") %></h2>
      </div>
    </div>

    <section class="site-card property-workspace-panel property-workspace-panel--appointments" data-testid="customer-bookings-panel">
      <div class="property-workspace-bookings">
        <% [
          [:upcoming, t("ui.properties.mine.upcoming_appointments", default: "Upcoming"), t("ui.properties.mine.no_upcoming_appointments", default: "No upcoming appointments.")],
          [:previous, t("ui.properties.mine.previous_appointments", default: "Previous"), t("ui.properties.mine.no_previous_appointments", default: "No previous appointments.")],
          [:cancelled, t("ui.properties.mine.cancelled_appointments", default: "Cancelled"), t("ui.properties.mine.no_cancelled_appointments", default: "No cancelled appointments.")]
        ].each do |bucket_key, heading, empty_copy| %>
          <% appointments = @customer_appointment_buckets.fetch(bucket_key) %>

          <section class="property-workspace-bookings__section">
            <div class="property-workspace-bookings__header">
              <p class="property-workspace-card__appointment-heading"><%= heading %></p>
              <span class="badge badge--neutral"><%= appointments.count %></span>
            </div>

            <% if appointments.any? %>
              <div class="property-workspace-card__appointment-list">
                <% appointments.each do |appointment| %>
                  <div class="property-workspace-card__appointment property-workspace-card__appointment--customer" data-testid="customer-booking-row">
                    <div class="property-workspace-bookings__details">
                      <strong><%= appointment.property.address_line_1 %></strong>
                      <p><%= formatted_date_time(appointment.scheduled_at) %></p>
                      <p><%= appointment.property.location_line %></p>
                    </div>
                    <div class="property-workspace-card__appointment-actions">
                      <span class="<%= appointment_status_badge_class(appointment.status) %>"><%= appointment.display_status %></span>
                      <%= link_to t("ui.properties.mine.open_details", default: "Open details"), property_path(appointment.property), class: "button hollow secondary" %>
                      <%= link_to t("ui.properties.mine.view_booking", default: "View booking"), appointment_path(appointment, token: appointment.access_token), class: "button hollow secondary" %>
                    </div>
                  </div>
                <% end %>
              </div>
            <% else %>
              <p class="empty-copy"><%= empty_copy %></p>
            <% end %>
          </section>
        <% end %>
      </div>
    </section>
  <% end %>

  <% if @saved_properties.any? %>
    <div class="section-heading">
      <div>
        <p class="section-heading__eyebrow"><%= t("ui.properties.mine.saved_homes_eyebrow", default: "Your shortlist") %></p>
        <h2><%= t("ui.properties.mine.saved_homes_title", default: "Saved homes") %></h2>
      </div>
    </div>

    <div class="property-workspace__grid">
      <% @saved_properties.each do |property| %>
        <article class="site-card property-workspace-card" data-testid="saved-property-card">
          <div class="property-workspace-card__media">
            <%= small_image_for(property) %>
          </div>

          <div class="property-workspace-card__content">
            <div class="property-workspace-card__badges">
              <span class="<%= property_sale_status_badge_class(property.sale_status) %>"><%= translated_sale_status(property.sale_status) %></span>
              <% unless property.listing_state == "published" %>
                <span class="<%= listing_state_badge_class(property.listing_state) %>"><%= translated_listing_state(property.listing_state) %></span>
              <% end %>
            </div>

            <div>
              <h2><%= link_to property.address_line_1, property_path(property) %></h2>
              <p><%= property.headline %></p>
            </div>

            <dl class="property-workspace-card__meta">
              <div>
                <dt><%= t("ui.properties.mine.stats.location", default: "Location") %></dt>
                <dd><%= property.location_line %></dd>
              </div>
              <div>
                <dt><%= t("ui.properties.mine.stats.price", default: "Guide price") %></dt>
                <dd><%= format_price(property) %></dd>
              </div>
              <div>
                <dt><%= t("ui.properties.mine.stats.last_saved", default: "Last saved") %></dt>
                <dd><%= formatted_date_time(property.updated_at) %></dd>
              </div>
              <div>
                <dt><%= t("ui.properties.mine.stats.status", default: "Status") %></dt>
                <dd><%= translated_listing_state(property.listing_state) %></dd>
              </div>
            </dl>

            <div class="property-workspace-card__actions">
              <%= link_to t("ui.properties.mine.open_details", default: "Open details"), property_path(property), class: "button primary" %>
              <%= button_to t("ui.saved_properties.saved_button", default: "Remove from saved list"), property_saved_property_path(property), method: :delete, class: "button primary hollow" %>
            </div>
          </div>
        </article>
      <% end %>
    </div>
  <% end %>

  <div class="section-heading">
    <div>
      <p class="section-heading__eyebrow"><%= t("ui.properties.mine.list_eyebrow", default: "Your records") %></p>
      <h2><%= t("ui.properties.mine.list_title", default: "Saved and partially completed listings") %></h2>
    </div>

    <div class="section-heading__actions">
      <%= link_to t("ui.site_header.add_property"), new_property_path, class: "button primary" %>
    </div>
  </div>

  <% if @properties.any? %>
    <div class="property-workspace__grid">
      <% @properties.each do |property| %>
        <article class="site-card property-workspace-card" data-testid="owner-property-card">
          <div class="property-workspace-card__media">
            <%= small_image_for(property) %>
          </div>

          <div class="property-workspace-card__content">
            <div class="property-workspace-card__badges">
              <span class="<%= property_sale_status_badge_class(property.sale_status) %>"><%= translated_sale_status(property.sale_status) %></span>
              <% unless property.listing_state == "published" %>
                <span class="<%= listing_state_badge_class(property.listing_state) %>"><%= translated_listing_state(property.listing_state) %></span>
              <% end %>
            </div>

            <div>
              <h2><%= link_to property.address_line_1, property_path(property) %></h2>
              <p><%= property.headline %></p>
            </div>

            <dl class="property-workspace-card__meta">
              <div>
                <dt><%= t("ui.properties.mine.stats.location", default: "Location") %></dt>
                <dd><%= property.location_line %></dd>
              </div>
              <div>
                <dt><%= t("ui.properties.mine.stats.price", default: "Guide price") %></dt>
                <dd><%= format_price(property) %></dd>
              </div>
              <div>
                <dt><%= t("ui.properties.mine.stats.readiness", default: "Readiness") %></dt>
                <dd><%= property.listing_completeness_percentage %>%</dd>
              </div>
              <div>
                <dt><%= t("ui.properties.mine.stats.last_saved", default: "Last saved") %></dt>
                <dd><%= formatted_date_time(property.updated_at) %></dd>
              </div>
            </dl>

            <p class="property-workspace-card__visibility">
              <%= property.publicly_visible? ? t("ui.properties.mine.visibility_live", default: "Visible on the public site.") : t("ui.properties.mine.visibility_private", default: "Only visible to you and admins until it is published.") %>
            </p>

            <% appointment_buckets = @appointments_by_property.fetch(property.id, { upcoming: [], previous: [], cancelled: [] }) %>

            <section class="property-workspace-card__appointments">
              <h3><%= t("ui.properties.mine.appointments_title", default: "Appointments") %></h3>

              <div class="property-workspace-card__appointment-groups">
                <div>
                  <p class="property-workspace-card__appointment-heading"><%= t("ui.properties.mine.upcoming_appointments", default: "Upcoming") %></p>
                  <% if appointment_buckets[:upcoming].any? %>
                    <div class="property-workspace-card__appointment-list">
                      <% appointment_buckets[:upcoming].each do |appointment| %>
                        <div class="property-workspace-card__appointment">
                          <div>
                            <strong><%= appointment.customer_name %></strong>
                            <p><%= appointment.customer_email %> · <%= formatted_date_time(appointment.scheduled_at) %></p>
                          </div>
                          <div class="property-workspace-card__appointment-actions">
                            <span class="<%= appointment_status_badge_class(appointment.status) %>"><%= appointment.display_status %></span>
                            <%= link_to t("ui.properties.mine.open_details", default: "Open details"), property_path(property), class: "button hollow secondary" %>
                          </div>
                        </div>
                      <% end %>
                    </div>
                  <% else %>
                    <p class="empty-copy"><%= t("ui.properties.mine.no_upcoming_appointments", default: "No upcoming appointments.") %></p>
                  <% end %>
                </div>

                <div>
                  <p class="property-workspace-card__appointment-heading"><%= t("ui.properties.mine.previous_appointments", default: "Previous") %></p>
                  <% if appointment_buckets[:previous].any? %>
                    <div class="property-workspace-card__appointment-list">
                      <% appointment_buckets[:previous].each do |appointment| %>
                        <div class="property-workspace-card__appointment">
                          <div>
                            <strong><%= appointment.customer_name %></strong>
                            <p><%= appointment.customer_email %> · <%= formatted_date_time(appointment.scheduled_at) %></p>
                          </div>
                          <div class="property-workspace-card__appointment-actions">
                            <span class="<%= appointment_status_badge_class(appointment.status) %>"><%= appointment.display_status %></span>
                            <%= link_to t("ui.properties.mine.open_details", default: "Open details"), property_path(property), class: "button hollow secondary" %>
                          </div>
                        </div>
                      <% end %>
                    </div>
                  <% else %>
                    <p class="empty-copy"><%= t("ui.properties.mine.no_previous_appointments", default: "No previous appointments.") %></p>
                  <% end %>
                </div>

                <div>
                  <p class="property-workspace-card__appointment-heading"><%= t("ui.properties.mine.cancelled_appointments", default: "Cancelled") %></p>
                  <% if appointment_buckets[:cancelled].any? %>
                    <div class="property-workspace-card__appointment-list">
                      <% appointment_buckets[:cancelled].each do |appointment| %>
                        <div class="property-workspace-card__appointment">
                          <div>
                            <strong><%= appointment.customer_name %></strong>
                            <p><%= appointment.customer_email %> · <%= formatted_date_time(appointment.scheduled_at) %></p>
                          </div>
                          <div class="property-workspace-card__appointment-actions">
                            <span class="<%= appointment_status_badge_class(appointment.status) %>"><%= appointment.display_status %></span>
                            <%= link_to t("ui.properties.mine.open_details", default: "Open details"), property_path(property), class: "button hollow secondary" %>
                          </div>
                        </div>
                      <% end %>
                    </div>
                  <% else %>
                    <p class="empty-copy"><%= t("ui.properties.mine.no_cancelled_appointments", default: "No cancelled appointments.") %></p>
                  <% end %>
                </div>
              </div>
            </section>

            <div class="property-workspace-card__actions">
              <%= link_to t("ui.properties.mine.open_details", default: "Open details"), property_path(property), class: "button primary" %>
              <%= link_to t("ui.properties.show.edit_listing"), edit_property_path(property), class: "button hollow secondary" %>
            </div>
          </div>
        </article>
      <% end %>
    </div>

    <div class="property-workspace__footer">
      <%= paginate @properties %>
    </div>
  <% else %>
    <section class="site-card empty-state">
      <p class="section-heading__eyebrow"><%= t("ui.properties.mine.list_eyebrow", default: "Your records") %></p>
      <h2><%= t("ui.properties.mine.empty_title", default: "No saved listings yet") %></h2>
      <p><%= t("ui.properties.mine.empty_body", default: "Create your first property and come back here whenever you want to continue working on it.") %></p>
      <div class="form-actions">
        <%= link_to t("ui.site_header.add_property"), new_property_path, class: "button primary" %>
      </div>
    </section>
  <% end %>
</section>
