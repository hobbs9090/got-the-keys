<% title t("ui.properties.mine.title", default: "My listings") %>

<section class="property-workspace">
  <h1 class="visually-hidden"><%= t("ui.properties.mine.title", default: "My listings") %></h1>
  <section class="site-card property-workspace-section <%= "property-workspace-section--empty-listings" if @properties.blank? %>" data-testid="owner-listings-section">
    <p class="section-heading__eyebrow"><%= t("ui.properties.mine.list_eyebrow", default: "Your records") %></p>
    <h2><%= t("ui.properties.mine.list_title", default: "Saved and partially completed listings") %></h2>
    <p><%= t("ui.properties.mine.list_blurb", default: "Draft and live listings you are working on are shown here for quick access.") %></p>

    <% if @properties.blank? %>
      <h3 class="property-workspace-section__empty-title"><%= t("ui.properties.mine.empty_title", default: "No saved listings yet") %></h3>
      <p><%= t("ui.properties.mine.empty_body", default: "Create your first property and come back here whenever you want to continue working on it.") %></p>
      <div class="property-workspace-section__actions">
        <%= link_to t("ui.site_header.add_property"), new_property_path, class: "button primary" %>
      </div>
    <% else %>
      <div class="property-workspace-section__actions">
        <%= link_to t("ui.site_header.add_property"), new_property_path, class: "button primary" %>
      </div>
      <%= render "properties/owner_properties_section" %>
    <% end %>
  </section>

  <section class="site-card property-workspace-section" data-testid="customer-bookings-section">
    <p class="section-heading__eyebrow"><%= t("ui.properties.mine.customer_bookings_eyebrow", default: "Your viewings") %></p>
    <h2><%= t("ui.properties.mine.customer_bookings_title", default: "Your bookings") %></h2>
    <p><%= t("ui.properties.mine.customer_bookings_blurb", default: "Upcoming, previous, and cancelled bookings are grouped here so you can track every viewing in one place.") %></p>

    <% if @customer_appointment_buckets.values.any?(&:any?) %>
      <section class="site-card property-workspace-panel property-workspace-panel--appointments" data-testid="customer-bookings-panel">
        <div class="property-workspace-bookings">
          <% [
            [:upcoming, t("ui.properties.mine.upcoming_appointments", default: "Upcoming"), t("ui.properties.mine.no_upcoming_appointments", default: "No upcoming appointments.")],
            [:previous, t("ui.properties.mine.previous_appointments", default: "Previous"), t("ui.properties.mine.no_previous_appointments", default: "No previous appointments.")],
            [:cancelled, t("ui.properties.mine.cancelled_appointments", default: "Cancelled"), t("ui.properties.mine.no_cancelled_appointments", default: "No cancelled appointments.")]
          ].each do |bucket_key, heading, empty_copy| %>
            <% appointments = @customer_appointment_buckets.fetch(bucket_key) %>

            <section class="property-workspace-bookings__section">
              <div class="property-workspace-bookings__header">
                <p class="property-workspace-card__appointment-heading"><%= heading %></p>
                <span class="badge badge--neutral"><%= display_number(appointments.count) %></span>
              </div>

              <% if appointments.any? %>
                <div class="property-workspace-card__appointment-list">
                  <% appointments.each do |appointment| %>
                    <div class="property-workspace-card__appointment property-workspace-card__appointment--customer" data-testid="customer-booking-row">
                      <div class="property-workspace-bookings__details">
                        <span class="<%= property_sale_status_badge_class(appointment.property.sale_status) %>" data-testid="customer-booking-sale-status-<%= appointment.id %>"><%= translated_sale_status(appointment.property.sale_status) %></span>
                        <strong><%= appointment.property.address_line_1 %></strong>
                        <p><%= formatted_date_time(appointment.scheduled_at) %></p>
                        <p><%= appointment.property.location_line %></p>
                      </div>
                      <div class="property-workspace-card__appointment-actions">
                        <span class="<%= appointment_status_badge_class(appointment.status) %>"><%= appointment.display_status %></span>
                        <%= link_to t("ui.properties.mine.open_details", default: "Open details"), property_path(appointment.property), class: "button primary property-workspace-card__appointment-button" %>
                        <%= link_to t("ui.properties.mine.view_booking", default: "View booking"), appointment_path(appointment, token: appointment.access_token), class: "button hollow primary property-workspace-card__appointment-button" %>
                      </div>
                    </div>
                  <% end %>
                </div>
              <% else %>
                <p class="empty-copy"><%= empty_copy %></p>
              <% end %>
            </section>
          <% end %>
        </div>
      </section>
    <% else %>
      <h3 class="property-workspace-section__empty-title"><%= t("ui.properties.mine.customer_bookings_empty_title", default: "No bookings yet") %></h3>
      <p class="empty-copy"><%= t("ui.properties.mine.customer_bookings_empty", default: "You do not have any bookings yet.") %></p>
    <% end %>
  </section>

  <section class="site-card property-workspace-section" data-testid="saved-homes-section">
      <p class="section-heading__eyebrow"><%= t("ui.properties.mine.saved_homes_eyebrow", default: "Your shortlist") %></p>
      <h2><%= t("ui.properties.mine.saved_homes_title", default: "Saved homes") %></h2>
      <p><%= t("ui.properties.mine.saved_homes_blurb", default: "Homes you have shortlisted stay here so you can jump back into details quickly.") %></p>

      <% if @saved_properties.any? %>
        <div class="property-workspace__grid">
          <% @saved_properties.each do |property| %>
          <article id="<%= dom_id(property, :saved_property_card) %>" class="site-card property-workspace-card" data-testid="saved-property-card">
            <div class="property-workspace-card__media">
              <%= small_image_for(property) %>
            </div>

            <div class="property-workspace-card__content">
              <div class="property-workspace-card__badges">
                <span class="<%= property_sale_status_badge_class(property.sale_status) %>"><%= translated_sale_status(property.sale_status) %></span>
                <% unless property.listing_state == "published" %>
                  <span class="<%= listing_state_badge_class(property.listing_state) %>"><%= translated_listing_state(property.listing_state) %></span>
                <% end %>
              </div>

              <div>
                <h2><%= link_to property.address_line_1, property_path(property) %></h2>
                <p><%= property.headline %></p>
              </div>

              <dl class="property-workspace-card__meta">
                <div>
                  <dt><%= t("ui.properties.mine.stats.location", default: "Location") %></dt>
                  <dd><%= property.location_line %></dd>
                </div>
                <div>
                  <dt><%= t("ui.properties.mine.stats.price", default: "Guide price") %></dt>
                  <dd><%= format_price(property) %></dd>
                </div>
                <div>
                  <dt><%= t("ui.properties.mine.stats.last_saved", default: "Last saved") %></dt>
                  <dd><%= formatted_date_time(property.updated_at) %></dd>
                </div>
                <div>
                  <dt><%= t("ui.properties.mine.stats.status", default: "Status") %></dt>
                  <dd><%= translated_listing_state(property.listing_state) %></dd>
                </div>
              </dl>

              <div class="property-workspace-card__actions">
                <%= link_to t("ui.properties.mine.open_details", default: "Open details"), property_path(property), class: "button primary" %>
                <%= button_to t("ui.saved_properties.saved_button", default: "Remove from saved list"), property_saved_property_path(property), method: :delete, class: "button primary hollow", form: { data: { turbo_stream: true } } %>
              </div>
            </div>
            </article>
          <% end %>
        </div>
      <% else %>
        <h3 class="property-workspace-section__empty-title"><%= t("ui.properties.mine.saved_homes_empty_title", default: "No saved homes yet") %></h3>
        <p class="empty-copy"><%= t("ui.properties.mine.saved_homes_empty", default: "Save homes from the catalogue to keep your shortlist in one place.") %></p>
      <% end %>
    </section>

  <section class="site-card property-workspace-section" id="saved-searches" data-testid="workspace-saved-searches">
    <p class="section-heading__eyebrow"><%= t("ui.properties.mine.saved_searches_eyebrow") %></p>
    <h2><%= t("ui.properties.mine.saved_searches_title") %></h2>
    <p><%= t("ui.properties.mine.saved_searches_blurb", default: "Your saved filter combinations are listed here so you can reopen matching results anytime.") %></p>

    <% if @saved_searches.blank? %>
      <h3 class="property-workspace-section__empty-title"><%= t("ui.properties.mine.saved_searches_empty_title", default: "No saved searches yet") %></h3>
      <p class="empty-copy"><%= t("ui.properties.mine.saved_searches_empty") %></p>
    <% else %>
      <%= render "properties/saved_searches_cards", saved_searches: @saved_searches %>
    <% end %>
  </section>

</section>
