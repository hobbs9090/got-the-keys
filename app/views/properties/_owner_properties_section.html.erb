<div class="property-workspace__grid">
  <% @properties.each do |property| %>
    <article class="site-card property-workspace-card" data-testid="owner-property-card">
      <div class="property-workspace-card__media">
        <%= small_image_for(property) %>
      </div>

      <div class="property-workspace-card__content">
        <div class="property-workspace-card__badges">
          <span class="<%= property_sale_status_badge_class(property.sale_status) %>"><%= translated_sale_status(property.sale_status) %></span>
          <% unless property.listing_state == "published" %>
            <span class="<%= listing_state_badge_class(property.listing_state) %>"><%= translated_listing_state(property.listing_state) %></span>
          <% end %>
        </div>

        <div>
          <h2><%= link_to property.address_line_1, property_path(property) %></h2>
          <p><%= property.headline %></p>
        </div>

        <dl class="property-workspace-card__meta">
          <div>
            <dt><%= t("ui.properties.mine.stats.location", default: "Location") %></dt>
            <dd><%= property.location_line %></dd>
          </div>
          <div>
            <dt><%= t("ui.properties.mine.stats.price", default: "Guide price") %></dt>
            <dd><%= format_price(property) %></dd>
          </div>
          <div>
            <dt><%= t("ui.properties.mine.stats.readiness", default: "Readiness") %></dt>
            <dd><%= property.listing_completeness_percentage %>%</dd>
          </div>
          <div>
            <dt><%= t("ui.properties.mine.stats.last_saved", default: "Last saved") %></dt>
            <dd><%= formatted_date_time(property.updated_at) %></dd>
          </div>
        </dl>

        <p class="property-workspace-card__visibility">
          <%= property.publicly_visible? ? t("ui.properties.mine.visibility_live", default: "Visible on the public site.") : t("ui.properties.mine.visibility_private", default: "Only visible to you and admins until it is published.") %>
        </p>
        <% appointment_buckets = @appointments_by_property.fetch(property.id, { upcoming: [], previous: [], cancelled: [] }) %>

        <section class="property-workspace-card__appointments">
          <h3><%= t("ui.properties.mine.appointments_title", default: "Appointments") %></h3>

          <div class="property-workspace-bookings">
            <% [
              [:upcoming, t("ui.properties.mine.upcoming_appointments", default: "Upcoming"), t("ui.properties.mine.no_upcoming_appointments", default: "No upcoming appointments.")],
              [:previous, t("ui.properties.mine.previous_appointments", default: "Previous"), t("ui.properties.mine.no_previous_appointments", default: "No previous appointments.")],
              [:cancelled, t("ui.properties.mine.cancelled_appointments", default: "Cancelled"), t("ui.properties.mine.no_cancelled_appointments", default: "No cancelled appointments.")]
            ].each do |bucket_key, heading, empty_copy| %>
              <% appointments = appointment_buckets.fetch(bucket_key) %>

              <section class="property-workspace-bookings__section">
                <div class="property-workspace-bookings__header">
                  <p class="property-workspace-card__appointment-heading"><%= heading %></p>
                  <span class="badge badge--neutral"><%= appointments.count %></span>
                </div>

                <% if appointments.any? %>
                  <div class="property-workspace-card__appointment-list">
                    <% appointments.each do |appointment| %>
                      <div class="property-workspace-card__appointment property-workspace-card__appointment--customer">
                        <div class="property-workspace-bookings__details">
                          <strong><%= appointment.customer_name %></strong>
                          <p><%= appointment.customer_email %> · <%= formatted_date_time(appointment.scheduled_at) %></p>
                        </div>
                        <div class="property-workspace-card__appointment-actions">
                          <span class="<%= appointment_status_badge_class(appointment.status) %>"><%= appointment.display_status %></span>
                          <%= link_to t("ui.properties.mine.open_details", default: "Open details"), appointment_path(appointment, token: appointment.access_token), class: "button hollow secondary" %>
                        </div>
                      </div>
                    <% end %>
                  </div>
                <% else %>
                  <p class="empty-copy"><%= empty_copy %></p>
                <% end %>
              </section>
            <% end %>
          </div>
        </section>

        <div class="property-workspace-card__actions">
          <%= link_to t("ui.properties.mine.open_details", default: "Open details"), property_path(property), class: "button primary" %>
          <%= link_to t("ui.properties.show.edit_listing"), edit_property_path(property), class: "button hollow secondary" %>
        </div>
      </div>
    </article>
  <% end %>
</div>

<div class="property-workspace__footer">
  <%= paginate @properties %>
</div>
