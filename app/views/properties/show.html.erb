<% title "#{@property.address_line_1} | #{t('gotthekeys.gotthekeys')}" %>
<% meta_description "#{@property.headline.presence || @property.property_type} in #{@property.town_city}. #{format_price(@property)}. #{pluralize(@property.bedrooms, 'bedroom')}, #{pluralize(@property.bathrooms, 'bathroom')}." %>

<section class="property-hero" data-testid="property-showcase">
  <div class="property-hero__content">
    <div class="property-hero__labels">
      <span class="<%= property_sale_status_badge_class(@property.sale_status) %>"><%= translated_sale_status(@property.sale_status) %></span>
      <% unless @property.listing_state == "published" %>
        <span class="<%= listing_state_badge_class(@property.listing_state) %>"><%= translated_listing_state(@property.listing_state) %></span>
      <% end %>
      <% if @property.featured? %>
        <span class="<%= property_featured_badge_class %>"><%= t("ui.common.featured") %></span>
      <% end %>
    </div>

    <p class="property-hero__eyebrow"><%= property_location_label(@property) %></p>
    <div class="property-hero__title-block">
      <h1><%= @property.address_line_1 %></h1>
      <p class="property-hero__headline"><%= @property.headline %></p>
    </div>

    <div class="property-hero__details">
      <div class="property-hero__price">
        <strong><%= format_price(@property) %></strong>
        <% if chinese_locale? %>
          <span><%= format_renminbi(@property) %></span>
        <% end %>
      </div>

      <dl class="property-hero__meta">
        <div>
          <dt><%= t("properties.bedrooms") %></dt>
          <dd><%= format_bedrooms(@property) %></dd>
        </div>
        <div>
          <dt><%= t("ui.common.bathrooms") %></dt>
          <dd><%= format_bathrooms(@property.bathrooms) %></dd>
        </div>
        <div>
          <dt><%= t("ui.common.postcode") %></dt>
          <dd><%= @property.postcode %></dd>
        </div>
        <% if @property.available_from.present? %>
          <div>
            <dt><%= t("ui.properties.show.available_from") %></dt>
            <dd><%= l(@property.available_from, format: :long) %></dd>
          </div>
        <% end %>
      </dl>
    </div>
  </div>

  <div class="property-hero__media property-hero__media--ratio-3-2">
    <%= medium_image_for(@property) %>
  </div>
</section>

<section class="property-layout">
  <article class="property-panel">
    <h2><%= t("ui.common.overview") %></h2>
    <p><%= @property.property_description %></p>

    <% if property_fact_rows(@property).any? %>
      <div class="property-address">
        <h3><%= t("ui.properties.show.key_facts_title") %></h3>
        <dl class="detail-list">
          <% property_fact_rows(@property).each do |label, value| %>
            <div>
              <dt><%= label %></dt>
              <dd><%= value %></dd>
            </div>
          <% end %>
        </dl>
      </div>
    <% end %>

    <div class="property-address">
      <h3><%= t("ui.common.address") %></h3>
      <p><%= [@property.address_line_1, @property.address_line_2, @property.town_city, @property.county, @property.postcode, @property.country].reject(&:blank?).join(", ") %></p>
    </div>

    <% if @public_documents.any? %>
      <div class="property-address" data-testid="property-documents-panel">
        <h3><%= t("ui.properties.show.documents_title") %></h3>
        <ul class="detail-inline-list">
          <% @public_documents.each do |document| %>
            <li>
              <strong><%= document.title %></strong>
              (<%= document.category_label %>)
              <%= link_to t("ui.common.download"), download_property_property_document_path(@property, document), class: "button hollow secondary", download: document.file_name, data: { testid: "property-document-download-#{document.id}", turbo: false } %>
            </li>
          <% end %>
        </ul>
      </div>
    <% end %>
  </article>

  <aside class="property-booking-panel" data-testid="booking-panel" id="booking-panel">
    <% if current_user != @property.user %>
      <div class="empty-state property-booking-panel__support-card property-booking-panel__save-card" data-testid="property-save-panel">
        <h3><%= t("ui.saved_properties.panel_title", default: "Save this listing") %></h3>
        <p>
          <%= user_signed_in? ?
                t("ui.saved_properties.panel_body", default: "Keep this home handy so you can come back to it without searching again.") :
                t("ui.saved_properties.panel_body_guest", default: "Keep this home handy so you can come back to it without searching again. Sign in or create an account to save listings.") %>
        </p>

        <% if user_signed_in? %>
          <% if @saved_property.present? %>
            <%= button_to t("ui.saved_properties.saved_button", default: "Remove from saved list"), property_saved_property_path(@property), method: :delete, class: "button primary hollow expanded", data: { testid: "unsave-property-button" } %>
          <% else %>
            <%= button_to t("ui.saved_properties.save_button", default: "Save property"), property_saved_property_path(@property), method: :post, class: "button primary expanded", data: { testid: "save-property-button" } %>
          <% end %>
        <% else %>
          <%= link_to t("ui.saved_properties.sign_in_to_save", default: "Sign in to save"), new_user_session_path(return_to: property_path(@property), save_property_id: @property.id), class: "button primary expanded", data: { testid: "save-property-sign-in-link" } %>
        <% end %>
      </div>
    <% end %>

    <% if user_signed_in? %>
      <h2><%= t("ui.common.book_a_viewing") %></h2>
      <p><%= t("ui.properties.show.booking_body") %></p>
      <%= render "shared/errors", object: @appointment %>

      <% if @available_slots.any? %>
        <%= form_with model: [@property, @appointment], local: true, class: "stacked-form", data: { testid: "appointment-form" } do |f| %>
          <div>
            <%= f.label :customer_name, t("ui.common.full_name"), **form_label_options(@appointment, :customer_name) %>
            <%= f.text_field :customer_name, required: true, autocomplete: "name", maxlength: 100, **form_control_options(@appointment, :customer_name) %>
            <%= field_error_messages(@appointment, :customer_name) %>
          </div>

          <div>
            <%= f.label :customer_email, t("ui.common.email_address"), **form_label_options(@appointment, :customer_email) %>
            <%= f.email_field :customer_email,
                              required: true,
                              autocomplete: "email",
                              readonly: user_signed_in?,
                              **form_control_options(@appointment, :customer_email) %>
            <%= field_error_messages(@appointment, :customer_email) %>
          </div>

          <div>
            <%= f.label :customer_phone, t("ui.common.phone_number"), **form_label_options(@appointment, :customer_phone) %>
            <%= f.telephone_field :customer_phone, required: true, autocomplete: "tel", maxlength: 20, **form_control_options(@appointment, :customer_phone) %>
            <%= field_error_messages(@appointment, :customer_phone) %>
          </div>

          <div>
            <%= f.label :requested_time, t("ui.appointments.new.preferred_slot"), **form_label_options(@appointment, :requested_time) %>
          <%= render "appointments/slot_picker",
                     slots: @available_slots,
                     field_name: "appointment[requested_time]",
                     field_id: "appointment_requested_time",
                     selected_value: @appointment.requested_time&.iso8601,
                     eyebrow: t("ui.appointments.new.preferred_slot"),
                     summary_prefix: t("ui.appointments.new.preferred_slot"),
                     empty_summary: t("ui.appointments.new.choose_slot"),
                     date_label: t("ui.appointments.new.preferred_slot"),
                     fallback_label: t("ui.appointments.new.preferred_slot"),
                     fallback_prompt: t("ui.appointments.new.choose_slot"),
                     testid: "requested-time-picker" %>
            <%= field_error_messages(@appointment, :requested_time) %>
          </div>

          <div>
            <%= f.label :notes, t("ui.appointments.new.notes_label"), **form_label_options(@appointment, :notes) %>
            <%= f.text_area :notes, rows: 4, maxlength: 2000, placeholder: t("ui.appointments.new.notes_placeholder"), **form_control_options(@appointment, :notes) %>
            <%= field_error_messages(@appointment, :notes) %>
          </div>

          <div class="form-actions">
            <%= f.submit t("ui.appointments.new.submit"), class: "button primary expanded", data: { testid: "book-viewing-cta" } %>
          </div>
        <% end %>
      <% else %>
        <div class="empty-state">
          <h3><%= t("ui.properties.show.no_slots_title") %></h3>
          <p><%= t("ui.properties.show.no_slots_body") %></p>
        </div>
      <% end %>
    <% else %>
      <div class="empty-state property-booking-panel__support-card" data-testid="book-viewing-sign-in-panel">
        <h3><%= t("ui.common.book_a_viewing") %></h3>
        <p><%= t("ui.properties.show.booking_sign_in_body", default: "Sign in or create an account to request a viewing and pick from the published time slots for this home.") %></p>
        <%= link_to t("ui.properties.show.booking_sign_in_cta", default: "Sign in to book a viewing"), new_user_session_path(return_to: property_path(@property, anchor: "booking-panel")), class: "button primary expanded", data: { testid: "book-viewing-sign-in-link" } %>
      </div>
    <% end %>

    <div class="empty-state property-booking-panel__support-card" data-testid="property-enquiry-panel">
      <h3><%= t("ui.properties.show.enquiry_title") %></h3>
      <p><%= user_signed_in? ? t("ui.properties.show.enquiry_body") : t("ui.properties.show.enquiry_body_guest", default: "Sign in or create an account to ask for brochure information, a landlord or seller callback, or clarification before you pick a viewing slot.") %></p>
      <%= link_to t("ui.properties.show.enquiry_cta"), (user_signed_in? ? new_property_enquiry_path(@property) : new_user_session_path(return_to: property_path(@property, anchor: "booking-panel"))), class: "button primary expanded", data: { testid: "open-enquiry-form" } %>
    </div>

    <% if @property.sale_status == Property::SALE_STATUSES[:for_sale] %>
      <div class="empty-state property-booking-panel__support-card" data-testid="property-offer-panel">
        <h3><%= t("ui.properties.show.offer_title") %></h3>
        <p><%= user_signed_in? ? t("ui.properties.show.offer_body") : t("ui.properties.show.offer_body_guest", default: "Sign in or create an account to register your buying position and submit an offer.") %></p>
        <%= link_to t("ui.properties.show.offer_cta"), (user_signed_in? ? new_property_offer_path(@property) : new_user_session_path(return_to: property_path(@property, anchor: "booking-panel"))), class: "button primary expanded", data: { testid: "open-offer-form" } %>
      </div>
    <% elsif @property.sale_status == Property::SALE_STATUSES[:for_rent] %>
      <div class="empty-state property-booking-panel__support-card" data-testid="property-rental-application-panel">
        <h3><%= t("ui.properties.show.rental_application_title") %></h3>
        <p><%= user_signed_in? ? t("ui.properties.show.rental_application_body") : t("ui.properties.show.rental_application_body_guest", default: "Sign in or create an account to share your intended move-in timing and affordability notes with the lettings team.") %></p>
        <%= link_to t("ui.properties.show.rental_application_cta"), (user_signed_in? ? new_property_rental_application_path(@property) : new_user_session_path(return_to: property_path(@property, anchor: "booking-panel"))), class: "button primary expanded", data: { testid: "open-rental-application-form" } %>
      </div>
    <% end %>

    <div class="empty-state property-booking-panel__support-card property-branch-card" data-testid="property-branch-card">
      <h3><%= primary_branch_profile[:name] %></h3>
      <p><%= primary_branch_profile[:response_time] %></p>
      <p><%= primary_branch_profile[:phone] %> · <%= primary_branch_profile[:email] %></p>
      <p><%= primary_branch_profile[:hours] %></p>
    </div>
  </aside>
</section>

<% if current_user == @property.user %>
  <section class="property-workspace property-workspace--seller">
    <article class="property-panel" data-testid="seller-listing-workspace">
      <h2><%= t("ui.properties.show.seller_title") %></h2>
      <p><strong><%= @property.listing_completeness_percentage %>%</strong> <%= t("ui.properties.show.readiness_summary", score: @property.listing_completeness_score, total: @property.listing_completeness_checks.size, display_score: display_number(@property.listing_completeness_score), display_total: display_number(@property.listing_completeness_checks.size)) %></p>
      <ul class="detail-inline-list" data-testid="seller-listing-checklist">
        <% @property.listing_completeness_checks.each do |check| %>
          <li class="<%= check[:complete] ? 'text-success' : 'text-danger' %>">
            <strong><%= check[:complete] ? t("ui.properties.show.done") : t("ui.properties.show.needed") %></strong>: <%= check[:label] %>
          </li>
        <% end %>
      </ul>
      <div class="section-heading__actions">
        <%= link_to t("ui.properties.show.edit_listing"), edit_property_path(@property), class: "button primary" %>
        <%= link_to t("ui.properties.show.manage_photos"), property_photos_path(@property), class: "button hollow secondary", data: { testid: "manage-photos-link" } %>
        <%= link_to t("ui.properties.show.manage_floor_plans"), property_floor_plans_path(@property), class: "button hollow secondary" %>
        <%= link_to t("ui.properties.show.manage_documents"), property_property_documents_path(@property), class: "button hollow secondary", data: { testid: "manage-documents-link" } %>
      </div>

      <h3><%= t("ui.properties.show.recent_lead_activity_title") %></h3>
      <% if @recent_enquiries.any? %>
        <ul class="detail-inline-list" data-testid="seller-recent-enquiries">
          <% @recent_enquiries.each do |enquiry| %>
            <li>
              <strong><%= enquiry.customer_name %></strong>:
              <%= enquiry_source_label(enquiry.source_type) %>,
              <%= enquiry.display_status.downcase %>,
              <%= l(enquiry.created_at, format: :long) %>
            </li>
          <% end %>
        </ul>
      <% else %>
        <p class="empty-copy"><%= t("ui.properties.show.no_enquiries") %></p>
      <% end %>

      <% if @property.sale_status == Property::SALE_STATUSES[:for_sale] %>
        <h3><%= t("ui.properties.show.recent_offers_title") %></h3>
        <% if @recent_offers.any? %>
          <ul class="detail-inline-list" data-testid="seller-recent-offers">
            <% @recent_offers.each do |offer| %>
              <li>
                <strong><%= offer.buyer_name %></strong>:
                <%= number_to_currency(offer.amount, unit: "£", precision: 0) %>,
                <%= t("ui.offers.statuses.#{offer.status}", default: offer.status.humanize.downcase) %>
              </li>
            <% end %>
          </ul>
        <% else %>
          <p class="empty-copy"><%= t("ui.properties.show.no_offers") %></p>
        <% end %>
      <% elsif @property.sale_status == Property::SALE_STATUSES[:for_rent] %>
        <h3><%= t("ui.properties.show.recent_rental_applications_title") %></h3>
        <% if @recent_rental_applications.any? %>
          <ul class="detail-inline-list" data-testid="seller-recent-rental-applications">
            <% @recent_rental_applications.each do |application| %>
              <li>
                <strong><%= application.applicant_name %></strong>:
                <%= t("ui.rental_applications.statuses.#{application.status}", default: application.status.humanize.downcase) %>,
                <%= t("ui.properties.show.move_in", date: l(application.move_in_date, format: :long)) %>
              </li>
            <% end %>
          </ul>
        <% else %>
          <p class="empty-copy"><%= t("ui.properties.show.no_rental_applications") %></p>
        <% end %>
      <% end %>

      <h3><%= t("ui.properties.show.recent_listing_activity_title") %></h3>
      <% if @recent_activity.any? %>
        <ol class="timeline" data-testid="seller-property-activity-timeline">
          <% @recent_activity.each do |entry| %>
            <li>
              <strong><%= property_activity_action_label(entry.action) %></strong>
              <span><%= formatted_date_time(entry.occurred_at) %></span>
              <p><%= entry.message %></p>
            </li>
          <% end %>
        </ol>
      <% else %>
        <p class="empty-copy"><%= t("ui.properties.show.no_listing_activity") %></p>
      <% end %>
    </article>
  </section>
<% end %>
