<% title t('properties.title') %>
<% active_filter_labels = property_filter_chip_labels(@filters) %>
<% current_scope = @filters[:sale_status].presence %>

<section class="page-hero property-catalogue-hero">
  <div>
    <div class="page-hero__brand">
      <%= render "layouts/gotthekeys", class_name: "marketing-wordmark--hero", decorative: true, width: 248 %>
    </div>
    <p class="page-hero__eyebrow"><%= t("ui.properties.catalogue.eyebrow") %></p>
    <h1><%= t("ui.properties.catalogue.hero_title") %></h1>
    <p><%= t("ui.properties.catalogue.hero_body") %></p>
  </div>

  <div class="page-hero__meta property-catalogue-hero__meta">
    <span class="badge badge--neutral">
      <%= active_filter_labels.any? ? t("ui.properties.catalogue.active_filter_count", count: active_filter_labels.count) : t("ui.properties.catalogue.overview_badge") %>
    </span>
    <strong><%= number_with_delimiter(@total_properties, delimiter: ",") %></strong>
    <span><%= t("ui.properties.catalogue.matching_properties", count: @total_properties) %></span>
  </div>
</section>

<section class="property-catalogue">
  <aside class="property-catalogue__sidebar">
    <section class="site-card property-catalogue__browse">
      <p class="section-heading__eyebrow"><%= t("ui.properties.catalogue.browse_eyebrow") %></p>
      <h2><%= t("ui.properties.catalogue.browse_title") %></h2>
      <p><%= t("ui.properties.catalogue.browse_body") %></p>

      <div class="segmented-links property-catalogue__scope-links">
        <%= link_to t("ui.properties.catalogue.all_listings"), properties_path, class: ("is-active" if current_scope.blank?) %>
        <%= link_to t("ui.properties.sale_statuses.for_sale"), for_sale_index_path, class: ("is-active" if current_scope == Property::SALE_STATUSES[:for_sale]) %>
        <%= link_to t("ui.properties.sale_statuses.for_rent"), for_rent_index_path, class: ("is-active" if current_scope == Property::SALE_STATUSES[:for_rent]) %>
      </div>

      <dl class="property-catalogue__totals">
        <div>
          <dt><%= t("ui.properties.catalogue.totals.all") %></dt>
          <dd><%= number_with_delimiter(@catalogue_totals[:all], delimiter: ",") %></dd>
        </div>
        <div>
          <dt><%= t("ui.properties.sale_statuses.for_sale") %></dt>
          <dd><%= number_with_delimiter(@catalogue_totals[:for_sale], delimiter: ",") %></dd>
        </div>
        <div>
          <dt><%= t("ui.properties.sale_statuses.for_rent") %></dt>
          <dd><%= number_with_delimiter(@catalogue_totals[:for_rent], delimiter: ",") %></dd>
        </div>
      </dl>
    </section>

    <section class="site-card property-catalogue__filters">
      <div class="property-results-panel__head">
        <div>
          <p class="section-heading__eyebrow"><%= t("ui.properties.catalogue.filters_eyebrow") %></p>
          <h2><%= t("ui.properties.catalogue.filters_title") %></h2>
        </div>

        <% if active_filter_labels.any? %>
          <span class="badge badge--accent"><%= t("ui.properties.catalogue.active_filter_count", count: active_filter_labels.count) %></span>
        <% end %>
      </div>

      <p class="property-catalogue__sidebar-copy"><%= t("ui.properties.catalogue.sidebar_copy") %></p>

      <%= render "properties/filters", url: properties_path, selected_sale_status: params[:sale_status], show_status_select: true %>
    </section>

    <section class="site-card property-catalogue__saved-search" data-testid="saved-search-panel">
      <p class="section-heading__eyebrow"><%= t("ui.properties.catalogue.saved_search.eyebrow") %></p>
      <h2><%= t("ui.properties.catalogue.saved_search.title") %></h2>
      <p class="property-catalogue__sidebar-copy"><%= t("ui.properties.catalogue.saved_search.body") %></p>

      <%= form_with model: @saved_search, url: saved_searches_path, class: "saved-search-form" do |f| %>
        <%= f.hidden_field :locale %>
        <%= f.hidden_field :sale_status %>
        <%= f.hidden_field :search_query %>
        <%= f.hidden_field :town_city %>
        <%= f.hidden_field :min_bedrooms %>
        <%= f.hidden_field :min_price %>
        <%= f.hidden_field :max_price %>
        <%= f.hidden_field :sort %>

        <div>
          <%= f.label :email, t("ui.common.email_address") %>
          <%= f.email_field :email, placeholder: t("ui.properties.catalogue.saved_search.email_placeholder") %>
        </div>

        <div class="form-grid__checkbox">
          <%= f.check_box :alerts_enabled %>
          <%= f.label :alerts_enabled, t("ui.properties.catalogue.saved_search.alerts_enabled"), class: "checkbox-label" %>
        </div>

        <div class="form-actions">
          <%= f.submit t("ui.properties.catalogue.saved_search.submit"), class: "button primary expanded", data: { testid: "save-search-button" } %>
        </div>
      <% end %>
    </section>

    <section class="site-card property-catalogue__branch-card">
      <p class="section-heading__eyebrow"><%= t("ui.properties.catalogue.local_team_eyebrow") %></p>
      <h2><%= primary_branch_profile[:name] %></h2>
      <ul class="detail-inline-list">
        <li><strong><%= primary_branch_profile[:team_label] %></strong></li>
        <li><%= primary_branch_profile[:response_time] %></li>
        <li><%= primary_branch_profile[:phone] %></li>
        <li><%= primary_branch_profile[:email] %></li>
      </ul>
    </section>
  </aside>

  <div class="property-catalogue__content">
    <section class="site-card property-results-panel">
      <div class="property-results-panel__head">
        <div>
          <p class="section-heading__eyebrow"><%= t("ui.properties.catalogue.results_eyebrow") %></p>
          <h2><%= t("ui.properties.catalogue.results_title", count: @total_properties) %></h2>
        </div>

        <div class="property-results-panel__meta">
          <span class="badge badge--neutral"><%= property_sort_label(@filters[:sort].presence || "recommended") %></span>
          <% if active_filter_labels.any? %>
            <%= link_to t("ui.common.clear_all"), properties_path, class: "button secondary hollow" %>
          <% end %>
        </div>
      </div>

      <% if active_filter_labels.any? %>
        <div class="property-results-panel__chips">
          <% active_filter_labels.each do |label| %>
            <span class="badge badge--neutral"><%= label %></span>
          <% end %>
        </div>
      <% else %>
        <p class="property-results-panel__empty-copy"><%= t("ui.properties.catalogue.empty_copy") %></p>
      <% end %>

      <div class="property-results-panel__pagination">
        <%= paginate @properties %>
      </div>
    </section>

    <%= render "properties/property" %>

    <div class="property-results-panel__footer">
      <%= paginate @properties %>
    </div>
  </div>
</section>
