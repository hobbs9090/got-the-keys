<% form_model = local_assigns.fetch(:form_model, @property) %>
<% cancel_path = local_assigns.fetch(:cancel_path, properties_path) %>
<% allow_destroy = local_assigns.fetch(:allow_destroy, true) %>

<%= form_with model: form_model do |f| %>
  <%= render "shared/errors", object: form_model %>

  <div class="form-grid">
    <div>
      <%= f.label :address_line_1, nil, **form_label_options(form_model, :address_line_1) %>
      <%= f.text_field :address_line_1, autofocus: true, required: true, maxlength: 50, **form_control_options(form_model, :address_line_1) %>
      <%= field_error_messages(form_model, :address_line_1) %>
    </div>
    <div>
      <%= f.label :address_line_2, nil, **form_label_options(form_model, :address_line_2) %>
      <%= f.text_field :address_line_2, maxlength: 50, **form_control_options(form_model, :address_line_2) %>
      <%= field_error_messages(form_model, :address_line_2) %>
    </div>
    <div>
      <%= f.label :town_city, nil, **form_label_options(form_model, :town_city) %>
      <%= f.text_field :town_city, required: true, maxlength: 50, **form_control_options(form_model, :town_city) %>
      <%= field_error_messages(form_model, :town_city) %>
    </div>
    <div>
      <%= f.label :county, nil, **form_label_options(form_model, :county) %>
      <%= f.text_field :county, required: true, maxlength: 50, **form_control_options(form_model, :county) %>
      <%= field_error_messages(form_model, :county) %>
    </div>
    <div>
      <%= f.label :postcode, nil, **form_label_options(form_model, :postcode) %>
      <%= f.text_field :postcode, required: true, maxlength: 50, **form_control_options(form_model, :postcode) %>
      <%= field_error_messages(form_model, :postcode) %>
    </div>
    <div>
      <%= f.label :country, nil, **form_label_options(form_model, :country) %>
      <%= f.text_field :country, required: true, maxlength: 50, **form_control_options(form_model, :country) %>
      <%= field_error_messages(form_model, :country) %>
    </div>
    <div>
      <%= f.label :property_type, "Property type", **form_label_options(form_model, :property_type) %>
      <%= f.text_field :property_type, required: true, maxlength: 50, **form_control_options(form_model, :property_type) %>
      <%= field_error_messages(form_model, :property_type) %>
    </div>
    <div>
      <%= f.label :listing_tagline, "Tagline", **form_label_options(form_model, :listing_tagline) %>
      <%= f.text_field :listing_tagline, placeholder: "A calm family home close to the station", maxlength: 120, **form_control_options(form_model, :listing_tagline) %>
      <%= field_error_messages(form_model, :listing_tagline) %>
    </div>
    <div>
      <%= f.label :bedrooms, nil, **form_label_options(form_model, :bedrooms) %>
      <%= f.number_field :bedrooms, min: 0, step: 1, required: true, **form_control_options(form_model, :bedrooms) %>
      <%= field_error_messages(form_model, :bedrooms) %>
    </div>
    <div>
      <%= f.label :bathrooms, "Bathrooms", **form_label_options(form_model, :bathrooms) %>
      <%= f.number_field :bathrooms, min: 1, step: 1, required: true, **form_control_options(form_model, :bathrooms) %>
      <%= field_error_messages(form_model, :bathrooms) %>
    </div>
    <div>
      <%= f.label :sale_status, nil, **form_label_options(form_model, :sale_status) %>
      <%= f.select :sale_status, Property::SALE_STATUS, { prompt: t('properties.pick_one') }, form_control_options(form_model, :sale_status, classes: nil) %>
      <%= field_error_messages(form_model, :sale_status) %>
    </div>
    <div>
      <%= f.label :asking_price, nil, **form_label_options(form_model, :asking_price) %>
      <%= f.number_field :asking_price, min: 0, step: 1000, required: true, **form_control_options(form_model, :asking_price) %>
      <%= field_error_messages(form_model, :asking_price) %>
    </div>
    <div>
      <%= f.label :image_file_name, nil, **form_label_options(form_model, :image_file_name) %>
      <%= f.text_field :image_file_name, placeholder: "property_placeholder_listing.svg", **form_control_options(form_model, :image_file_name) %>
      <%= field_error_messages(form_model, :image_file_name) %>
    </div>
    <div class="form-grid__checkbox">
      <%= f.check_box :featured %>
      <%= f.label :featured, "Feature this listing", class: "checkbox-label" %>
    </div>
    <div class="form-grid__full">
      <%= f.label :property_description, nil, **form_label_options(form_model, :property_description) %>
      <%= f.text_area :property_description, rows: 10, required: true, maxlength: 5000, **form_control_options(form_model, :property_description) %>
      <%= field_error_messages(form_model, :property_description) %>
    </div>
  </div>

  <div class="form-actions">
    <%= f.submit class: "button primary" %>
    <%= link_to t('helpers.label.property.cancel'), cancel_path, class: 'button hollow secondary' %>
    <% if allow_destroy && !current_page?(controller: 'properties', action: 'new') %>
      <%= link_to t('helpers.label.property.delete_property'),
                  @property,
                  class: 'button alert hollow',
                  data: { turbo_method: :delete, turbo_confirm: t('helpers.label.property.are_you_sure') } %>
    <% end %>
  </div>
<% end %>
