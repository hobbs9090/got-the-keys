<% saved_searches = local_assigns.fetch(:saved_searches) %>

<div class="property-workspace__grid property-saved-searches-grid">
  <% saved_searches.each do |search| %>
    <% chip_labels = property_filter_chip_labels(search.filter_params) %>
    <article class="site-card property-saved-search-card" data-testid="saved-search-card">
      <div class="property-saved-search-card__main">
        <div class="property-saved-search-card__chips">
          <% if chip_labels.any? %>
            <% chip_labels.each do |label| %>
              <span class="badge badge--neutral"><%= label %></span>
            <% end %>
          <% else %>
            <span class="badge badge--neutral"><%= t("ui.properties.filters.all_listings") %></span>
          <% end %>
        </div>

        <p class="property-saved-search-card__meta">
          <span><%= t("ui.properties.catalogue.saved_search.saved_at", time: formatted_date_time(search.created_at)) %></span>
          <% if search.alerts_enabled %>
            <span class="badge badge--accent"><%= t("ui.properties.catalogue.saved_search.alerts_on") %></span>
          <% else %>
            <span class="badge badge--muted"><%= t("ui.properties.catalogue.saved_search.alerts_off") %></span>
          <% end %>
        </p>
      </div>

      <div class="property-saved-search-card__actions">
        <% matches_count = search.matching_properties_count %>
        <%= link_to t("ui.properties.catalogue.saved_search.view_matches", count: matches_count), properties_path(search.filter_params), class: "button primary hollow" %>
        <%= button_to t("ui.properties.catalogue.saved_search.remove"), saved_search_path(search), method: :delete, class: "button secondary hollow" %>
      </div>
    </article>
  <% end %>
</div>
