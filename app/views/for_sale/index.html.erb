<% title t('for_sale.title') %>

<section class="page-hero">
  <div>
    <div class="page-hero__brand">
      <%= render "layouts/gotthekeys", class_name: "marketing-wordmark--hero", decorative: true, width: 248 %>
    </div>
    <p class="page-hero__eyebrow">For sale</p>
    <h1>Homes available to buy</h1>
    <p>Use the filters to find stock by area, bedrooms, and price, then move into the booking flow from the listing details page.</p>
  </div>

  <div class="page-hero__meta">
    <strong><%= number_with_delimiter(@total_for_sale, delimiter: ",") %></strong>
    <span>sale listings</span>
  </div>
</section>

<section class="page-section">
  <%= render "properties/filters", url: for_sale_index_path, selected_sale_status: Property::SALE_STATUSES[:for_sale], show_status_select: false %>
</section>

<section class="page-section">
  <%= paginate @properties %>
  <%= render "properties/property" %>
  <%= paginate @properties %>
</section>
