<% title t('for_sale.title') %>

<section class="page-hero">
  <div>
    <p class="page-hero__eyebrow"><%= t("ui.for_sale.eyebrow") %></p>
    <h1><%= t("ui.for_sale.hero_title") %></h1>
    <p><%= t("ui.for_sale.hero_body") %></p>
  </div>

  <div class="page-hero__meta">
    <strong><%= number_with_delimiter(@total_for_sale, delimiter: ",") %></strong>
    <span><%= t("ui.for_sale.count_label", count: @total_for_sale) %></span>
  </div>
</section>

<section class="page-section">
  <%= render "properties/filters", url: for_sale_index_path, selected_sale_status: Property::SALE_STATUSES[:for_sale], show_status_select: false, catalogue_scope: "for_sale" %>
</section>

<section class="page-section">
  <%= render "properties/paginated_results", properties: @properties %>
</section>
