<% title t("ui.photos.title", address: @property.address_line_1) %>

<section class="page-hero">
  <div>
    <p class="page-hero__eyebrow"><%= t("ui.photos.eyebrow") %></p>
    <h1><%= t("ui.photos.heading") %></h1>
    <p><%= t("ui.photos.body") %></p>
  </div>
</section>

<section class="property-workspace property-workspace--seller">
  <%= render "properties/seller_workspace_panel", property: @property %>
</section>

<section class="page-section page-section--stacked-panels">
  <article class="property-panel">
    <h2><%= t("ui.photos.add_title") %></h2>
    <%= render "shared/errors", object: @new_photo %>

    <%= form_with model: [@property, @new_photo] do |f| %>
      <div class="form-grid">
        <div>
          <%= f.label :image_filename, t("ui.photos.fields.image_filename") %>
          <%= f.text_field :image_filename, placeholder: t("ui.photos.fields.image_filename_placeholder") %>
        </div>
        <div>
          <%= f.label :image_upload, t("ui.photos.fields.image_upload", default: "Upload image") %>
          <%= f.file_field :image_upload, accept: "image/jpeg,image/png,image/webp,image/gif,.jpg,.jpeg,.png,.webp,.gif" %>
        </div>
        <div>
          <%= f.label :caption, t("ui.photos.fields.caption") %>
          <%= f.text_field :caption, placeholder: t("ui.photos.fields.caption_placeholder") %>
        </div>
        <div>
          <%= f.label :position, t("ui.photos.fields.position") %>
          <%= f.number_field :position, min: 0, step: 1 %>
        </div>
        <div class="form-grid__checkbox">
          <% primary_radio_id = "new-photo-primary-#{@property.id}" %>
          <%= f.hidden_field :primary, value: false %>
          <%= f.radio_button :primary,
                             true,
                             id: primary_radio_id,
                             checked: @new_photo.primary?,
                             data: { primary_photo_radio: true, primary_photo_group: "property-#{@property.id}-photos" } %>
          <%= label_tag primary_radio_id, t("ui.photos.fields.primary"), class: "checkbox-label" %>
        </div>
      </div>

      <div class="form-actions">
        <%= f.submit t("ui.photos.actions.add"), class: "button primary", data: { testid: "add-photo-button" } %>
        <%= link_to t("ui.common.back_to_listing"), property_listing_edit_path(@property), class: "button hollow secondary" %>
      </div>
    <% end %>
  </article>

  <article class="property-panel">
    <h2><%= t("ui.photos.current_title") %></h2>
    <% listing_image_filename = @property.image_file_name.to_s.strip %>
    <% listing_image_in_photo_records = listing_image_filename.present? && @photos.any? { |photo| photo.image_filename.to_s == listing_image_filename } %>

    <% if listing_image_filename.present? || @photos.any? %>
      <div class="admin-list">
        <% if listing_image_filename.present? && !listing_image_in_photo_records %>
          <div class="admin-list__item">
            <div class="property-panel">
              <% if previewable_image_file?(listing_image_filename) %>
                <div class="admin-asset-item admin-asset-item--workspace-photo">
                  <%= image_tag listing_image_source(listing_image_filename),
                                alt: t("ui.photos.primary_listing_image", default: "Primary listing image"),
                                class: "admin-asset-item__thumbnail",
                                loading: "lazy",
                                data: { testid: "property-listing-image-thumbnail" } %>
                  <div>
                    <strong><%= t("ui.photos.primary_listing_image", default: "Primary listing image") %></strong>
                  </div>
                </div>
              <% end %>
              <div class="form-grid">
                <div>
                  <label><%= t("ui.photos.fields.image_filename") %></label>
                  <input type="text" value="<%= listing_image_filename %>" readonly data-testid="property-listing-image-filename">
                </div>
                <div>
                  <label><%= t("ui.photos.fields.caption") %></label>
                  <input type="text" value="<%= t("ui.photos.primary_listing_image", default: "Primary listing image") %>" readonly data-testid="property-listing-image-caption">
                </div>
              </div>
              <p class="empty-copy"><%= t("ui.photos.listing_image_note", default: "This image is attached to the listing record and can be updated from Edit listing.") %></p>
            </div>
          </div>
        <% end %>

        <% @photos.each do |photo| %>
          <% photo_form = photo == @edited_photo ? @edited_photo : photo %>
          <div class="admin-list__item">
            <div class="property-panel">
              <% if previewable_image_file?(photo.image_filename) %>
                <div class="admin-asset-item admin-asset-item--workspace-photo">
                  <%= image_tag listing_image_source(photo.image_filename),
                                alt: photo.primary? ? t("ui.photos.fields.primary_image", default: "Primary image") : photo.caption.presence || t("ui.photos.photo_position", position: photo.position, default: "Photo %{position}"),
                                class: "admin-asset-item__thumbnail",
                                loading: "lazy",
                                data: { testid: "property-photo-thumbnail-#{photo.id}" } %>
                  <div>
                    <strong><%= photo.primary? ? t("ui.photos.fields.primary_image", default: "Primary image") : t("ui.photos.photo_position", position: photo.position, default: "Photo %{position}") %></strong>
                  </div>
                </div>
              <% end %>
              <%= form_with model: [@property, photo_form], method: :patch do |f| %>
                <div class="form-grid">
                  <div>
                    <%= f.label :image_filename, t("ui.photos.fields.image_filename") %>
                    <%= f.text_field :image_filename %>
                  </div>
                  <div>
                    <%= f.label :caption, t("ui.photos.fields.caption") %>
                    <%= f.text_field :caption %>
                  </div>
                  <div>
                    <%= f.label :position, t("ui.photos.fields.position") %>
                    <%= f.number_field :position, min: 0, step: 1 %>
                  </div>
                  <div class="form-grid__checkbox">
                    <% primary_radio_id = "photo-#{photo.id}-primary" %>
                    <%= f.hidden_field :primary, value: false %>
                    <%= f.radio_button :primary,
                                       true,
                                       id: primary_radio_id,
                                       checked: photo_form.primary?,
                                       data: { primary_photo_radio: true, primary_photo_group: "property-#{@property.id}-photos" } %>
                    <%= label_tag primary_radio_id, t("ui.photos.fields.primary_image"), class: "checkbox-label" %>
                  </div>
                </div>
                <div class="form-actions">
                  <%= f.submit t("ui.common.save"), class: "button primary hollow" %>
                  <%= link_to t("ui.common.remove"),
                              property_photo_path(@property, photo),
                              class: "button alert hollow",
                              data: { turbo_method: :delete, turbo_confirm: t("ui.photos.actions.remove_confirm") } %>
                </div>
              <% end %>
            </div>
          </div>
        <% end %>
      </div>
    <% else %>
      <p class="empty-copy"><%= t("ui.photos.empty") %></p>
    <% end %>
  </article>
</section>
