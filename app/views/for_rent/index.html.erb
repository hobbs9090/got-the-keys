<% title t('for_rent.title') %>

<section class="page-hero">
  <div>
    <p class="page-hero__eyebrow">For rent</p>
    <h1>Rental listings with viewings ready to book</h1>
    <p>Explore homes to let, compare availability, and test the renter viewing flow across a realistic catalogue.</p>
  </div>

  <div class="page-hero__meta">
    <strong><%= number_with_delimiter(@total_for_rent, delimiter: ",") %></strong>
    <span>rental listings</span>
  </div>
</section>

<section class="page-section">
  <%= render "properties/filters", url: for_rent_index_path, selected_sale_status: Property::SALE_STATUSES[:for_rent], show_status_select: false %>
</section>

<section class="page-section">
  <%= paginate @properties %>
  <%= render "properties/property" %>
  <%= paginate @properties %>
</section>
