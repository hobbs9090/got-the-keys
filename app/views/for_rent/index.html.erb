<% title t('for_rent.title') %>

<section class="page-hero">
  <div>
    <p class="page-hero__eyebrow"><%= t("ui.for_rent.eyebrow") %></p>
    <h1><%= t("ui.for_rent.hero_title") %></h1>
    <p><%= t("ui.for_rent.hero_body") %></p>
  </div>

  <div class="page-hero__meta">
    <strong><%= number_with_delimiter(@total_for_rent, delimiter: ",") %></strong>
    <span><%= translate_count("ui.for_rent.count_label", @total_for_rent) %></span>
  </div>
</section>

<section class="page-section">
  <%= render "properties/filters", url: for_rent_index_path, selected_sale_status: Property::SALE_STATUSES[:for_rent], show_status_select: false, catalogue_scope: "for_rent" %>
</section>

<section class="page-section">
  <%= render "properties/paginated_results", properties: @properties %>
</section>
