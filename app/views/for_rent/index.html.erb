<% title t('for_rent.title') %>

<section class="page-hero">
  <div>
    <p class="page-hero__eyebrow"><%= t("ui.for_rent.eyebrow") %></p>
    <h1><%= t("ui.for_rent.hero_title") %></h1>
    <p><%= t("ui.for_rent.hero_body") %></p>
  </div>

  <div class="page-hero__meta">
    <strong><%= number_with_delimiter(@total_for_rent, delimiter: ",") %></strong>
    <span><%= t("ui.for_rent.count_label", count: @total_for_rent) %></span>
  </div>
</section>

<section class="page-section">
  <%= render "properties/filters", url: for_rent_index_path, selected_sale_status: Property::SALE_STATUSES[:for_rent], show_status_select: false %>
</section>

<section class="page-section">
  <div class="property-results-panel__pagination">
    <%= paginate @properties %>
  </div>
  <%= render "properties/property" %>
  <div class="property-results-panel__footer">
    <%= paginate @properties %>
  </div>
</section>
