<% title t("ui.appointments.new.title", address: @property.address_line_1) %>

<section class="page-hero">
  <div>
    <p class="page-hero__eyebrow"><%= t("ui.appointments.new.eyebrow") %></p>
    <h1><%= t("ui.appointments.new.title", address: @property.address_line_1) %></h1>
    <p><%= t("ui.appointments.new.hero_body") %></p>
  </div>
</section>

<section class="property-layout">
  <article class="property-panel">
    <h2><%= @property.headline %></h2>
    <p><%= @property.property_description %></p>
    <p><strong><%= format_price(@property) %></strong> · <%= format_bedrooms(@property) %> · <%= format_bathrooms(@property.bathrooms) %></p>
  </article>

  <aside class="property-booking-panel">
    <%= render "shared/errors", object: @appointment %>

    <% if @available_slots.any? %>
      <%= form_with model: [@property, @appointment], class: "stacked-form", data: { testid: "appointment-form" } do |f| %>
        <div>
          <%= f.label :customer_name, t("ui.common.full_name"), **form_label_options(@appointment, :customer_name) %>
          <%= f.text_field :customer_name, required: true, autocomplete: "name", maxlength: 100, **form_control_options(@appointment, :customer_name) %>
          <%= field_error_messages(@appointment, :customer_name) %>
        </div>

        <div>
          <%= f.label :customer_email, t("ui.common.email_address"), **form_label_options(@appointment, :customer_email) %>
          <%= f.email_field :customer_email, required: true, autocomplete: "email", **form_control_options(@appointment, :customer_email) %>
          <%= field_error_messages(@appointment, :customer_email) %>
        </div>

        <div>
          <%= f.label :customer_phone, t("ui.common.phone_number"), **form_label_options(@appointment, :customer_phone) %>
          <%= f.telephone_field :customer_phone, required: true, autocomplete: "tel", maxlength: 20, **form_control_options(@appointment, :customer_phone) %>
          <%= field_error_messages(@appointment, :customer_phone) %>
        </div>

        <div>
          <%= f.label :requested_time, t("ui.appointments.new.preferred_slot"), **form_label_options(@appointment, :requested_time) %>
          <%= render "slot_picker",
                     slots: @available_slots,
                     field_name: "appointment[requested_time]",
                     field_id: "appointment_requested_time",
                     selected_value: @appointment.requested_time&.iso8601,
                     eyebrow: t("ui.appointments.new.preferred_slot"),
                     summary_prefix: t("ui.appointments.new.preferred_slot"),
                     empty_summary: t("ui.appointments.new.choose_slot"),
                     date_label: t("ui.appointments.new.preferred_slot"),
                     fallback_label: t("ui.appointments.new.preferred_slot"),
                     fallback_prompt: t("ui.appointments.new.choose_slot"),
                     testid: "requested-time-picker" %>
          <%= field_error_messages(@appointment, :requested_time) %>
        </div>

        <div>
          <%= f.label :notes, t("ui.appointments.new.notes_label"), **form_label_options(@appointment, :notes) %>
          <%= f.text_area :notes, rows: 4, maxlength: 2000, placeholder: t("ui.appointments.new.notes_placeholder"), **form_control_options(@appointment, :notes) %>
          <%= field_error_messages(@appointment, :notes) %>
        </div>

        <div class="form-actions">
          <%= f.submit t("ui.appointments.new.submit"), class: "button primary expanded" %>
          <%= link_to t("ui.appointments.new.back_to_property"), property_path(@property), class: "button hollow secondary expanded" %>
        </div>
      <% end %>
    <% else %>
      <div class="empty-state">
        <h2><%= t("ui.appointments.new.no_slots_title") %></h2>
        <p><%= t("ui.appointments.new.no_slots_body") %></p>
        <%= link_to t("ui.appointments.new.back_to_property"), property_path(@property), class: "button hollow secondary expanded" %>
      </div>
    <% end %>
  </aside>
</section>
