<% title t("ui.appointments.show.title", reference: @appointment.public_reference) %>

<section class="page-hero">
  <div>
    <p class="page-hero__eyebrow"><%= t("ui.appointments.show.eyebrow") %></p>
    <h1><%= @appointment.public_reference %></h1>
    <p><%= t("ui.appointments.show.hero_body") %></p>
  </div>

  <div class="page-hero__meta">
    <span class="<%= appointment_status_badge_class(@appointment.status) %>"><%= @appointment.display_status %></span>
  </div>
</section>

<section class="property-layout">
  <article class="property-panel">
    <h2><%= t("ui.appointments.show.summary_title") %></h2>

    <dl class="detail-list">
      <div>
        <dt><%= t("ui.common.property") %></dt>
        <dd><%= link_to @appointment.property.address_line_1, property_path(@appointment.property) %></dd>
      </div>
      <div>
        <dt><%= t("ui.common.requested_slot") %></dt>
        <dd><%= formatted_date_time(@appointment.requested_time) %></dd>
      </div>
      <div>
        <dt><%= t("ui.common.current_slot") %></dt>
        <dd><%= formatted_date_time(@appointment.scheduled_at) %></dd>
      </div>
      <div>
        <dt><%= t("ui.common.duration") %></dt>
        <dd><%= t("ui.appointments.show.duration_minutes", count: @appointment.duration_minutes) %></dd>
      </div>
      <% if @appointment.visit_outcome.present? %>
        <div>
          <dt>Visit outcome</dt>
          <dd><%= @appointment.visit_outcome.to_s.tr("_", " ").humanize %></dd>
        </div>
      <% end %>
      <div>
        <dt><%= t("ui.common.customer") %></dt>
        <dd><%= @appointment.customer_name %> · <%= @appointment.customer_email %><% if @appointment.customer_phone.present? %> · <%= @appointment.customer_phone %><% end %></dd>
      </div>
    </dl>

    <% if @appointment.notes.present? %>
      <div class="note-card">
        <h3><%= t("ui.common.customer_notes") %></h3>
        <p><%= @appointment.notes %></p>
      </div>
    <% end %>
  </article>

  <aside class="property-booking-panel">
    <h2>Manage your viewing</h2>
    <% if @appointment.manageable_by_customer? %>
      <p>You can reschedule or cancel this viewing online until <%= formatted_date_time(@appointment.self_service_expires_at) %>.</p>
      <div class="form-actions">
        <%= link_to "Request a new time", edit_self_service_appointment_path(@appointment, token: @appointment.access_token), class: "button primary expanded", data: { testid: "manage-viewing-link" } %>
        <%= button_to "Cancel viewing", cancel_self_service_appointment_path(@appointment, token: @appointment.access_token), method: :patch, class: "button alert hollow expanded", data: { testid: "cancel-viewing-button" } %>
      </div>
    <% else %>
      <p class="empty-copy">The self-service window for this viewing has now closed.</p>
    <% end %>

    <h2><%= t("ui.appointments.show.timeline_title") %></h2>
    <ol class="timeline" data-testid="appointment-timeline">
      <% @appointment.timeline.each do |event| %>
        <li>
          <strong><%= t("ui.appointments.events.#{event.event_type}", default: event.event_type.tr("_", " ").humanize) %></strong>
          <span><%= formatted_date_time(event.occurred_at) %></span>
          <p><%= event.message %></p>
        </li>
      <% end %>
    </ol>
  </aside>
</section>
