<% title t("ui.admin.security.title") %>
<% provisioning_uri = current_admin.otp_provisioning_uri(current_admin.email, otp_secret: @pending_otp_secret, issuer: "GotTheKeys Admin") if @pending_otp_secret.present? %>

<section class="admin-section">
  <div class="section-heading">
    <div>
      <p class="section-heading__eyebrow"><%= t("ui.admin.security.eyebrow") %></p>
      <h1><%= t("ui.admin.security.title") %></h1>
      <p><%= t("ui.admin.security.intro") %></p>
    </div>
  </div>
</section>

<section class="admin-grid">
  <article class="admin-panel" data-testid="admin-security-status-panel">
    <h2><%= t("ui.admin.security.status_title") %></h2>

    <dl class="detail-list">
      <div>
        <dt><%= t("ui.admin.security.global_mode") %></dt>
        <dd data-testid="admin-security-global-mode">
          <span class="<%= @booking_configuration.admin_two_factor_optional? ? 'badge badge--success' : 'badge badge--warning' %>">
            <%= admin_two_factor_mode_label(@booking_configuration.admin_two_factor_mode) %>
          </span>
        </dd>
      </div>
      <div>
        <dt><%= t("ui.admin.security.account_status") %></dt>
        <dd data-testid="admin-security-account-status">
          <span class="<%= current_admin.two_factor_enrolled? ? 'badge badge--success' : 'badge badge--muted' %>">
            <%= current_admin.two_factor_enrolled? ? t("ui.admin.security.enabled") : t("ui.admin.security.disabled") %>
          </span>
        </dd>
      </div>
      <div>
        <dt><%= t("ui.admin.security.sign_in_behavior") %></dt>
        <dd data-testid="admin-security-sign-in-behavior">
          <% if @booking_configuration.admin_two_factor_disabled? %>
            <%= t("ui.admin.security.behavior_disabled") %>
          <% elsif current_admin.two_factor_enrolled? %>
            <%= t("ui.admin.security.behavior_enrolled") %>
          <% else %>
            <%= t("ui.admin.security.behavior_unenrolled") %>
          <% end %>
        </dd>
      </div>
      <div>
        <dt><%= t("ui.admin.security.backup_codes") %></dt>
        <dd data-testid="admin-security-backup-code-status">
          <%= current_admin.two_factor_backup_codes_generated? ? t("ui.admin.security.backup_codes_ready") : t("ui.admin.security.backup_codes_missing") %>
        </dd>
      </div>
    </dl>

    <div class="form-actions admin-security-actions">
      <% if current_admin.two_factor_enrolled? %>
        <%= button_to t("ui.admin.security.regenerate_backup_codes"), regenerate_backup_codes_admin_security_path, method: :post, class: "button secondary hollow" %>
        <%= button_to t("ui.admin.security.disable_action"), disable_admin_security_path, method: :delete, class: "button alert hollow" %>
      <% else %>
        <%= button_to(@pending_otp_secret.present? ? t("ui.admin.security.restart_setup") : t("ui.admin.security.begin_setup"), enroll_admin_security_path, method: :post, class: "button primary") %>
      <% end %>
    </div>
  </article>

  <article class="admin-panel admin-two-factor-mode-panel" data-testid="admin-two-factor-mode-panel">
    <h2><%= t("ui.admin.qa.admin_two_factor.title") %></h2>
    <p><%= t("ui.admin.qa.admin_two_factor.body") %></p>

    <%= render "shared/errors", object: @booking_configuration %>

    <%= form_with model: [:admin, @booking_configuration], url: admin_security_path, method: :patch, class: "stacked-form", local: true do |f| %>
      <div class="form-grid">
        <div>
          <label class="admin-two-factor-mode-panel__choice">
            <%= f.radio_button :admin_two_factor_mode, "optional" %>
            <span>
              <strong><%= admin_two_factor_mode_label("optional") %></strong><br>
              <%= t("ui.admin.qa.admin_two_factor.optional_help") %>
            </span>
          </label>
        </div>

        <div>
          <label class="admin-two-factor-mode-panel__choice">
            <%= f.radio_button :admin_two_factor_mode, "disabled" %>
            <span>
              <strong><%= admin_two_factor_mode_label("disabled") %></strong><br>
              <%= t("ui.admin.qa.admin_two_factor.disabled_help") %>
            </span>
          </label>
        </div>

        <div class="form-grid__full">
          <div class="callout warning admin-two-factor-mode-panel__warning" data-testid="admin-two-factor-warning-callout">
            <p><strong><%= t("ui.admin.qa.admin_two_factor.warning_title") %>:</strong> <%= t("ui.admin.qa.admin_two_factor.warning_body") %></p>
          </div>
        </div>

        <div class="form-grid__full">
          <%= label_tag :confirm_disable_admin_two_factor, t("ui.admin.qa.admin_two_factor.confirmation_label", phrase: admin_two_factor_disable_confirmation_phrase) %>
          <%= text_field_tag :confirm_disable_admin_two_factor, params[:confirm_disable_admin_two_factor], placeholder: admin_two_factor_disable_confirmation_phrase %>
          <p class="help-text"><%= t("ui.admin.qa.admin_two_factor.confirmation_help") %></p>
        </div>
      </div>

      <div class="form-actions">
        <%= f.submit t("ui.admin.qa.admin_two_factor.save"), class: "button primary" %>
      </div>
    <% end %>

    <dl class="detail-list">
      <div>
        <dt><%= t("ui.admin.qa.admin_two_factor.current_mode") %></dt>
        <dd data-testid="qa-admin-two-factor-mode"><%= admin_two_factor_mode_label(@booking_configuration.admin_two_factor_mode) %></dd>
      </div>

      <% if @last_admin_two_factor_mode_change.present? %>
        <div>
          <dt><%= t("ui.admin.qa.admin_two_factor.last_changed_by") %></dt>
          <dd data-testid="qa-admin-two-factor-actor"><%= @last_admin_two_factor_mode_change.actor_display %></dd>
        </div>
        <div>
          <dt><%= t("ui.admin.qa.admin_two_factor.last_changed_at") %></dt>
          <dd data-testid="qa-admin-two-factor-changed-at"><%= formatted_date_time(@last_admin_two_factor_mode_change.occurred_at) %></dd>
        </div>
      <% end %>
    </dl>
  </article>

  <% if @pending_otp_secret.present? %>
    <article class="admin-panel admin-security-enrollment" data-testid="admin-security-enrollment-panel">
      <h2><%= t("ui.admin.security.enrollment_title") %></h2>
      <p><%= t("ui.admin.security.enrollment_body") %></p>

      <div class="admin-security-enrollment__grid">
        <div class="admin-security-enrollment__qr" data-testid="admin-security-qr">
          <%= admin_two_factor_qr_svg(provisioning_uri) %>
        </div>

        <div class="admin-security-enrollment__details">
          <p class="admin-security-enrollment__label"><%= t("ui.admin.security.manual_key") %></p>
          <div class="code-block" data-testid="admin-security-manual-key"><%= @pending_otp_secret %></div>
          <p class="help-text"><%= t("ui.admin.security.manual_key_hint") %></p>
        </div>
      </div>

      <%= render "shared/errors", object: current_admin %>

      <%= form_with url: confirm_admin_security_path, method: :patch, class: "stacked-form", local: true do %>
        <div>
          <%= label_tag "admin_otp_attempt", t("ui.admin.security.confirm_code"), **form_label_options(current_admin, :otp_attempt) %>
          <%= text_field_tag "admin[otp_attempt]", params.dig(:admin, :otp_attempt), required: true, autocomplete: "one-time-code", data: { testid: "admin-security-otp-attempt" }, **form_control_options(current_admin, :otp_attempt) %>
          <%= field_error_messages(current_admin, :otp_attempt) %>
        </div>

        <div class="form-actions">
          <%= submit_tag t("ui.admin.security.confirm_setup"), class: "button primary" %>
        </div>
      <% end %>
    </article>
  <% elsif @fresh_backup_codes.any? %>
    <article class="admin-panel admin-security-backup-codes" data-testid="admin-security-backup-codes-panel">
      <h2><%= t("ui.admin.security.backup_codes_title") %></h2>
      <p><%= t("ui.admin.security.backup_codes_body") %></p>
      <ol class="admin-security-backup-codes__list" data-testid="admin-security-backup-codes">
        <% @fresh_backup_codes.each do |backup_code| %>
          <li class="admin-security-backup-codes__item" data-testid="admin-security-backup-code">
            <code><%= backup_code %></code>
          </li>
        <% end %>
      </ol>
    </article>
  <% else %>
    <article class="admin-panel">
      <h2><%= t("ui.admin.security.setup_steps_title") %></h2>
      <ol class="timeline">
        <li><p><%= t("ui.admin.security.setup_steps.scan") %></p></li>
        <li><p><%= t("ui.admin.security.setup_steps.confirm") %></p></li>
        <li><p><%= t("ui.admin.security.setup_steps.save") %></p></li>
      </ol>
    </article>
  <% end %>
</section>

<section class="admin-panel" data-testid="admin-security-activity-panel">
  <h2><%= t("ui.admin.security.activity_title") %></h2>

  <% if @security_audit_logs.any? %>
    <ol class="timeline">
      <% @security_audit_logs.each do |audit_log| %>
        <li>
          <p><strong><%= admin_two_factor_audit_action_label(audit_log.action) %></strong></p>
          <p><%= admin_security_activity_message(audit_log) %></p>
          <p><%= t("ui.admin.security.activity_meta", actor: audit_log.actor_display, time: formatted_date_time(audit_log.occurred_at)) %></p>
        </li>
      <% end %>
    </ol>
  <% else %>
    <p><%= t("ui.admin.security.activity_empty") %></p>
  <% end %>
</section>
