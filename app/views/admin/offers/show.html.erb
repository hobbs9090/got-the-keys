<% title t("ui.admin.offers.show.title", reference: @offer.public_reference) %>

<section class="admin-section">
  <div class="section-heading">
    <div>
      <p class="section-heading__eyebrow"><%= t("ui.admin.offers.show.eyebrow") %></p>
      <h1><%= @offer.public_reference %></h1>
    </div>

    <div class="section-heading__actions">
      <%= link_to t("ui.admin.offers.show.back"), admin_sales_path, class: "button hollow secondary" %>
      <span class="<%= offer_status_badge_class(@offer.status) %>"><%= t("ui.offers.statuses.#{@offer.status}", default: @offer.status.humanize) %></span>
    </div>
  </div>
</section>

<section class="admin-grid admin-grid--split">
  <article class="admin-panel">
    <h2><%= t("ui.admin.offers.show.summary_title") %></h2>
    <dl class="detail-list">
      <div><dt><%= t("ui.admin.offers.show.property") %></dt><dd><%= @offer.property.address_line_1 %></dd></div>
      <div><dt><%= t("ui.admin.offers.show.buyer") %></dt><dd><%= @offer.buyer_name %></dd></div>
      <div><dt><%= t("ui.admin.offers.show.email") %></dt><dd><%= @offer.buyer_email %></dd></div>
      <div><dt><%= t("ui.admin.offers.show.phone") %></dt><dd><%= @offer.buyer_phone %></dd></div>
      <div><dt><%= t("ui.admin.offers.show.amount") %></dt><dd><%= number_to_currency(@offer.amount, unit: "£", precision: 0) %></dd></div>
      <div><dt><%= t("ui.admin.offers.show.chain") %></dt><dd><%= @offer.chain_position.presence || t("ui.admin.offers.show.not_supplied") %></dd></div>
      <div><dt><%= t("ui.admin.offers.show.notes") %></dt><dd><%= @offer.notes.presence || t("ui.admin.offers.show.none") %></dd></div>
    </dl>
  </article>

  <article class="admin-panel">
    <h2><%= t("ui.admin.offers.show.manage_title") %></h2>
    <%= form_with model: @offer, url: admin_sale_path(@offer), data: { testid: "offer-management-form" } do |f| %>
      <div class="form-grid">
        <div>
          <%= f.label :status, t("ui.admin.offers.show.status") %>
          <%= f.select :status, Offer::STATUSES.map { |status| [t("ui.offers.statuses.#{status}", default: status.humanize), status] }, {}, data: { testid: "offer-status-select" } %>
        </div>
        <div class="form-grid__full">
          <%= f.label :chain_position, t("ui.admin.offers.show.chain_position") %>
          <%= f.text_field :chain_position, data: { testid: "offer-chain-position-admin" } %>
        </div>
        <div class="form-grid__full">
          <%= f.label :internal_notes, t("ui.admin.offers.show.internal_notes") %>
          <%= f.text_area :internal_notes, rows: 6, data: { testid: "offer-internal-notes" } %>
        </div>
      </div>
      <div class="form-actions">
        <%= f.submit t("ui.admin.offers.show.save"), class: "button primary", data: { testid: "save-offer-button" } %>
      </div>
    <% end %>
  </article>
</section>

<section class="admin-panel">
  <h2><%= t("ui.admin.offers.show.history_title") %></h2>
  <ol class="timeline" data-testid="offer-decision-history">
    <% @offer.timeline.each do |event| %>
      <li>
        <strong><%= event.event_type.to_s.humanize %></strong>
        <span><%= formatted_date_time(event.occurred_at) %></span>
        <p><%= event.message %></p>
      </li>
    <% end %>
  </ol>
</section>
