<% title t("ui.admin.offers.index.title") %>

<section class="admin-section">
  <div class="section-heading">
    <div>
      <p class="section-heading__eyebrow"><%= t("ui.admin.offers.index.eyebrow") %></p>
      <h1><%= t("ui.admin.offers.index.title") %></h1>
    </div>
  </div>
</section>

<section class="admin-grid admin-grid--board">
  <% @offers_by_status.each do |status, offers| %>
    <article class="admin-panel" data-testid="offers-column-<%= status %>">
      <h2><%= t("ui.offers.statuses.#{status}", default: status.humanize).to_s.capitalize %></h2>
      <% if offers.any? %>
        <div class="admin-list">
          <% offers.each do |offer| %>
            <div class="admin-list__item">
              <div>
                <%= link_to offer.buyer_name, admin_customer_path(offer.buyer_email.to_s.downcase) %>
                <p><%= offer.property.address_line_1 %> · <%= number_to_currency(offer.amount, unit: "£", precision: 0) %></p>
                <div class="admin-board-card__footer">
                  <span class="<%= offer_status_badge_class(offer.status) %>"><%= offer.status.humanize %></span>
                  <%= link_to t("ui.admin.common.details", default: "Details"), admin_sale_path(offer), class: "button primary hollow", data: { testid: "admin-offer-open-#{offer.id}" } %>
                </div>
              </div>
            </div>
          <% end %>
        </div>
      <% else %>
        <p class="empty-copy"><%= t("ui.admin.offers.index.empty_column") %></p>
      <% end %>
    </article>
  <% end %>
</section>
