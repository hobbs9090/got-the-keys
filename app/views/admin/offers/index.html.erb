<% title "Offers board" %>

<section class="admin-section">
  <div class="section-heading">
    <div>
      <p class="section-heading__eyebrow">Sales progression</p>
      <h1>Offers board</h1>
    </div>
  </div>
</section>

<section class="admin-grid">
  <% @offers_by_status.each do |status, offers| %>
    <article class="admin-panel" data-testid="offers-column-<%= status %>">
      <h2><%= status.humanize %></h2>
      <% if offers.any? %>
        <div class="admin-list">
          <% offers.each do |offer| %>
            <div class="admin-list__item">
              <div>
                <%= link_to offer.buyer_name, admin_offer_path(offer) %>
                <p><%= offer.property.address_line_1 %> · <%= number_to_currency(offer.amount, unit: "£", precision: 0) %></p>
              </div>
              <span class="<%= offer_status_badge_class(offer.status) %>"><%= offer.status.humanize %></span>
            </div>
          <% end %>
        </div>
      <% else %>
        <p class="empty-copy">No offers in this column.</p>
      <% end %>
    </article>
  <% end %>
</section>
