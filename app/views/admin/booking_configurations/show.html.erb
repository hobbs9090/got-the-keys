<% title t("ui.admin.booking_configuration.title") %>

<section class="admin-section">
  <div class="section-heading">
    <div>
      <p class="section-heading__eyebrow"><%= t("ui.admin.booking_configuration.eyebrow") %></p>
      <h1><%= t("ui.admin.booking_configuration.title") %></h1>
    </div>
  </div>

  <article class="admin-panel">
    <%= render "shared/errors", object: @booking_configuration %>

    <%= form_with model: [:admin, @booking_configuration], url: admin_booking_configuration_path, class: "stacked-form" do |f| %>
      <div class="form-grid">
        <div>
          <%= f.label :slot_duration_minutes, t("ui.admin.booking_configuration.slot_duration_minutes"), **form_label_options(@booking_configuration, :slot_duration_minutes) %>
          <%= f.select :slot_duration_minutes,
                       BookingConfiguration::SUPPORTED_SLOT_DURATIONS.map { |duration| ["#{duration} minutes", duration] },
                       {},
                       form_control_options(@booking_configuration, :slot_duration_minutes) %>
          <%= field_error_messages(@booking_configuration, :slot_duration_minutes) %>
        </div>
        <div>
          <%= f.label :booking_window_days, t("ui.admin.booking_configuration.booking_window_days"), **form_label_options(@booking_configuration, :booking_window_days) %>
          <%= f.number_field :booking_window_days, min: 1, max: 60, step: 1, required: true, **form_control_options(@booking_configuration, :booking_window_days) %>
          <%= field_error_messages(@booking_configuration, :booking_window_days) %>
        </div>
        <div>
          <%= f.label :lead_time_hours, t("ui.admin.booking_configuration.lead_time_hours"), **form_label_options(@booking_configuration, :lead_time_hours) %>
          <%= f.number_field :lead_time_hours, min: 0, max: 336, step: 1, required: true, **form_control_options(@booking_configuration, :lead_time_hours) %>
          <%= field_error_messages(@booking_configuration, :lead_time_hours) %>
        </div>
        <div>
          <%= f.label :buffer_minutes, t("ui.admin.booking_configuration.buffer_minutes"), **form_label_options(@booking_configuration, :buffer_minutes) %>
          <%= f.number_field :buffer_minutes, min: 0, max: 180, step: 5, required: true, **form_control_options(@booking_configuration, :buffer_minutes) %>
          <%= field_error_messages(@booking_configuration, :buffer_minutes) %>
        </div>
        <div>
          <%= f.label :office_opens_at, t("ui.admin.booking_configuration.office_opens_at"), **form_label_options(@booking_configuration, :office_opens_at) %>
          <%= f.text_field :office_opens_at, placeholder: "09:00", pattern: "\\d{2}:\\d{2}", required: true, data: { validation_pattern_message: t("ui.admin.booking_configuration.validation.clock_format_hint", default: "Please use 24-hour HH:MM format.") }, **form_control_options(@booking_configuration, :office_opens_at) %>
          <%= field_error_messages(@booking_configuration, :office_opens_at) %>
        </div>
        <div>
          <%= f.label :office_closes_at, t("ui.admin.booking_configuration.office_closes_at"), **form_label_options(@booking_configuration, :office_closes_at) %>
          <%= f.text_field :office_closes_at, placeholder: "18:00", pattern: "\\d{2}:\\d{2}", required: true, data: { validation_pattern_message: t("ui.admin.booking_configuration.validation.clock_format_hint", default: "Please use 24-hour HH:MM format.") }, **form_control_options(@booking_configuration, :office_closes_at) %>
          <%= field_error_messages(@booking_configuration, :office_closes_at) %>
        </div>
        <div class="form-grid__full">
          <%= f.label :open_weekdays, t("ui.admin.booking_configuration.open_weekdays"), **form_label_options(@booking_configuration, :open_weekdays) %>
          <%= hidden_field_tag "booking_configuration[open_weekdays][]", "" %>
          <div class="checkbox-row">
            <% I18n.t("date.abbr_day_names", default: Date::ABBR_DAYNAMES).each_with_index do |label, value| %>
              <label class="checkbox-pill">
                <%= check_box_tag "booking_configuration[open_weekdays][]", value, @booking_configuration.open_weekday_numbers.include?(value) %>
                <span><%= label %></span>
              </label>
            <% end %>
          </div>
          <%= field_error_messages(@booking_configuration, :open_weekdays) %>
        </div>
      </div>

      <div class="form-actions">
        <%= f.submit t("ui.admin.booking_configuration.save"), class: "button primary" %>
      </div>
    <% end %>
  </article>
</section>
