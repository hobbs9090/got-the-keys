<% title t("ui.admin.qa.title") %>

<section class="admin-section">
  <div class="section-heading">
    <div>
      <p class="section-heading__eyebrow"><%= t("ui.admin.qa.eyebrow") %></p>
      <h1><%= t("ui.admin.qa.title") %></h1>
    </div>

    <aside class="qa-version-box" data-testid="qa-version-box">
      <p class="qa-version-box__eyebrow"><%= t("ui.admin.qa.version_box.title", default: "Release build") %></p>
      <div class="qa-version-box__hero">
        <p class="qa-version-box__label"><%= t("ui.admin.qa.app_version") %></p>
        <p class="qa-version-box__version" data-testid="qa-app-version"><%= full_app_version %></p>
      </div>
      <dl class="qa-version-box__list">
        <div>
          <dt><%= t("ui.admin.qa.version_box.git_sha", default: "Git SHA") %></dt>
          <dd data-testid="qa-git-sha"><%= app_build_value(app_build_sha) %></dd>
        </div>
        <div>
          <dt><%= t("ui.admin.qa.version_box.build_number", default: "Build number") %></dt>
          <dd data-testid="qa-build-number"><%= app_build_value(app_build_number) %></dd>
        </div>
        <div>
          <dt><%= t("ui.admin.qa.version_box.deployed_at", default: "Deployed at") %></dt>
          <dd data-testid="qa-deployed-at"><%= app_build_value(app_deployed_at) %></dd>
        </div>
        <div>
          <dt><%= t("ui.admin.qa.version_box.environment", default: "Environment") %></dt>
          <dd data-testid="qa-environment"><%= app_runtime_environment %></dd>
        </div>
      </dl>
    </aside>
  </div>
</section>

<section class="admin-grid">
  <article class="admin-panel">
    <h2><%= t("ui.admin.qa.diagnostics_title") %></h2>
    <dl class="detail-list">
      <% @diagnostics.each do |label, value| %>
        <div>
          <dt><%= t("ui.admin.qa.diagnostic_labels.#{label}", default: label.to_s.humanize) %></dt>
          <dd><%= value.is_a?(DemoScenarioRun) ? t("ui.admin.qa.demo_action_value", action: admin_demo_action_label(value.action_type), time: formatted_date_time(value.created_at)) : value %></dd>
        </div>
      <% end %>
    </dl>
  </article>

  <article class="admin-panel">
    <h2><%= t("ui.admin.qa.known_credentials_title") %></h2>
    <div class="code-block">
      <% Array(@baseline[:admins]).each do |admin| %>
        <%= t("ui.admin.qa.admin_credential", email: admin[:email], password: admin[:password] || t("ui.admin.qa.default_password")) %>
      <% end %>

      <% Array(@baseline[:users]).each do |user| %>
        <%= t("ui.admin.qa.seller_credential", email: user[:email], password: user[:password] || t("ui.admin.qa.default_password")) %>
      <% end %>
    </div>
  </article>
</section>

<section class="admin-grid">
  <article class="admin-panel admin-two-factor-mode-panel" data-testid="admin-two-factor-mode-panel">
    <h2><%= t("ui.admin.qa.admin_two_factor.title", default: "Admin 2FA mode") %></h2>
    <p><%= t("ui.admin.qa.admin_two_factor.body", default: "Optional mode only enforces OTP for admins who have already enrolled. Disabled mode bypasses OTP for every admin without deleting enrollment secrets or backup codes.") %></p>
    <p><%= t("ui.admin.qa.admin_two_factor.security_page_hint", default: "Enrollment and backup code management live on the dedicated admin security page.") %> <%= link_to t("ui.admin.navigation.security", default: "Security"), admin_security_path %>.</p>

    <%= render "shared/errors", object: @booking_configuration %>

    <%= form_with model: [:admin, @booking_configuration], url: admin_qa_path, method: :patch, class: "stacked-form", local: true do |f| %>
      <div class="form-grid">
        <div>
          <label class="admin-two-factor-mode-panel__choice">
            <%= f.radio_button :admin_two_factor_mode, "optional" %>
            <span>
              <strong><%= admin_two_factor_mode_label("optional") %></strong><br>
              <%= t("ui.admin.qa.admin_two_factor.optional_help", default: "Enrolled admins must use OTP or a backup code. Unenrolled admins can still sign in with email and password.") %>
            </span>
          </label>
        </div>

        <div>
          <label class="admin-two-factor-mode-panel__choice">
            <%= f.radio_button :admin_two_factor_mode, "disabled" %>
            <span>
              <strong><%= admin_two_factor_mode_label("disabled") %></strong><br>
              <%= t("ui.admin.qa.admin_two_factor.disabled_help", default: "Emergency bypass: OTP checks are skipped for all admins until optional mode is restored.") %>
            </span>
          </label>
        </div>

        <div class="form-grid__full">
          <div class="callout warning">
            <p><strong><%= t("ui.admin.qa.admin_two_factor.warning_title", default: "Warning") %>:</strong> <%= t("ui.admin.qa.admin_two_factor.warning_body", default: "Switching to disabled removes OTP prompts for every admin immediately. Existing enrollment secrets and backup codes remain stored so optional mode can be restored later.") %></p>
          </div>
        </div>

        <div class="form-grid__full">
          <%= label_tag :confirm_disable_admin_two_factor, t("ui.admin.qa.admin_two_factor.confirmation_label", default: "Type %{phrase} before switching to disabled", phrase: admin_two_factor_disable_confirmation_phrase) %>
          <%= text_field_tag :confirm_disable_admin_two_factor, params[:confirm_disable_admin_two_factor], placeholder: admin_two_factor_disable_confirmation_phrase %>
          <p class="help-text"><%= t("ui.admin.qa.admin_two_factor.confirmation_help", default: "This confirmation is only required when changing from optional to disabled.") %></p>
        </div>
      </div>

      <div class="form-actions">
        <%= f.submit t("ui.admin.qa.admin_two_factor.save", default: "Save admin 2FA mode"), class: "button primary" %>
      </div>
    <% end %>

    <dl class="detail-list">
      <div>
        <dt><%= t("ui.admin.qa.admin_two_factor.current_mode", default: "Current mode") %></dt>
        <dd data-testid="qa-admin-two-factor-mode"><%= admin_two_factor_mode_label(@booking_configuration.admin_two_factor_mode) %></dd>
      </div>

      <% if @last_admin_two_factor_mode_change.present? %>
        <div>
          <dt><%= t("ui.admin.qa.admin_two_factor.last_changed_by", default: "Last changed by") %></dt>
          <dd data-testid="qa-admin-two-factor-actor"><%= @last_admin_two_factor_mode_change.actor_display %></dd>
        </div>
        <div>
          <dt><%= t("ui.admin.qa.admin_two_factor.last_changed_at", default: "Last changed at") %></dt>
          <dd data-testid="qa-admin-two-factor-changed-at"><%= formatted_date_time(@last_admin_two_factor_mode_change.occurred_at) %></dd>
        </div>
      <% end %>
    </dl>
  </article>

  <article class="admin-panel">
    <h2><%= t("ui.admin.qa.training_title") %></h2>
    <ol class="timeline">
      <% @training_journeys.each do |journey| %>
        <li><p><%= journey %></p></li>
      <% end %>
    </ol>
  </article>
</section>

<section class="admin-grid">
  <article class="admin-panel">
    <h2>Selector contract registry</h2>
    <% @selector_groups.each do |surface, selectors| %>
      <p><strong><%= surface %></strong></p>
      <ul class="detail-inline-list">
        <% selectors.each do |entry| %>
          <li><code><%= entry[:selector] %></code>: <%= entry[:purpose] %></li>
        <% end %>
      </ul>
    <% end %>
  </article>
</section>

<section class="admin-panel">
  <h2>Scenario families</h2>
  <% @scenario_family_groups.each do |family, scenarios| %>
    <p><strong><%= admin_scenario_family_label(family) %></strong></p>
    <ul class="detail-inline-list">
      <% scenarios.each do |scenario| %>
        <li>
          <strong><%= scenario[:name] %></strong>:
          <%= scenario.dig(:qa, :intended_journey) %>
          (<%= scenario.dig(:qa, :complexity).to_s.humanize %>)
        </li>
      <% end %>
    </ul>
  <% end %>
</section>
