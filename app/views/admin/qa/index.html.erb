<% title t("ui.admin.qa.title") %>

<section class="admin-section">
  <div class="section-heading">
    <div>
      <p class="section-heading__eyebrow"><%= t("ui.admin.qa.eyebrow") %></p>
      <h1><%= t("ui.admin.qa.title") %></h1>
    </div>
  </div>

  <aside class="qa-version-box" data-testid="qa-version-box">
    <p class="qa-version-box__eyebrow"><%= t("ui.admin.qa.version_box.title") %></p>
    <div class="qa-version-box__hero">
      <p class="qa-version-box__label"><%= t("ui.admin.qa.app_version") %></p>
      <p class="qa-version-box__version" data-testid="qa-app-version"><%= full_app_version %></p>
      <% if display_app_build_sha.present? %>
        <p class="qa-version-box__commit" data-testid="qa-build-commit"><%= t("ui.admin.qa.version_box.commit_badge", sha: display_app_build_sha) %></p>
      <% end %>
    </div>
    <dl class="qa-version-box__list">
      <div>
        <dt><%= t("ui.admin.qa.version_box.git_sha") %></dt>
        <dd data-testid="qa-git-sha"><%= app_build_value(app_build_sha) %></dd>
      </div>
      <div>
        <dt><%= t("ui.admin.qa.version_box.build_number") %></dt>
        <dd data-testid="qa-build-number"><%= app_build_value(app_build_number) %></dd>
      </div>
      <div>
        <dt><%= t("ui.admin.qa.version_box.deployed_at") %></dt>
        <dd data-testid="qa-deployed-at"><%= app_build_value(app_deployed_at) %></dd>
      </div>
      <div>
        <dt><%= t("ui.admin.qa.version_box.environment") %></dt>
        <dd data-testid="qa-environment"><%= app_runtime_environment %></dd>
      </div>
    </dl>
  </aside>
</section>

<section class="admin-grid">
  <article class="admin-panel">
    <h2><%= t("ui.admin.qa.diagnostics_title") %></h2>
    <dl class="detail-list">
      <% @diagnostics.each do |label, value| %>
        <div>
          <dt><%= t("ui.admin.qa.diagnostic_labels.#{label}") %></dt>
          <dd>
            <% if value.is_a?(DemoScenarioRun) %>
              <%= t("ui.admin.qa.demo_action_value", action: admin_demo_action_label(value.action_type), time: formatted_date_time(value.created_at)) %>
            <% elsif label.to_sym == :seeded_personas && value.is_a?(Hash) %>
              <div class="qa-seeded-personas">
                <% if value[:admins].present? %>
                  <section class="qa-seeded-personas__group">
                    <p><strong><%= t("ui.admin.qa.seeded_personas.admins_label", default: "Admins") %>:</strong></p>
                    <ul class="qa-seeded-personas__list">
                      <% value[:admins].each do |credential| %>
                        <li><code><%= credential %></code></li>
                      <% end %>
                    </ul>
                  </section>
                <% end %>
                <% if value[:sellers].present? %>
                  <section class="qa-seeded-personas__group">
                    <p><strong><%= t("ui.admin.qa.seeded_personas.sellers_label", default: "Sellers") %>:</strong></p>
                    <ul class="qa-seeded-personas__list">
                      <% value[:sellers].each do |credential| %>
                        <li><code><%= credential %></code></li>
                      <% end %>
                    </ul>
                  </section>
                <% end %>
                <% if value[:buyers].present? %>
                  <section class="qa-seeded-personas__group">
                    <p><strong><%= t("ui.admin.qa.seeded_personas.buyers_label", default: "Buyers") %>:</strong></p>
                    <ul class="qa-seeded-personas__list">
                      <% value[:buyers].each do |credential| %>
                        <li><code><%= credential %></code></li>
                      <% end %>
                    </ul>
                  </section>
                <% end %>
              </div>
            <% else %>
              <%= value %>
            <% end %>
          </dd>
        </div>
      <% end %>
    </dl>
  </article>
</section>

<section class="admin-grid">
  <article class="admin-panel">
    <h2><%= t("ui.admin.qa.training_title") %></h2>
    <ol class="timeline">
      <% @training_journeys.each do |journey| %>
        <li><p><%= journey %></p></li>
      <% end %>
    </ol>
  </article>
</section>

<section class="admin-grid">
  <article class="admin-panel">
    <h2><%= t("ui.admin.qa.selector_contract_registry") %></h2>
    <% @selector_groups.each do |surface, selectors| %>
      <p><strong><%= admin_selector_surface_label(selectors.first) %></strong></p>
      <ul class="detail-inline-list">
        <% selectors.each do |entry| %>
          <li><code><%= entry[:selector] %></code>: <%= admin_selector_purpose_label(entry) %></li>
        <% end %>
      </ul>
    <% end %>
  </article>
</section>
