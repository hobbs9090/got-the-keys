<% title "Edit appointment #{@appointment.public_reference}" %>

<section class="admin-section">
  <div class="section-heading">
    <div>
      <p class="section-heading__eyebrow">Booking management</p>
      <h1>Edit appointment <%= @appointment.public_reference %></h1>
    </div>
  </div>

  <article class="admin-panel">
    <%= render "shared/errors", object: @appointment %>

    <%= form_with model: [:admin, @appointment], class: "stacked-form", data: { testid: "admin-appointment-edit-form" } do |f| %>
      <div class="form-grid">
        <div>
          <%= f.label :customer_name, "Customer name" %>
          <%= f.text_field :customer_name %>
        </div>
        <div>
          <%= f.label :customer_email, "Customer email" %>
          <%= f.email_field :customer_email %>
        </div>
        <div>
          <%= f.label :customer_phone, "Customer phone" %>
          <%= f.telephone_field :customer_phone %>
        </div>
        <div>
          <%= f.label :duration_minutes, "Duration (minutes)" %>
          <%= f.number_field :duration_minutes, min: 15, step: 15 %>
        </div>
        <div>
          <%= f.label :requested_time, "Requested time" %>
          <%= f.datetime_local_field :requested_time %>
        </div>
        <div>
          <%= f.label :scheduled_at, "Confirmed slot" %>
          <%= f.datetime_local_field :scheduled_at %>
        </div>
        <div>
          <%= f.label :status %>
          <%= f.select :status, Appointment::STATUSES.map { |status| [status.humanize, status] } %>
        </div>
        <div class="form-grid__full">
          <%= f.label :notes, "Customer notes" %>
          <%= f.text_area :notes, rows: 4 %>
        </div>
        <div class="form-grid__full">
          <%= f.label :internal_notes, "Internal notes" %>
          <%= f.text_area :internal_notes, rows: 5 %>
        </div>
      </div>

      <div class="form-actions">
        <%= f.submit "Save changes", class: "button primary" %>
        <%= link_to "Back", admin_appointment_path(@appointment), class: "button hollow secondary" %>
      </div>
    <% end %>
  </article>
</section>
