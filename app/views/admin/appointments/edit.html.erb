<% title t("ui.admin.appointments.edit.title", reference: @appointment.public_reference) %>

<section class="admin-section">
  <div class="section-heading">
    <div>
      <p class="section-heading__eyebrow"><%= t("ui.admin.appointments.edit.eyebrow") %></p>
      <h1><%= t("ui.admin.appointments.edit.heading", reference: @appointment.public_reference) %></h1>
    </div>
  </div>

  <article class="admin-panel">
    <%= render "shared/errors", object: @appointment %>

    <%= form_with model: [:admin, @appointment], class: "stacked-form", data: { testid: "admin-appointment-edit-form" } do |f| %>
      <div class="form-grid">
        <div>
          <%= f.label :customer_name, t("ui.admin.appointments.edit.customer_name"), **form_label_options(@appointment, :customer_name) %>
          <%= f.text_field :customer_name, required: true, maxlength: 100, **form_control_options(@appointment, :customer_name) %>
          <%= field_error_messages(@appointment, :customer_name) %>
        </div>
        <div>
          <%= f.label :customer_email, t("ui.admin.appointments.edit.customer_email"), **form_label_options(@appointment, :customer_email) %>
          <%= f.email_field :customer_email, required: true, **form_control_options(@appointment, :customer_email) %>
          <%= field_error_messages(@appointment, :customer_email) %>
        </div>
        <div>
          <%= f.label :customer_phone, t("ui.admin.appointments.edit.customer_phone"), **form_label_options(@appointment, :customer_phone) %>
          <%= f.telephone_field :customer_phone, required: true, maxlength: 20, **form_control_options(@appointment, :customer_phone) %>
          <%= field_error_messages(@appointment, :customer_phone) %>
        </div>
        <div>
          <%= f.label :duration_minutes, t("ui.admin.appointments.edit.duration_minutes"), **form_label_options(@appointment, :duration_minutes) %>
          <%= f.select :duration_minutes,
                       BookingConfiguration::SUPPORTED_SLOT_DURATIONS.map { |duration| ["#{duration} minutes", duration] },
                       {},
                       form_control_options(@appointment, :duration_minutes) %>
          <%= field_error_messages(@appointment, :duration_minutes) %>
        </div>
        <div>
          <%= f.label :requested_time, t("ui.admin.appointments.edit.requested_time"), **form_label_options(@appointment, :requested_time) %>
          <%= f.datetime_local_field :requested_time, required: true, **form_control_options(@appointment, :requested_time) %>
          <%= field_error_messages(@appointment, :requested_time) %>
        </div>
        <div>
          <%= f.label :scheduled_at, t("ui.admin.appointments.edit.confirmed_slot"), **form_label_options(@appointment, :scheduled_at) %>
          <%= f.datetime_local_field :scheduled_at, required: true, **form_control_options(@appointment, :scheduled_at) %>
          <%= field_error_messages(@appointment, :scheduled_at) %>
        </div>
        <div>
          <%= f.label :status, nil, **form_label_options(@appointment, :status) %>
          <%= f.select :status, Appointment::STATUSES.map { |status| [t("ui.appointments.statuses.#{status}", default: status.humanize), status] }, {}, form_control_options(@appointment, :status) %>
          <%= field_error_messages(@appointment, :status) %>
        </div>
        <div>
          <%= f.label :visit_outcome, "Visit outcome", **form_label_options(@appointment, :visit_outcome) %>
          <%= f.select :visit_outcome, [["Not recorded", nil]] + Appointment::VISIT_OUTCOMES.map { |outcome| [outcome.to_s.humanize, outcome] }, {}, form_control_options(@appointment, :visit_outcome) %>
          <%= field_error_messages(@appointment, :visit_outcome) %>
        </div>
        <div class="form-grid__full">
          <%= f.label :notes, t("ui.admin.appointments.edit.customer_notes"), **form_label_options(@appointment, :notes) %>
          <%= f.text_area :notes, rows: 4, maxlength: 2000, **form_control_options(@appointment, :notes) %>
          <%= field_error_messages(@appointment, :notes) %>
        </div>
        <div class="form-grid__full">
          <%= f.label :internal_notes, t("ui.admin.appointments.edit.internal_notes"), **form_label_options(@appointment, :internal_notes) %>
          <%= f.text_area :internal_notes, rows: 5, maxlength: 2000, **form_control_options(@appointment, :internal_notes) %>
          <%= field_error_messages(@appointment, :internal_notes) %>
        </div>
      </div>

      <div class="form-actions">
        <%= f.submit t("ui.admin.appointments.edit.save_changes"), class: "button primary" %>
        <%= link_to t("ui.admin.appointments.edit.back"), admin_appointment_path(@appointment), class: "button hollow secondary" %>
      </div>
    <% end %>
  </article>
</section>
