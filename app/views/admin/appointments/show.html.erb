<% title t("ui.admin.appointments.show.title", reference: @appointment.public_reference) %>

<section class="admin-section">
  <div class="section-heading">
    <div>
      <p class="section-heading__eyebrow"><%= t("ui.admin.appointments.show.eyebrow") %></p>
      <h1><%= @appointment.public_reference %></h1>
    </div>

    <div class="section-heading__actions admin-appointment-header-actions" data-testid="admin-appointment-header-actions">
      <span class="<%= appointment_status_badge_class(@appointment.status) %>"><%= @appointment.display_status %></span>
      <%= link_to t("ui.admin.appointments.show.edit"), edit_admin_appointment_path(@appointment), class: "button primary hollow" %>
      <%= button_to t("ui.admin.appointments.show.send_reminder"), send_reminder_admin_appointment_path(@appointment), method: :post, class: "button hollow secondary" if @appointment.status.in?(%w[pending confirmed rescheduled]) %>
    </div>
  </div>
</section>

<section class="admin-grid admin-grid--split">
  <article class="admin-panel">
    <h2><%= t("ui.admin.appointments.show.summary_title") %></h2>
    <dl class="detail-list">
      <div>
        <dt><%= t("ui.common.property") %></dt>
        <dd><%= link_to @appointment.property.address_line_1, admin_property_path(@appointment.property) %></dd>
      </div>
      <div>
        <dt><%= t("ui.common.customer") %></dt>
        <dd><%= @appointment.customer_name %></dd>
      </div>
      <div>
        <dt><%= t("ui.common.email_address") %></dt>
        <dd><%= @appointment.customer_email %></dd>
      </div>
      <div>
        <dt><%= t("ui.common.phone_number") %></dt>
        <dd><%= @appointment.customer_phone.presence || t("ui.admin.appointments.show.not_supplied") %></dd>
      </div>
      <div>
        <dt><%= t("ui.common.requested_slot") %></dt>
        <dd><%= formatted_date_time(@appointment.requested_time) %></dd>
      </div>
      <div>
        <dt><%= t("ui.common.current_slot") %></dt>
        <dd><%= formatted_date_time(@appointment.scheduled_at) %></dd>
      </div>
      <div>
        <dt><%= t("ui.admin.appointments.show.visit_outcome") %></dt>
        <dd><%= @appointment.visit_outcome.present? ? @appointment.visit_outcome.to_s.humanize : t("ui.admin.appointments.show.not_recorded") %></dd>
      </div>
      <div>
        <dt><%= t("ui.admin.appointments.show.self_service") %></dt>
        <dd><%= @appointment.manageable_by_customer? ? t("ui.admin.appointments.show.self_service_open_until", time: formatted_date_time(@appointment.self_service_expires_at)) : t("ui.admin.appointments.show.self_service_closed") %></dd>
      </div>
      <% if @appointment.reminder_sent_at.present? %>
        <div>
          <dt><%= t("ui.admin.appointments.show.reminder_sent") %></dt>
          <dd><%= formatted_date_time(@appointment.reminder_sent_at) %></dd>
        </div>
      <% end %>
    </dl>

    <div class="admin-inline-actions">
      <%= button_to t("ui.admin.appointments.confirm"), transition_admin_appointment_path(@appointment, status: "confirmed"), method: :patch, class: "button success hollow" unless @appointment.status == "confirmed" %>
      <%= button_to t("ui.admin.appointments.show.actions.complete"), transition_admin_appointment_path(@appointment, status: "completed"), method: :patch, class: "button primary hollow" unless @appointment.status == "completed" %>
      <%= button_to t("ui.admin.appointments.show.actions.no_show"), transition_admin_appointment_path(@appointment, status: "no_show"), method: :patch, class: "button warning hollow" unless @appointment.status == "no_show" %>
      <%= button_to t("ui.admin.appointments.cancel"), transition_admin_appointment_path(@appointment, status: "cancelled"), method: :patch, class: "button alert hollow" unless @appointment.status == "cancelled" %>
    </div>
  </article>

  <article class="admin-panel">
    <h2><%= t("ui.admin.appointments.show.notes_title") %></h2>
    <p><strong><%= t("ui.common.customer_notes") %></strong></p>
    <p><%= @appointment.notes.presence || t("ui.admin.appointments.show.no_customer_notes") %></p>

    <p><strong><%= t("ui.admin.appointments.edit.internal_notes") %></strong></p>
    <p><%= @appointment.internal_notes.presence || t("ui.admin.appointments.show.no_internal_notes") %></p>
  </article>
</section>

<section class="admin-grid admin-grid--split">
  <article class="admin-panel">
    <h2><%= t("ui.admin.appointments.show.audit_trail_title") %></h2>
    <ol class="timeline">
      <% @appointment.timeline.each do |event| %>
        <li>
          <strong><%= t("ui.appointments.events.#{event.event_type}", default: event.event_type.tr("_", " ").humanize) %></strong>
          <span><%= formatted_date_time(event.occurred_at) %></span>
          <p><%= event.message %></p>
        </li>
      <% end %>
    </ol>
  </article>

  <article class="admin-panel">
    <h2><%= t("ui.admin.appointments.show.customer_history_title") %></h2>
    <% if @customer_history.any? %>
      <div class="admin-list">
        <% @customer_history.each do |appointment| %>
          <div class="admin-list__item">
            <div>
              <%= link_to appointment.public_reference, admin_appointment_path(appointment) %>
              <p><%= appointment.property.address_line_1 %> · <%= formatted_date_time(appointment.scheduled_at) %></p>
            </div>
            <span class="<%= appointment_status_badge_class(appointment.status) %>"><%= appointment.display_status %></span>
          </div>
        <% end %>
      </div>
    <% else %>
      <p class="empty-copy"><%= t("ui.admin.appointments.show.no_customer_history") %></p>
    <% end %>
  </article>
</section>
