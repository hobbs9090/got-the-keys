<% title t("ui.admin.appointments.title") %>

<section class="admin-section">
  <div class="section-heading">
    <div>
      <p class="section-heading__eyebrow"><%= t("ui.admin.appointments.eyebrow") %></p>
      <h1><%= t("ui.admin.appointments.title") %></h1>
      <p><%= t("ui.admin.appointments.hero_body") %></p>
    </div>

    <div class="section-heading__actions">
      <div class="admin-bookings-view-switch" data-testid="admin-bookings-view-switch">
        <% %w[agenda day week month].each do |mode| %>
          <%= link_to t("ui.admin.appointments.views.#{mode}"), admin_bookings_path(request.query_parameters.merge(view: mode)), class: ["admin-bookings-view-switch__link", ("is-active" if @view_mode == mode)].compact.join(" "), data: { testid: "admin-bookings-view-#{mode}" } %>
        <% end %>
      </div>
    </div>
  </div>

  <%= form_with url: admin_bookings_path, method: :get, class: "admin-filter-form", local: true, data: { testid: "admin-bookings-filters" } do %>
    <%= hidden_field_tag :view, @view_mode %>
    <div>
      <%= label_tag :date, t("ui.admin.appointments.filters.anchor_date") %>
      <%= date_field_tag :date, @anchor_date, data: { testid: "bookings-filter-anchor-date" } %>
    </div>
    <div>
      <%= label_tag :property_id, t("ui.common.property") %>
      <%= select_tag :property_id, options_from_collection_for_select(@properties, :id, :address_line_1, params[:property_id]), include_blank: t("ui.admin.appointments.filters.all_properties"), data: { testid: "bookings-filter-property" } %>
    </div>
    <div>
      <%= label_tag :status, t("ui.common.status") %>
      <%= select_tag :status, options_for_select(@statuses.map { |status| [I18n.t("ui.appointments.statuses.#{status}", default: status.humanize), status] }, params[:status]), include_blank: t("ui.admin.appointments.filters.all_statuses"), data: { testid: "bookings-filter-status" } %>
    </div>
    <div>
      <%= label_tag :admin_id, t("ui.admin.appointments.filters.assigned_admin") %>
      <%= select_tag :admin_id, options_from_collection_for_select(@admins, :id, :email, params[:admin_id]), include_blank: t("ui.admin.appointments.filters.anyone"), data: { testid: "bookings-filter-admin" } %>
    </div>
    <div>
      <%= label_tag :visit_outcome, "Visit outcome" %>
      <%= select_tag :visit_outcome, options_for_select(@visit_outcomes.map { |outcome| [outcome.to_s.humanize, outcome] }, params[:visit_outcome]), include_blank: "Any outcome", data: { testid: "bookings-filter-outcome" } %>
    </div>
    <div>
      <%= label_tag :from, "From" %>
      <%= date_field_tag :from, params[:from], data: { testid: "bookings-filter-from" } %>
    </div>
    <div>
      <%= label_tag :to, "To" %>
      <%= date_field_tag :to, params[:to], data: { testid: "bookings-filter-to" } %>
    </div>
    <div>
      <%= label_tag :customer_email, t("ui.admin.appointments.filters.customer_email") %>
      <%= text_field_tag :customer_email, params[:customer_email], placeholder: t("ui.admin.appointments.filters.customer_email_placeholder"), data: { testid: "bookings-filter-customer-email" } %>
    </div>
    <div class="admin-filter-form__actions">
      <%= button_tag t("ui.common.apply"), class: "button primary" %>
      <%= link_to t("ui.common.reset"), admin_bookings_path(view: @view_mode), class: "button hollow secondary" %>
    </div>
<% end %>
</section>

<% if @view_mode == "agenda" %>
  <section class="admin-section admin-bookings-agenda-days" data-testid="admin-bookings-agenda-days">
    <% @appointments_by_day.each do |date, appointments| %>
      <article class="admin-panel">
        <h2><%= l(date, format: :long) %></h2>
        <div class="admin-list admin-bookings-agenda-list" data-testid="admin-bookings-agenda-list">
          <% appointments.each do |appointment| %>
            <div class="admin-list__item" data-testid="admin-appointment-row">
              <div>
                <%= link_to appointment.customer_name, admin_appointment_path(appointment) %>
                <p>
                  <%= link_to appointment.property.address_line_1, admin_property_path(appointment.property), data: { testid: "admin-appointment-property-link-#{appointment.id}" } %>
                  · <%= formatted_date_time(appointment.scheduled_at) %>
                </p>
              </div>

              <div class="admin-inline-actions admin-bookings-row__actions" data-testid="admin-bookings-row-actions">
                <span class="<%= [appointment_status_badge_class(appointment.status), "admin-bookings-row__pill"].join(" ") %>"><%= appointment.display_status %></span>
                <% if appointment.visit_outcome.present? %>
                  <span class="badge badge--neutral admin-bookings-row__pill"><%= appointment.visit_outcome.to_s.humanize %></span>
                <% end %>
                <%= button_to t("ui.admin.appointments.confirm"), transition_admin_appointment_path(appointment, status: "confirmed"), method: :patch, class: "button success hollow admin-bookings-row__action" unless appointment.status == "confirmed" %>
                <%= button_to t("ui.admin.appointments.cancel"), transition_admin_appointment_path(appointment, status: "cancelled"), method: :patch, class: "button alert hollow admin-bookings-row__action" unless appointment.status == "cancelled" %>
              </div>
            </div>
          <% end %>
        </div>
      </article>
    <% end %>
  </section>
<% else %>
  <section class="admin-calendar-grid admin-calendar-grid--<%= @view_mode %>">
    <% @calendar_days.each do |day| %>
      <article class="admin-calendar-day">
        <header>
          <strong><%= l(day, format: :calendar_day) %></strong>
          <span><%= translate_count("ui.admin.appointments.bookings_count", @appointments_by_day.fetch(day, []).count) %></span>
        </header>
        <div class="admin-calendar-day__body">
          <% @appointments_by_day.fetch(day, []).first(@view_mode == "month" ? 4 : 12).each do |appointment| %>
            <%= link_to admin_appointment_path(appointment), class: "calendar-entry #{appointment.status}" do %>
              <strong><%= l(appointment.scheduled_at, format: :time_only) %></strong>
              <span><%= appointment.customer_name %></span>
            <% end %>
          <% end %>
        </div>
      </article>
    <% end %>
  </section>
<% end %>
