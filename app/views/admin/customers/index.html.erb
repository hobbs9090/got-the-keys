<% title t("ui.admin.customers.index.title") %>

<section class="admin-section">
  <div class="section-heading">
    <div>
      <p class="section-heading__eyebrow"><%= t("ui.admin.customers.index.eyebrow") %></p>
      <h1><%= t("ui.admin.customers.index.title") %></h1>
      <p data-testid="admin-customers-count"><%= translate_count("ui.admin.customers.index.count_label", @customers.total_count) %></p>
    </div>
  </div>
</section>

<section class="admin-panel">
  <%= form_with url: admin_customers_path, method: :get, class: "admin-filter-form", local: true, data: { testid: "admin-customers-search" } do |f| %>
    <div>
      <%= f.label :q, t("ui.admin.customers.index.search.label") %>
      <%= f.search_field :q, value: @query, placeholder: t("ui.admin.customers.index.search.placeholder"), data: { testid: "admin-customers-search-input" } %>
    </div>
    <div class="admin-filter-form__actions">
      <%= f.button t("ui.admin.customers.index.search.submit"), type: :submit, class: "button primary", data: { testid: "admin-customers-search-submit" } %>
      <%= link_to t("ui.admin.customers.index.search.clear"), admin_customers_path, class: "button hollow secondary", data: { testid: "admin-customers-search-clear" } %>
    </div>
  <% end %>
</section>

<section class="admin-panel">
  <% if @customers.any? %>
    <div class="admin-list">
      <% @customers.each do |customer| %>
        <article class="admin-list__item" data-testid="admin-customer-row-<%= customer.email_key.parameterize %>">
          <div>
            <%= link_to customer.customer_name.presence || customer.customer_email, admin_customer_path(customer.email_key) %>
            <p><%= admin_customer_display_email(customer.customer_email) %> · <%= customer.customer_phone.presence || t("ui.admin.appointments.show.not_supplied") %></p>
            <% badges = admin_customer_badges(customer) %>
            <% if badges.any? %>
              <div class="admin-customer-badges">
                <% badges.each do |badge| %>
                  <span class="badge <%= badge[:css_class] %>" data-testid="admin-customer-badge-<%= customer.email_key.parameterize %>-<%= badge[:key] %>"><%= badge[:label] %></span>
                <% end %>
              </div>
            <% end %>
            <p>
              <%= translate_count("ui.admin.customers.index.appointment_count", customer.appointments_count.to_i) %>
              <% if customer.latest_appointment_at.present? %>
                · <%= formatted_date_time(customer.latest_appointment_at) %>
              <% elsif customer.registered_at.present? %>
                · <%= t("ui.admin.customers.index.registered_on", time: formatted_date_time(customer.registered_at)) %>
              <% end %>
            </p>
          </div>
          <div class="admin-inline-actions">
            <%= link_to t("ui.admin.customers.index.view_bookings"), admin_appointments_path(view: "agenda", customer_email: customer.customer_email), class: "button primary hollow", data: { testid: "admin-customer-view-bookings-#{customer.email_key.parameterize}" } %>
          </div>
        </article>
      <% end %>
    </div>

    <%= paginate @customers %>
  <% else %>
    <p class="empty-copy"><%= t("ui.admin.customers.index.no_results") %></p>
  <% end %>
</section>
