<% title t("ui.admin.dashboard.title") %>

<section class="admin-section">
  <div class="section-heading">
    <div>
      <p class="section-heading__eyebrow"><%= t("ui.admin.dashboard.eyebrow") %></p>
      <h1><%= t("ui.admin.dashboard.title") %></h1>
    </div>

  </div>

  <div class="admin-dashboard__status-grid" data-testid="admin-dashboard-status-grid">
    <% @metrics.each do |label, value| %>
      <article class="admin-dashboard__status-card admin-dashboard__status-card--<%= label.to_s.dasherize %>" data-testid="admin-status-card-<%= label %>">
        <strong class="admin-dashboard__status-value"><%= number_with_delimiter(value, delimiter: ",") %></strong>
        <div class="admin-dashboard__status-copy">
          <span class="admin-dashboard__status-label"><%= t("ui.admin.dashboard.metrics.#{label}", default: label.to_s.humanize) %></span>
        </div>
      </article>
    <% end %>
  </div>
</section>

<section class="admin-panel">
  <div class="section-heading">
    <div>
      <p class="section-heading__eyebrow"><%= t("ui.admin.dashboard.bookings_eyebrow") %></p>
      <h2><%= t("ui.admin.dashboard.bookings_title") %></h2>
    </div>

    <div class="admin-dashboard__quick-links">
      <%= link_to t("ui.admin.dashboard.all_bookings"), admin_bookings_path, class: "button primary admin-dashboard__quick-link" %>
      <%= link_to t("ui.admin.dashboard.pending_action"), admin_bookings_path(status: "pending"), class: "button secondary hollow admin-dashboard__quick-link" %>
      <%= link_to t("ui.admin.dashboard.this_week"), admin_bookings_path(view: "week", date: Date.current), class: "button secondary hollow admin-dashboard__quick-link" %>
    </div>
  </div>

  <p><%= t("ui.admin.dashboard.bookings_body") %></p>
</section>

<section class="admin-grid">
  <article class="admin-panel">
    <h2><%= t("ui.admin.dashboard.bookings_requiring_action") %></h2>
    <% if @pending_appointments.any? %>
      <div class="admin-list">
        <% @pending_appointments.each do |appointment| %>
          <div class="admin-list__item">
            <div>
              <%= link_to appointment.customer_name, admin_appointment_path(appointment) %>
              <p><%= appointment.property.address_line_1 %> · <%= formatted_date_time(appointment.scheduled_at) %></p>
            </div>
            <span class="<%= appointment_status_badge_class(appointment.status) %>"><%= appointment.display_status %></span>
          </div>
        <% end %>
      </div>
    <% else %>
      <p class="empty-copy"><%= t("ui.admin.dashboard.nothing_needs_attention") %></p>
    <% end %>
  </article>

  <article class="admin-panel">
    <h2><%= t("ui.admin.dashboard.recent_leads") %></h2>
    <% if @recent_enquiries.any? %>
      <div class="admin-list">
        <% @recent_enquiries.each do |enquiry| %>
          <div class="admin-list__item">
            <div>
              <%= link_to enquiry.customer_name, admin_enquiry_path(enquiry) %>
              <p><%= enquiry.property.address_line_1 %> · <%= enquiry_source_label(enquiry.source_type) %></p>
            </div>
            <span class="<%= enquiry_status_badge_class(enquiry.status) %>"><%= enquiry.display_status %></span>
          </div>
        <% end %>
      </div>
    <% else %>
      <p class="empty-copy"><%= t("ui.admin.dashboard.no_leads") %></p>
    <% end %>
  </article>
</section>

<section class="admin-grid">
  <article class="admin-panel">
    <h2><%= t("ui.admin.dashboard.upcoming_appointments") %></h2>
    <% if @upcoming_appointments.any? %>
      <div class="admin-list">
        <% @upcoming_appointments.each do |appointment| %>
          <div class="admin-list__item">
            <div>
              <%= link_to appointment.property.address_line_1, admin_appointment_path(appointment) %>
              <p><%= appointment.customer_name %> · <%= formatted_date_time(appointment.scheduled_at) %></p>
            </div>
            <span class="<%= appointment_status_badge_class(appointment.status) %>"><%= appointment.display_status %></span>
          </div>
        <% end %>
      </div>
    <% else %>
      <p class="empty-copy"><%= t("ui.admin.dashboard.no_upcoming_bookings") %></p>
    <% end %>
  </article>
  <article class="admin-panel">
    <h2><%= t("ui.admin.dashboard.recent_activity") %></h2>
    <div class="admin-list">
      <% @recent_appointments.each do |appointment| %>
        <div class="admin-list__item">
          <div>
            <%= link_to appointment.public_reference, admin_appointment_path(appointment) %>
            <p><%= appointment.customer_name %> · <%= appointment.property.address_line_1 %></p>
          </div>
          <span class="<%= [appointment_status_badge_class(appointment.status), "admin-bookings-row__pill"].join(" ") %>"><%= appointment.display_status %></span>
        </div>
      <% end %>
    </div>
  </article>

  <article class="admin-panel">
    <h2><%= t("ui.admin.dashboard.notification_log_snapshot") %></h2>
    <% if @notification_logs.any? %>
      <div class="admin-list">
        <% @notification_logs.each do |log| %>
          <div class="admin-list__item">
            <div>
              <strong><%= log.subject %></strong>
              <p><%= log.recipient_email %> · <%= formatted_date_time(log.created_at) %></p>
            </div>
            <span class="<%= appointment_status_badge_class(admin_notification_badge_state(log.status)) %>"><%= admin_notification_status_label(log.status) %></span>
          </div>
        <% end %>
      </div>
    <% else %>
      <p class="empty-copy"><%= t("ui.admin.dashboard.no_notification_records") %></p>
    <% end %>
  </article>
</section>

<section class="admin-panel">
  <h2><%= t("ui.admin.dashboard.last_demo_data_action") %></h2>
  <% if @latest_demo_run.present? %>
    <p><strong><%= admin_demo_action_label(@latest_demo_run.action_type) %></strong> <%= t("ui.admin.dashboard.on") %> <%= formatted_date_time(@latest_demo_run.created_at) %></p>
    <p><%= @latest_demo_run.summary_data&.fetch("name", translated_demo_scenario_key(@latest_demo_run.scenario_key)) %></p>
  <% else %>
    <p class="empty-copy"><%= t("ui.admin.dashboard.no_demo_action") %></p>
  <% end %>
</section>
