<% title t("ui.admin.rental_applications.index.title") %>

<section class="admin-section">
  <div class="section-heading">
    <div>
      <p class="section-heading__eyebrow"><%= t("ui.admin.rental_applications.index.eyebrow") %></p>
      <h1><%= t("ui.admin.rental_applications.index.title") %></h1>
    </div>
  </div>
</section>

<section class="admin-grid admin-grid--board">
  <% @applications_by_status.each do |status, applications| %>
    <article class="admin-panel" data-testid="rental-applications-column-<%= status %>">
      <h2><%= t("ui.rental_applications.statuses.#{status}", default: status.humanize).to_s.capitalize %></h2>
      <% if applications.any? %>
        <div class="admin-list">
          <% applications.each do |application| %>
            <div class="admin-list__item">
              <div>
                <%= link_to application.applicant_name, admin_customer_path(application.applicant_email.to_s.downcase) %>
                <p><%= application.property.address_line_1 %> · <%= t("ui.admin.rental_applications.index.move_in", date: application.move_in_date) %></p>
              </div>
              <div class="admin-inline-actions">
                <span class="<%= rental_application_status_badge_class(application.status) %>"><%= t("ui.rental_applications.statuses.#{application.status}", default: application.status.humanize) %></span>
                <%= link_to t("ui.admin.common.details", default: "Details"), admin_rental_path(application), class: "button primary hollow", data: { testid: "admin-rental-application-open-#{application.id}" } %>
              </div>
            </div>
          <% end %>
        </div>
      <% else %>
        <p class="empty-copy"><%= t("ui.admin.rental_applications.index.empty_column") %></p>
      <% end %>
    </article>
  <% end %>
</section>
