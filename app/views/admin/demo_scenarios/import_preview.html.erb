<% title "Import preview #{@preview.fetch(:name)}" %>

<section class="admin-section">
  <div class="section-heading">
    <div>
      <p class="section-heading__eyebrow">Import preview</p>
      <h1><%= @preview.fetch(:name) %></h1>
    </div>
  </div>

  <article class="admin-panel">
    <p><%= @preview.fetch(:description) %></p>
    <dl class="detail-list">
      <% @preview.except(:name, :description).each do |label, value| %>
        <div>
          <dt><%= label.to_s.humanize %></dt>
          <dd><%= value.is_a?(Hash) ? value.map { |k, v| "#{k}: #{v}" }.join(", ") : value %></dd>
        </div>
      <% end %>
    </dl>

    <div class="form-actions">
      <%= button_to "Apply imported scenario", apply_import_admin_demo_scenarios_path, method: :post, class: "button primary" %>
      <%= link_to "Back to import", import_admin_demo_scenarios_path, class: "button hollow secondary" %>
    </div>
  </article>

  <article class="admin-panel">
    <h2>Raw YAML</h2>
    <pre class="code-block"><%= @raw_yaml %></pre>
  </article>
</section>
