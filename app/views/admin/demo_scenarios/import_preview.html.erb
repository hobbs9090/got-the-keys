<% title t("ui.admin.demo_data.import_preview.title", name: @preview.fetch(:name)) %>

<section class="admin-section">
  <div class="section-heading">
    <div>
      <p class="section-heading__eyebrow"><%= t("ui.admin.demo_data.import_preview.eyebrow") %></p>
      <h1><%= @preview.fetch(:name) %></h1>
    </div>
  </div>

  <article class="admin-panel" data-testid="import-preview-panel">
    <p><%= @preview.fetch(:description) %></p>
    <dl class="detail-list">
      <% @preview.except(:name, :description).each do |label, value| %>
        <div>
          <dt><%= admin_demo_label(label) %></dt>
          <dd><%= admin_demo_value(label, value) %></dd>
        </div>
      <% end %>
    </dl>

    <div class="form-actions">
      <%= button_to t("ui.admin.demo_data.import_preview.apply_imported_scenario"), apply_import_admin_demo_scenarios_path, method: :post, class: "button primary", form: { data: { testid: "import-apply-form" } } %>
      <%= link_to t("ui.admin.demo_data.import_preview.back_to_import"), import_admin_demo_scenarios_path, class: "button hollow secondary" %>
    </div>
  </article>

  <article class="admin-panel">
    <h2><%= t("ui.admin.demo_data.import_preview.raw_yaml") %></h2>
    <pre class="code-block"><%= @raw_yaml %></pre>
  </article>
</section>
