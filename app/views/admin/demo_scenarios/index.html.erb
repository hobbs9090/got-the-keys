<% title t("ui.admin.demo_data.title") %>

<section class="admin-section">
  <div class="section-heading">
    <div>
      <p class="section-heading__eyebrow"><%= t("ui.admin.demo_data.eyebrow") %></p>
      <h1><%= t("ui.admin.demo_data.title") %></h1>
      <p><%= t("ui.admin.demo_data.baseline_only_body", default: "The admin reset flow is currently limited to the baseline demo dataset so QA always has one predictable starting point.") %></p>
    </div>
  </div>
</section>

<section class="admin-grid">
  <article class="admin-panel">
    <h2><%= t("ui.admin.demo_data.diagnostics_title") %></h2>
    <dl class="detail-list">
      <% @diagnostics.each do |label, value| %>
        <div>
          <dt><%= admin_demo_label(label) %></dt>
          <dd><%= value.is_a?(Time) ? formatted_date_time(value) : value %></dd>
        </div>
      <% end %>
    </dl>
  </article>

  <article class="admin-panel">
    <h2><%= @baseline_scenario.fetch(:name) %></h2>
    <p><%= @baseline_scenario.fetch(:description) %></p>
    <ul class="detail-inline-list admin-demo-scenario-card__meta">
      <li><strong><%= @baseline_scenario.fetch(:property_count) %></strong> <%= t("ui.admin.demo_data.counts.properties", count: @baseline_scenario.fetch(:property_count)) %></li>
      <li><strong><%= @baseline_scenario.fetch(:appointment_count) %></strong> <%= t("ui.admin.demo_data.counts.bookings", count: @baseline_scenario.fetch(:appointment_count)) %></li>
      <li><strong><%= @baseline_scenario.fetch(:user_count) %></strong> <%= t("ui.admin.demo_data.counts.sellers", count: @baseline_scenario.fetch(:user_count)) %></li>
      <li><strong><%= @baseline_scenario.fetch(:enquiry_count, 0) %></strong> leads</li>
      <li><strong><%= @baseline_scenario.fetch(:offer_count, 0) %></strong> offers</li>
      <li><strong><%= @baseline_scenario.fetch(:rental_application_count, 0) %></strong> rental applications</li>
    </ul>
  </article>
</section>

<section class="admin-panel admin-demo-danger-zone" data-testid="scenario-seed-reset-panel">
  <div class="admin-demo-danger-zone__header">
    <p class="admin-demo-danger-zone__eyebrow"><%= t("ui.admin.demo_data.seed_resets.eyebrow") %></p>
    <h2><%= t("ui.admin.demo_data.seed_resets.title") %></h2>
    <p><%= t("ui.admin.demo_data.seed_resets.baseline_only_description", default: "Use this to rebuild the shared baseline training dataset. Other curated resets are hidden for now so the admin flow stays simple.") %></p>
  </div>

  <div class="admin-demo-danger-zone__list" data-testid="scenario-seed-reset-list">
    <%= render "seed_reset_gate",
               scenario: @baseline_scenario,
               return_to: admin_demo_scenarios_path,
               show_preview_link: false,
               compact: true,
               action_url: restore_baseline_admin_demo_scenarios_path,
               button_text: t("ui.admin.demo_data.restore_baseline") %>
  </div>
</section>

<section class="admin-section">
  <div class="section-heading">
    <div>
      <p class="section-heading__eyebrow"><%= t("ui.admin.demo_data.eyebrow") %></p>
      <h2><%= t("ui.admin.demo_data.last_demo_action_title") %></h2>
    </div>
  </div>
</section>

<section class="admin-grid">
  <article class="admin-panel">
    <% if @latest_run.present? %>
      <p><strong><%= admin_demo_action_label(@latest_run.action_type) %></strong> <%= t("ui.admin.dashboard.on") %> <%= formatted_date_time(@latest_run.created_at) %></p>
      <pre class="code-block"><%= JSON.pretty_generate(@latest_run.summary_data || {}) %></pre>
    <% else %>
      <p class="empty-copy"><%= t("ui.admin.demo_data.no_actions") %></p>
    <% end %>
  </article>
</section>
