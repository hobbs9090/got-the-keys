<% title t("ui.admin.demo_data.title") %>

<section class="admin-section">
  <div class="section-heading">
    <div>
      <p class="section-heading__eyebrow"><%= t("ui.admin.demo_data.eyebrow") %></p>
      <h1><%= t("ui.admin.demo_data.title") %></h1>
      <p><%= t("ui.admin.demo_data.baseline_only_body", default: "The admin reset flow is currently limited to the baseline demo dataset so QA always has one predictable starting point.") %></p>
    </div>
    <div class="section-heading__actions admin-dashboard__quick-links">
      <%= link_to t("ui.admin.demo_data.export_current_data"), export_admin_demo_scenarios_path, class: "button secondary small admin-dashboard__quick-link" %>
      <%= link_to t("ui.admin.demo_data.import_scenario"), import_admin_demo_scenarios_path, class: "button secondary small admin-dashboard__quick-link" %>
    </div>
  </div>
</section>

<section class="admin-panel admin-demo-danger-zone" data-testid="scenario-seed-reset-panel">
  <div class="admin-demo-danger-zone__header">
    <p class="admin-demo-danger-zone__eyebrow"><%= t("ui.admin.demo_data.seed_resets.eyebrow") %></p>
    <h2><%= t("ui.admin.demo_data.seed_resets.title") %></h2>
    <p><%= t("ui.admin.demo_data.seed_resets.baseline_only_description", default: "Use this to rebuild the shared baseline training dataset.") %></p>
  </div>

  <div class="admin-demo-danger-zone__list" data-testid="scenario-seed-reset-list">
    <%= render "seed_reset_gate",
               scenario: @baseline_scenario,
               return_to: admin_demo_scenarios_path,
               show_preview_link: false,
               compact: true,
               action_url: restore_baseline_admin_demo_scenarios_path,
               button_text: t("ui.admin.demo_data.restore_baseline") %>
  </div>
</section>

<section class="admin-panel" data-testid="performance-seed-panel">
  <div class="section-heading">
    <div>
      <p class="section-heading__eyebrow"><%= t("ui.admin.demo_data.performance_seed.eyebrow") %></p>
      <h2><%= t("ui.admin.demo_data.performance_seed.title") %></h2>
      <p><%= t("ui.admin.demo_data.performance_seed.description") %></p>
    </div>
  </div>

  <div class="admin-grid admin-grid--split">
    <article class="admin-panel">
      <h3><%= t("ui.admin.demo_data.performance_seed.instructions_title") %></h3>
      <ol>
        <% t("ui.admin.demo_data.performance_seed.instructions").each do |instruction| %>
          <li><%= instruction %></li>
        <% end %>
      </ol>
    </article>

    <article class="admin-panel">
      <h3><%= t("ui.admin.demo_data.performance_seed.parameters_title") %></h3>
      <dl class="detail-list">
        <% %i[user_count property_count password ai_mode batch_size model].each do |field| %>
          <div>
            <dt><%= t("ui.admin.demo_data.performance_seed.fields.#{field}") %></dt>
            <dd><%= t("ui.admin.demo_data.performance_seed.field_help.#{field}") %></dd>
          </div>
        <% end %>
      </dl>
    </article>
  </div>

  <%= form_with url: populate_performance_admin_demo_scenarios_path, method: :post, class: "stacked-form", local: true, data: { testid: "performance-seed-form" } do %>
    <div class="admin-grid admin-grid--split">
      <div>
        <%= label_tag "performance_seed_user_count", t("ui.admin.demo_data.performance_seed.fields.user_count") %>
        <%= number_field_tag "performance_seed[user_count]", @performance_seed_form.fetch(:user_count), min: 1, step: 1, required: true, data: { testid: "performance-seed-user-count" } %>
      </div>
      <div>
        <%= label_tag "performance_seed_property_count", t("ui.admin.demo_data.performance_seed.fields.property_count") %>
        <%= number_field_tag "performance_seed[property_count]", @performance_seed_form.fetch(:property_count), min: 0, step: 1, required: true, data: { testid: "performance-seed-property-count" } %>
      </div>
      <div>
        <%= label_tag "performance_seed_password", t("ui.admin.demo_data.performance_seed.fields.password") %>
        <%= text_field_tag "performance_seed[password]", @performance_seed_form.fetch(:password), required: true, data: { testid: "performance-seed-password" } %>
      </div>
      <div>
        <%= label_tag "performance_seed_ai_mode", t("ui.admin.demo_data.performance_seed.fields.ai_mode") %>
        <%= select_tag "performance_seed[ai_mode]",
                       options_for_select(
                         [
                           [t("ui.admin.demo_data.performance_seed.ai_modes.off"), "off"],
                           [t("ui.admin.demo_data.performance_seed.ai_modes.auto"), "auto"],
                           [t("ui.admin.demo_data.performance_seed.ai_modes.on"), "on"]
                         ],
                         @performance_seed_form.fetch(:ai_mode)
                       ),
                       data: { testid: "performance-seed-ai-mode" } %>
      </div>
      <% ai_mode_is_off = @performance_seed_form.fetch(:ai_mode).to_s == "off" %>
      <div class="admin-perf-seed__ai-section">
        <div class="admin-perf-seed__ai-label">
          <%= t("ui.admin.demo_data.performance_seed.fields.ai_mode") %> dependent settings
        </div>

        <div class="admin-perf-seed__ai-fields">
          <div>
            <%= label_tag "performance_seed_batch_size", t("ui.admin.demo_data.performance_seed.fields.batch_size") %>
            <%= number_field_tag "performance_seed[batch_size]", @performance_seed_form.fetch(:batch_size), min: 1, step: 1, required: true, disabled: ai_mode_is_off, data: { testid: "performance-seed-batch-size" } %>
          </div>
          <div>
            <%= label_tag "performance_seed_model", t("ui.admin.demo_data.performance_seed.fields.model") %>
            <%= select_tag "performance_seed[model]",
                           options_for_select(
                             DemoData::OpenaiEnrichmentModels::AVAILABLE.map { |model| [model, model] },
                             @performance_seed_form.fetch(:model)
                           ),
                           required: true,
                           disabled: ai_mode_is_off,
                           data: { testid: "performance-seed-model" } %>
          </div>
        </div>
      </div>
    </div>

    <%= javascript_tag nonce: true do %>
      // Keep AI enrichment dependent settings in sync with the selected mode.
      // This inline script makes the behavior reliable even if the JS bundle
      // isn't immediately updated in a dev/browser refresh scenario.
      (() => {
        const form = document.querySelector('[data-testid="performance-seed-form"]');
        if (!form) return;

        const aiModeSelect = form.querySelector('[data-testid="performance-seed-ai-mode"]');
        const batchSizeInput = form.querySelector('[data-testid="performance-seed-batch-size"]');
        const modelInput = form.querySelector('[data-testid="performance-seed-model"]');
        if (!aiModeSelect || !batchSizeInput || !modelInput) return;

        const storageKey = "gotthekeys-admin-performance-seed-form";

        const readPersisted = () => {
          try {
            const raw = window.sessionStorage.getItem(storageKey);
            return raw ? JSON.parse(raw) : {};
          } catch (_error) {
            return {};
          }
        };

        const writePersisted = (next) => {
          try {
            window.sessionStorage.setItem(storageKey, JSON.stringify(next));
          } catch (_error) {
            // Ignore persistence failures (e.g. storage disabled).
          }
        };

        const apply = () => {
          const aiModeValue = (aiModeSelect.value || "").toString().trim().toLowerCase();
          const isAiModeOff = aiModeValue === "off";

          batchSizeInput.disabled = isAiModeOff;
          modelInput.disabled = isAiModeOff;
          batchSizeInput.required = !isAiModeOff;
          modelInput.required = !isAiModeOff;
        };

        const persisted = readPersisted();
        const persistedAiMode = (persisted.ai_mode || "").toString().trim().toLowerCase();
        if (persistedAiMode && ["off", "auto", "on"].includes(persistedAiMode)) {
          aiModeSelect.value = persistedAiMode;
          // If we also persisted values, restore them before applying disabled/enabled.
          if (persisted.batch_size != null) batchSizeInput.value = persisted.batch_size;
          if (persisted.model != null) modelInput.value = persisted.model;
        }

        const onAiModeChange = () => {
          writePersisted({
            ai_mode: aiModeSelect.value,
            batch_size: batchSizeInput.value,
            model: modelInput.value
          });
          apply();
        };

        // Some environments may fire `input` instead of `change` for select changes.
        aiModeSelect.addEventListener("change", onAiModeChange);
        aiModeSelect.addEventListener("input", onAiModeChange);

        batchSizeInput.addEventListener("input", () => {
          writePersisted({
            ai_mode: aiModeSelect.value,
            batch_size: batchSizeInput.value,
            model: modelInput.value
          });
        });

        modelInput.addEventListener("input", () => {
          writePersisted({
            ai_mode: aiModeSelect.value,
            batch_size: batchSizeInput.value,
            model: modelInput.value
          });
        });

        apply();
      })();
    <% end %>

    <div class="admin-filter-form__actions">
      <%= button_tag t("ui.admin.demo_data.performance_seed.submit"), class: "button primary", data: { testid: "performance-seed-submit" } %>
    </div>
  <% end %>
</section>

<section class="admin-panel" data-testid="scenario-run-history-panel">
  <h2><%= t("ui.admin.demo_data.run_history_title", default: "Recent activity") %></h2>
  <% if @scenario_runs.empty? %>
    <p class="quiet"><%= t("ui.admin.demo_data.no_actions") %></p>
  <% else %>
    <ol class="timeline" data-testid="scenario-run-history-list">
      <% @scenario_runs.each do |run| %>
        <li>
          <p><strong><%= admin_demo_action_label(run.action_type) %></strong></p>
          <% if run.scenario_key.present? %>
            <p><%= run.scenario_key %> &mdash; <%= run.initiated_by_email %></p>
          <% else %>
            <p><%= run.initiated_by_email %></p>
          <% end %>
          <p><%= formatted_date_time(run.created_at) %></p>
        </li>
      <% end %>
    </ol>
  <% end %>
</section>

