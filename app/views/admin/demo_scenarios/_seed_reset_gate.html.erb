<% scenario_key = scenario.fetch(:key).to_s %>
<% scenario_slug = scenario_key.dasherize %>
<% confirmation_phrase = admin_demo_confirmation_phrase(scenario) %>
<% field_id = "confirm-demo-scenario-#{scenario_slug}" %>
<% hint_id = "#{field_id}-hint" %>
<% show_preview_link = local_assigns.fetch(:show_preview_link, true) %>
<% compact = local_assigns.fetch(:compact, false) %>
<% action_url = local_assigns.fetch(:action_url, apply_admin_demo_scenario_path(scenario_key)) %>
<% button_text = local_assigns.fetch(:button_text, t("ui.admin.demo_data.seed_resets.apply")) %>

<article class="admin-demo-danger-zone__item" data-testid="scenario-seed-reset-<%= scenario_slug %>">
  <div class="admin-demo-danger-zone__content">
    <div class="admin-demo-danger-zone__title-row">
      <div class="admin-demo-danger-zone__title-copy">
        <h3><%= admin_scenario_name_label(scenario) %></h3>
        <p><%= admin_scenario_description_label(scenario) %></p>
      </div>
    </div>

    <% if compact %>
      <ul class="detail-inline-list admin-demo-danger-zone__meta">
        <li><strong><%= scenario.fetch(:property_count) %></strong> <%= t("ui.admin.demo_data.counts.properties", count: scenario.fetch(:property_count)) %></li>
        <li><strong><%= scenario.fetch(:appointment_count) %></strong> <%= t("ui.admin.demo_data.counts.bookings", count: scenario.fetch(:appointment_count)) %></li>
        <li><strong><%= scenario.fetch(:user_count) %></strong> <%= t("ui.admin.demo_data.counts.sellers", count: scenario.fetch(:user_count)) %></li>
        <li><strong><%= scenario.fetch(:enquiry_count, 0) %></strong> <%= t("ui.admin.demo_data.counts.leads", count: scenario.fetch(:enquiry_count, 0)) %></li>
        <li><strong><%= scenario.fetch(:offer_count, 0) %></strong> <%= t("ui.admin.demo_data.counts.offers", count: scenario.fetch(:offer_count, 0)) %></li>
        <li><strong><%= scenario.fetch(:rental_application_count, 0) %></strong> <%= t("ui.admin.demo_data.counts.rental_applications", count: scenario.fetch(:rental_application_count, 0)) %></li>
      </ul>
    <% else %>
      <ul class="detail-inline-list admin-demo-danger-zone__meta">
        <li><strong><%= t("ui.admin.demo_data.seed_resets.journey") %></strong>: <%= admin_scenario_journey_label(scenario) %></li>
        <li><strong><%= t("ui.admin.demo_data.seed_resets.risk") %></strong>: <%= admin_scenario_risk_type_label(scenario.dig(:qa, :risk_type)) %></li>
        <li><strong><%= t("ui.admin.demo_data.seed_resets.locales") %></strong>: <%= Array(scenario.dig(:qa, :locale_coverage)).join(", ") %></li>
      </ul>
    <% end %>

    <p class="admin-demo-danger-zone__hint" id="<%= hint_id %>">
      <%= t("ui.admin.demo_data.seed_resets.type_to_continue_html", phrase: content_tag(:span, confirmation_phrase, class: "admin-demo-danger-zone__phrase")) %>
    </p>
  </div>

  <div class="admin-demo-danger-zone__actions">
    <% if show_preview_link %>
      <%= link_to t("ui.admin.demo_data.seed_resets.preview"), admin_demo_scenario_path(scenario_key), class: "button hollow secondary" %>
    <% end %>

    <%= form_with url: action_url, method: :post, local: true, class: "admin-demo-danger-zone__form", data: { testid: "scenario-seed-reset-form-#{scenario_slug}" } do %>
      <%= hidden_field_tag :return_to, return_to %>

      <div class="admin-demo-danger-zone__field">
        <%= label_tag field_id, t("ui.admin.demo_data.seed_resets.field_label", phrase: confirmation_phrase) %>
        <%= text_field_tag :confirm_demo_scenario,
                           nil,
                           id: field_id,
                           class: "admin-demo-danger-zone__input",
                           required: true,
                           pattern: admin_demo_confirmation_pattern(confirmation_phrase),
                           title: t("ui.admin.demo_data.seed_resets.field_label", phrase: confirmation_phrase),
                           placeholder: confirmation_phrase,
                           autocomplete: "off",
                           autocapitalize: "none",
                           spellcheck: false,
                           aria: { describedby: hint_id },
                           data: { testid: "scenario-seed-reset-input-#{scenario_slug}" } %>
      </div>

      <%= button_tag button_text, class: "button alert admin-demo-danger-zone__submit", data: { testid: "scenario-seed-reset-apply-#{scenario_slug}" } %>
    <% end %>
  </div>
</article>
