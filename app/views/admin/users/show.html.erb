<% title t("ui.admin.users.show.title", name: @user.full_name.presence || @user.email) %>

<section class="admin-section">
  <div class="section-heading">
    <div>
      <p class="section-heading__eyebrow"><%= t("ui.admin.users.show.eyebrow") %></p>
      <h1><%= @user.full_name.presence || @user.email %></h1>
    </div>
  </div>
</section>

<section class="admin-grid">
  <article class="admin-panel">
    <h2><%= t("ui.admin.users.show.account_details_title") %></h2>
    <dl class="detail-list">
      <div>
        <dt><%= t("ui.common.email_address") %></dt>
        <dd><%= @user.email %></dd>
      </div>
      <div>
        <dt><%= t("ui.admin.users.show.mobile") %></dt>
        <dd><%= @user.mobile_number %></dd>
      </div>
      <div>
        <dt><%= t("ui.admin.users.show.properties") %></dt>
        <dd><%= translate_count("ui.admin.users.show.listing_count", @user.properties.count) %></dd>
      </div>
    </dl>
  </article>

  <article class="admin-panel">
    <h2><%= t("ui.admin.users.show.recent_booking_activity_title") %></h2>
    <% if @appointments.any? %>
      <div class="admin-list">
        <% @appointments.each do |appointment| %>
          <div class="admin-list__item">
            <div>
              <%= link_to appointment.public_reference, admin_appointment_path(appointment) %>
              <p><%= appointment.property.address_line_1 %> · <%= appointment.customer_name %></p>
            </div>
            <span class="<%= appointment_status_badge_class(appointment.status) %>"><%= appointment.display_status %></span>
          </div>
        <% end %>
      </div>
    <% else %>
      <p class="empty-copy"><%= t("ui.admin.users.show.no_activity") %></p>
    <% end %>
  </article>
</section>

<section class="admin-panel">
  <h2><%= t("ui.admin.users.show.listings_title") %></h2>
  <% if @properties.any? %>
    <div class="admin-list">
      <% @properties.each do |property| %>
        <div class="admin-list__item" data-testid="admin-user-property-row-<%= property.id %>">
          <div>
            <%= link_to property.address_line_1, admin_property_path(property) %>
            <p><%= property.location_line %> · <%= translated_sale_status(property.sale_status) %></p>
          </div>
          <span class="<%= listing_state_badge_class(property.listing_state) %>"><%= translated_listing_state(property.listing_state) %></span>
        </div>
      <% end %>
    </div>
  <% else %>
    <p class="empty-copy"><%= t("ui.admin.users.show.no_properties") %></p>
  <% end %>
</section>
