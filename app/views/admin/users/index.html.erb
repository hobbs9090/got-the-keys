<% title t("ui.admin.users.index.title") %>

<section class="admin-section">
  <div class="section-heading">
    <div>
      <p class="section-heading__eyebrow"><%= t("ui.admin.users.index.eyebrow") %></p>
      <h1><%= t("ui.admin.users.index.title") %></h1>
      <p data-testid="admin-users-count"><%= translate_count("ui.admin.users.index.count_label", @users.total_count) %></p>
    </div>
  </div>
</section>

<section class="admin-panel">
  <%= form_with url: admin_sellers_path, method: :get, class: "admin-filter-form", local: true, data: { testid: "admin-users-search" } do |f| %>
    <div>
      <%= f.label :q, t("ui.admin.users.index.search.label") %>
      <%= f.search_field :q, value: @query, placeholder: t("ui.admin.users.index.search.placeholder"), data: { testid: "admin-users-search-input" } %>
    </div>
    <div class="admin-filter-form__actions">
      <%= f.button t("ui.admin.users.index.search.submit"), type: :submit, class: "button primary", data: { testid: "admin-users-search-submit" } %>
      <%= link_to t("ui.admin.users.index.search.clear"), admin_sellers_path, class: "button hollow secondary", data: { testid: "admin-users-search-clear" } if @query.present? %>
    </div>
  <% end %>
</section>

<section class="admin-panel">
  <% if @users.any? %>
    <div class="admin-list">
      <% @users.each do |user| %>
        <% sale_count = user.properties.count { |property| property.sale_status == Property::SALE_STATUSES[:for_sale] } %>
        <% rent_count = user.properties.count { |property| property.sale_status == Property::SALE_STATUSES[:for_rent] } %>
        <div class="admin-list__item" data-testid="admin-user-row-<%= user.id %>">
          <div>
            <%= link_to user.full_name.presence || user.email, admin_seller_path(user) %>
            <p><%= user.email %></p>
            <div class="admin-customer-badges">
              <% if sale_count.positive? %>
                <span class="badge badge--accent" data-testid="admin-user-sale-count-<%= user.id %>"><%= t("ui.admin.users.index.sale_count_badge", count: sale_count) %></span>
              <% end %>
              <% if rent_count.positive? %>
                <span class="badge badge--success" data-testid="admin-user-rent-count-<%= user.id %>"><%= t("ui.admin.users.index.rent_count_badge", count: rent_count) %></span>
              <% end %>
            </div>
          </div>
          <span class="badge badge--neutral"><%= user.language.upcase %></span>
        </div>
      <% end %>
    </div>

    <%= paginate @users %>
  <% else %>
    <p class="empty-copy"><%= t("ui.admin.users.index.no_results") %></p>
  <% end %>
</section>
