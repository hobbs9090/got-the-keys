<% title t("ui.admin.properties.edit.title", address: @property.address_line_1) %>

<section class="admin-section">
  <div class="section-heading">
    <div>
      <p class="section-heading__eyebrow"><%= t("ui.admin.properties.edit.eyebrow") %></p>
      <h1><%= t("ui.admin.properties.edit.heading") %></h1>
    </div>
  </div>

  <article class="admin-panel">
    <div class="property-hero__media property-hero__media--ratio-3-2" data-testid="admin-property-edit-hero-media">
      <%= medium_image_for(@property) %>
    </div>
  </article>

  <article class="admin-panel">
    <%= render "properties/form", form_model: [:admin, @property], cancel_path: admin_property_path(@property), allow_destroy: false, show_seller_workspace_panel: true %>
  </article>
</section>
