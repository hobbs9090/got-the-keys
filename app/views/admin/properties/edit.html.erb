<% title t("ui.admin.properties.edit.title", address: @property.address_line_1) %>

<section class="admin-section">
  <div class="section-heading">
    <div>
      <p class="section-heading__eyebrow"><%= t("ui.admin.properties.edit.eyebrow") %></p>
      <h1><%= t("ui.admin.properties.edit.heading") %></h1>
    </div>
  </div>

  <article class="admin-panel">
    <h2><%= t("ui.properties.show.seller_title") %></h2>
    <%= render "properties/form", form_model: [:admin, @property], cancel_path: admin_property_path(@property), allow_destroy: false %>
  </article>
</section>
