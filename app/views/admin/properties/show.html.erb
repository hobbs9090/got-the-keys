<% title t("ui.admin.properties.show.title", address: @property.address_line_1) %>

<section class="admin-section">
  <div class="section-heading">
    <div>
      <p class="section-heading__eyebrow"><%= t("ui.admin.properties.show.eyebrow") %></p>
      <p>
        <span class="<%= property_sale_status_badge_class(@property.sale_status) %>" data-testid="admin-property-sale-status-badge"><%= translated_sale_status(@property.sale_status) %></span>
      </p>
      <h1><%= @property.address_line_1 %></h1>
    </div>

    <div class="section-heading__actions admin-property-page__actions">
      <%= link_to t("ui.admin.properties.show.edit_property"), edit_admin_property_path(@property), class: "button primary hollow" %>
      <%= link_to t("ui.admin.properties.show.view_public_page"), property_path(@property), class: "button hollow secondary" %>
    </div>
  </div>
</section>

<section class="admin-grid">
  <article class="admin-panel">
    <h2><%= t("ui.admin.properties.show.summary_title") %></h2>
    <p><strong><%= @property.headline %></strong></p>
    <p><%= @property.property_description %></p>
    <p><%= @property.seller_summary %></p>
    <p><span class="<%= listing_state_badge_class(@property.listing_state) %>"><%= translated_listing_state(@property.listing_state) %></span></p>
    <% if property_fact_rows(@property).any? %>
      <dl class="detail-list">
        <% property_fact_rows(@property).each do |label, value| %>
          <div>
            <dt><%= label %></dt>
            <dd><%= value %></dd>
          </div>
        <% end %>
      </dl>
    <% end %>
  </article>

  <article class="admin-panel admin-property-readiness" data-testid="admin-listing-completeness">
    <h2><%= t("ui.admin.properties.show.readiness_title") %></h2>
    <p><strong><%= t("ui.admin.properties.show.readiness_score", percentage: @property.listing_completeness_percentage) %></strong></p>
    <ul class="detail-inline-list admin-property-readiness__checks">
      <% @property.listing_completeness_checks.each do |check| %>
        <li><strong><%= check[:complete] ? t("ui.properties.show.done") : t("ui.properties.show.needed") %></strong>: <%= check[:label] %></li>
      <% end %>
    </ul>
    <div class="admin-property-readiness__transition-grid" data-testid="listing-transition-grid">
      <% %w[review_pending published under_offer let_agreed sold let withdrawn].each do |state| %>
        <%= button_to translated_listing_state(state),
                      transition_admin_property_path(@property, listing_state: state),
                      method: :patch,
                      class: "button #{state == @property.listing_state ? 'primary' : 'hollow secondary'} admin-property-readiness__transition-button",
                      form_class: "admin-property-readiness__transition-form",
                      data: { testid: "listing-transition-#{state.dasherize}" } %>
      <% end %>
    </div>
  </article>

  <article class="admin-panel">
    <h2><%= t("ui.admin.properties.show.availability_windows_title") %></h2>
    <% if @availability_windows.any? %>
      <div class="admin-list">
        <% @availability_windows.each do |window| %>
          <div class="admin-list__item">
            <div>
              <strong><%= admin_availability_window_kind_label(window.kind) %></strong>
              <p><%= t("ui.admin.properties.show.window_range", start_time: formatted_date_time(window.starts_at), end_time: formatted_date_time(window.ends_at)) %></p>
            </div>
          </div>
        <% end %>
      </div>
    <% else %>
      <p class="empty-copy"><%= t("ui.admin.properties.show.no_windows") %></p>
    <% end %>
  </article>
</section>

<section class="admin-panel">
  <h2><%= t("ui.admin.properties.show.marketing_assets_title") %></h2>
  <div class="admin-grid admin-grid--split">
    <article class="admin-panel">
      <h3><%= t("ui.admin.properties.show.photos_title") %></h3>
      <% if @property.ordered_photos.any? %>
        <div class="admin-list">
          <% @property.ordered_photos.each do |photo| %>
            <div class="admin-list__item">
              <div class="admin-asset-item">
                <% if previewable_image_file?(photo.image_filename) %>
                  <%= image_tag listing_image_source(photo.image_filename),
                                alt: photo.primary? ? t("ui.properties.show.primary_image") : t("ui.admin.properties.show.photo_position", position: photo.position),
                                class: "admin-asset-item__thumbnail",
                                loading: "lazy",
                                data: { testid: "admin-property-photo-thumbnail-#{photo.id}" } %>
                <% end %>
                <div>
                  <strong><%= photo.primary? ? t("ui.properties.show.primary_image") : t("ui.admin.properties.show.photo_position", position: photo.position) %></strong>
                </div>
              </div>
            </div>
          <% end %>
        </div>
      <% else %>
        <p class="empty-copy"><%= t("ui.admin.properties.show.no_photos") %></p>
      <% end %>
    </article>

    <article class="admin-panel">
      <h3><%= t("ui.admin.properties.show.floor_plans_title") %></h3>
      <% if @property.ordered_floor_plans.any? %>
        <div class="admin-list">
          <% @property.ordered_floor_plans.each do |floor_plan| %>
            <div class="admin-list__item">
              <div class="admin-asset-item">
                <% if previewable_image_file?(floor_plan.floor_plans) %>
                  <%= image_tag listing_image_source(floor_plan.floor_plans),
                                alt: floor_plan.label.presence || t("ui.admin.properties.show.floor_plan_position", position: floor_plan.position),
                                class: "admin-asset-item__thumbnail admin-asset-item__thumbnail--contain",
                                loading: "lazy",
                                data: { testid: "admin-property-floor-plan-thumbnail-#{floor_plan.id}" } %>
                <% end %>
                <div>
                  <strong><%= floor_plan.label.presence || t("ui.admin.properties.show.floor_plan_position", position: floor_plan.position) %></strong>
                  <% unless previewable_image_file?(floor_plan.floor_plans) %>
                    <p class="admin-asset-item__filename"><%= floor_plan.floor_plans %></p>
                  <% end %>
                </div>
              </div>
            </div>
          <% end %>
        </div>
      <% else %>
        <p class="empty-copy"><%= t("ui.admin.properties.show.no_floor_plans") %></p>
      <% end %>
    </article>
  </div>
</section>

<section class="admin-panel">
  <h2><%= t("ui.admin.properties.show.documents_title") %></h2>
  <% if @property.ordered_documents.any? %>
    <div class="admin-list">
      <% @property.ordered_documents.each do |document| %>
        <div class="admin-list__item">
          <div>
            <strong><%= document.title %></strong>
            <p><%= document.category_label %> · <%= document.visibility.humanize %> · <%= document.file_name %></p>
          </div>
          <%= link_to t("ui.common.download"), download_property_property_document_path(@property, document), class: "button hollow secondary", download: document.file_name, data: { turbo: false } %>
        </div>
      <% end %>
    </div>
  <% else %>
    <p class="empty-copy"><%= t("ui.admin.properties.show.no_documents") %></p>
  <% end %>
</section>

<section class="admin-panel">
  <h2><%= t("ui.admin.properties.show.booking_history_title") %></h2>
  <% if @appointments.any? %>
    <div class="admin-list">
      <% @appointments.each do |appointment| %>
        <div class="admin-list__item">
          <div>
            <%= link_to appointment.customer_name, admin_appointment_path(appointment) %>
            <p><%= appointment.customer_email %> · <%= formatted_date_time(appointment.scheduled_at) %></p>
          </div>
          <span class="<%= appointment_status_badge_class(appointment.status) %>"><%= appointment.display_status %></span>
        </div>
      <% end %>
    </div>
  <% else %>
    <p class="empty-copy"><%= t("ui.admin.properties.show.no_bookings") %></p>
  <% end %>
</section>

<section class="admin-panel">
  <h2><%= t("ui.admin.properties.show.activity_title") %></h2>
  <% if @activity_logs.any? %>
    <ol class="timeline" data-testid="admin-property-activity-timeline">
      <% @activity_logs.each do |entry| %>
        <li>
          <strong><%= entry.action.to_s.tr("_", " ").humanize %></strong>
          <span><%= formatted_date_time(entry.occurred_at) %></span>
          <p><%= entry.message %></p>
        </li>
      <% end %>
    </ol>
  <% else %>
    <p class="empty-copy"><%= t("ui.admin.properties.show.no_activity") %></p>
  <% end %>
</section>
