<% title t("ui.admin.properties.index.title") %>

<section class="admin-section">
  <div class="section-heading">
    <div>
      <p class="section-heading__eyebrow"><%= t("ui.admin.properties.index.eyebrow") %></p>
      <h1><%= t("ui.admin.properties.index.title") %></h1>
    </div>
  </div>

  <div class="property-grid">
    <% @properties.each do |property| %>
      <article class="<%= property_card_classes(property) %>">
        <div class="property-card__body">
          <p class="property-card__eyebrow"><%= property.user.full_name.presence || property.user.email %></p>
          <h3><%= property.address_line_1 %></h3>
          <p><%= property.headline %></p>
          <p><%= format_price(property) %> · <%= format_bedrooms(property) %></p>
          <p><span class="<%= listing_state_badge_class(property.listing_state) %>"><%= translated_listing_state(property.listing_state) %></span></p>
        </div>
        <footer class="property-card__footer">
          <span><%= property.listing_completeness_percentage %>% complete · <%= t("ui.admin.properties.index.appointment_count", count: property.appointments.count) %></span>
          <%= link_to t("ui.admin.properties.index.open"), admin_property_path(property), class: "button primary hollow" %>
        </footer>
      </article>
    <% end %>
  </div>

  <%= paginate @properties %>
</section>
