<% title t("ui.admin.properties.index.title") %>

<section class="admin-section">
  <div class="section-heading">
    <div>
      <p class="section-heading__eyebrow"><%= t("ui.admin.properties.index.eyebrow") %></p>
      <h1><%= t("ui.admin.properties.index.title") %></h1>
      <p data-testid="admin-properties-count"><%= translate_count("ui.admin.properties.index.count_label", @properties.total_count) %></p>
    </div>
  </div>
</section>

<%= render "saved_filters", saved_searches: @saved_searches %>

<section class="admin-panel">
  <%= form_with url: admin_properties_path, method: :get, class: "admin-filter-form", local: true, data: { testid: "admin-properties-search" } do |f| %>
    <div>
      <%= f.label :q, t("ui.admin.properties.index.search.label") %>
      <%= f.search_field :q, value: @query, placeholder: t("ui.properties.filters.query_placeholder"), data: { testid: "admin-properties-search-input" } %>
    </div>
    <div>
      <%= f.label :listing_state, t("ui.admin.properties.index.search.status") %>
      <%= f.select :listing_state, options_for_select([[t("ui.admin.properties.index.search.all_statuses"), ""]] + Property::LISTING_STATES.map { |state| [translated_listing_state(state), state] }, @listing_state), {}, data: { testid: "admin-properties-status-select" } %>
    </div>
    <div class="admin-filter-form__actions">
      <%= f.button t("ui.admin.properties.index.search.submit"), type: :submit, class: "button primary", data: { testid: "admin-properties-search-submit" } %>
      <%= link_to t("ui.admin.properties.index.search.clear"), admin_properties_path, class: "button hollow secondary", data: { testid: "admin-properties-search-clear" } %>
    </div>
  <% end %>
</section>

<section class="admin-panel">
  <% if @properties.any? %>
    <div class="property-grid property-grid--catalogue">
      <% @properties.each do |property| %>
        <article class="<%= property_card_classes(property) %>" data-testid="admin-property-card-<%= property.id %>">
          <div class="property-card__media" data-testid="admin-property-media-<%= property.id %>">
            <%= small_image_for(property) %>
            <div class="property-card__badges">
              <span class="<%= property_sale_status_badge_class(property.sale_status) %>"><%= translated_sale_status(property.sale_status) %></span>
              <% unless property.listing_state == "published" %>
                <span class="<%= listing_state_badge_class(property.listing_state) %>"><%= translated_listing_state(property.listing_state) %></span>
              <% end %>
            </div>
          </div>
          <div class="property-card__body">
            <div class="property-card__header">
              <p class="property-card__eyebrow"><%= property.seller_display_name %></p>
              <h3><%= property.address_line_1 %></h3>
            </div>
            <p><%= property.headline %></p>
            <p><%= format_price(property) %> · <%= format_bedrooms(property) %></p>
          </div>
          <footer class="property-card__footer">
            <span><%= property.listing_completeness_percentage %>% complete · <%= translate_count("ui.admin.properties.index.appointment_count", property.appointments.size) %></span>
            <%= link_to t("ui.admin.properties.index.open"), admin_property_path(property), class: "button primary hollow" %>
          </footer>
        </article>
      <% end %>
    </div>

    <%= paginate @properties %>
  <% else %>
    <p class="empty-copy"><%= t("ui.admin.properties.index.no_results") %></p>
  <% end %>
</section>
