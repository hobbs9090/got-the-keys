<% return if saved_searches.blank? %>

<details class="admin-panel admin-saved-filters-disclosure" data-testid="admin-saved-filters-panel">
  <summary class="property-results-panel__head admin-saved-filters-disclosure__summary" data-testid="admin-saved-filters-toggle">
    <div>
      <p class="section-heading__eyebrow"><%= t("ui.admin.properties.index.saved_filters.eyebrow", default: "Saved search filters") %></p>
      <h2><%= t("ui.admin.properties.index.saved_filters.title", default: "Apply a saved filter") %></h2>
    </div>
    <span class="badge badge--neutral admin-saved-filters-disclosure__count" data-testid="admin-saved-filters-count">
      <%= translate_count("ui.admin.properties.index.saved_filters.count_label", saved_searches.size) %>
    </span>
  </summary>

  <div class="admin-saved-filters-disclosure__content">
    <div class="property-workspace__grid property-saved-searches-grid">
      <% saved_searches.each do |search| %>
        <% chip_labels = [] %>
        <% admin_params = search.admin_filter_params %>
        <% matches_count = 0 %>
        <% begin %>
          <% filter_params = search.filter_params %>
          <% chip_labels = property_filter_chip_labels(filter_params) %>
        <% rescue StandardError %>
          <%# Fall back to still rendering the card even if filter parsing breaks. %>
        <% end %>

        <% begin %>
          <% matches_count = search.matching_properties_count %>
        <% rescue StandardError %>
          <%# Fall back to 0 if the match-count query fails (bad legacy data, casting, etc). %>
          <% matches_count = 0 %>
        <% end %>
        <article class="site-card property-saved-search-card" data-testid="admin-saved-filter-card">
          <div class="property-saved-search-card__main">
            <div class="property-saved-search-card__chips">
              <% if chip_labels.any? %>
                <% chip_labels.each do |label| %>
                  <span class="badge badge--neutral"><%= label %></span>
                <% end %>
              <% else %>
                <span class="badge badge--neutral"><%= t("ui.properties.filters.all_listings") %></span>
              <% end %>
            </div>

            <p class="property-saved-search-card__meta">
              <span><%= search.user&.email %></span>
              <span><%= t("ui.properties.catalogue.saved_search.saved_at", time: formatted_date_time(search.created_at)) %></span>
            </p>
          </div>

          <div class="property-saved-search-card__actions">
            <%= link_to translate_count("ui.properties.catalogue.saved_search.view_matches", matches_count), admin_properties_path(admin_params), class: "button primary hollow", data: { testid: "admin-apply-saved-filter-#{search.id}" } %>
            <%= button_to t("ui.properties.catalogue.saved_search.remove"), saved_search_path(search), method: :delete, class: "button secondary hollow", data: { testid: "admin-remove-saved-filter-#{search.id}" } %>
          </div>
        </article>
      <% end %>
    </div>
  </div>
</details>
