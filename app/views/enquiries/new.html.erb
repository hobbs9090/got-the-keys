<% title t("ui.enquiries.title", address: @property.address_line_1) %>

<section class="property-layout">
  <article class="property-panel">
    <p class="section-heading__eyebrow"><%= t("ui.enquiries.eyebrow") %></p>
    <h1><%= t("ui.enquiries.heading", address: @property.address_line_1) %></h1>
    <p><%= t("ui.enquiries.body") %></p>

    <%= form_with model: [@property, @enquiry], data: { testid: "property-enquiry-form" } do |f| %>
      <%= render "shared/errors", object: @enquiry %>

      <div class="form-grid">
        <div>
          <%= f.label :customer_name, t("ui.common.full_name"), **form_label_options(@enquiry, :customer_name) %>
          <%= f.text_field :customer_name, required: true, autofocus: true, maxlength: 100, data: { testid: "enquiry-customer-name" }, **form_control_options(@enquiry, :customer_name) %>
          <%= field_error_messages(@enquiry, :customer_name) %>
        </div>
        <div>
          <%= f.label :customer_email, t("ui.common.email_address"), **form_label_options(@enquiry, :customer_email) %>
          <%= f.email_field :customer_email, data: { testid: "enquiry-customer-email" }, **form_control_options(@enquiry, :customer_email) %>
          <%= field_error_messages(@enquiry, :customer_email) %>
        </div>
        <div>
          <%= f.label :customer_phone, t("ui.common.phone_number"), **form_label_options(@enquiry, :customer_phone) %>
          <%= f.telephone_field :customer_phone, data: { testid: "enquiry-customer-phone" }, **form_control_options(@enquiry, :customer_phone) %>
          <%= field_error_messages(@enquiry, :customer_phone) %>
        </div>
        <div>
          <%= f.label :source_type, t("ui.enquiries.fields.source_type"), **form_label_options(@enquiry, :source_type) %>
          <%= f.select :source_type, Enquiry::SOURCE_TYPES.map { |source| [enquiry_source_label(source), source] }, {}, form_control_options(@enquiry, :source_type, data: { testid: "enquiry-source-type" }) %>
          <%= field_error_messages(@enquiry, :source_type) %>
        </div>
        <div class="form-grid__full">
          <%= f.label :message, t("ui.enquiries.fields.message"), **form_label_options(@enquiry, :message) %>
          <%= f.text_area :message, rows: 8, required: true, minlength: 20, maxlength: 3000, data: { testid: "enquiry-message" }, **form_control_options(@enquiry, :message) %>
          <%= field_error_messages(@enquiry, :message) %>
        </div>
      </div>

      <div class="form-actions">
        <%= f.submit t("ui.enquiries.submit"), class: "button primary", data: { testid: "submit-enquiry-button" } %>
        <%= link_to t("ui.appointments.new.back_to_property"), property_path(@property), class: "button hollow secondary" %>
      </div>
    <% end %>
  </article>

  <aside class="property-booking-panel">
    <h2><%= t("ui.enquiries.next_steps_title") %></h2>
    <ul class="detail-inline-list">
      <li><strong>1.</strong> <%= t("ui.enquiries.next_steps.one") %></li>
      <li><strong>2.</strong> <%= t("ui.enquiries.next_steps.two") %></li>
      <li><strong>3.</strong> <%= t("ui.enquiries.next_steps.three") %></li>
    </ul>
  </aside>
</section>
