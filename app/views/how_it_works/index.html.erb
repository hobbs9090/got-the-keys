<% title t('how_it_works.title') %>

<div class="row">
  <div id="numero1" class="large-3 columns">
    <div class="site-process panel">
      <h5><%= t('how_it_works.panel_title_1') %></h5>
      <p><%= t('how_it_works.panel_body_1') %></p>
    </div>
  </div>

  <div class="large-6 columns">
    <div class="site-process panel">
      <h5><%= t('how_it_works.panel_title_2') %></h5>
      <p>
        <%= t('how_it_works.panel_body_2_part_1') %>
        <button type="button" class="button clear tiny" data-toggle="land-registry-note"><%= t('how_it_works.land_registry') %></button>
        <%= t('how_it_works.panel_body_2_part_2') %>
      </p>
      <div class="dropdown-pane bottom" id="land-registry-note" data-dropdown data-auto-focus="true">
        <p><%= t('how_it_works.data_feeds') %></p>
      </div>
    </div>
  </div>

  <div class="large-3 columns">
    <div class="site-process panel">
      <h5><%= t('how_it_works.panel_title_3') %></h5>
      <p><%= t('how_it_works.panel_body_3') %></p>
    </div>
  </div>
</div>

<div class="row">
  <div class="large-6 columns">
    <div class="site-process panel">
      <h5><%= t('how_it_works.panel_title_4') %></h5>
      <p><%= t('how_it_works.panel_body_4') %></p>
    </div>
  </div>

  <div class="large-2 columns">
    <div id="numero2" class="site-card">
      <%= square_image %>
    </div>
  </div>

  <div class="large-4 columns">
    <div class="site-process panel">
      <h5><%= t('how_it_works.panel_title_5') %></h5>
      <p><%= t('how_it_works.panel_body_5') %></p>
    </div>
  </div>
</div>

<div class="row">
  <div class="large-4 columns">
    <div class="site-card"><%= world_image %></div>
  </div>
  <div class="large-4 columns">
    <div class="site-card"><%= world_image %></div>
  </div>
  <div class="large-4 columns">
    <div class="site-card"><%= world_image %></div>
  </div>
</div>

<div class="row">
  <div id="numero3" class="large-6 columns">
    <div class="site-process panel">
      <h5><%= t('how_it_works.panel_title_6') %></h5>
      <p><%= t('how_it_works.panel_body_6') %></p>
    </div>
  </div>

  <div id="numero4" class="large-3 columns">
    <div class="site-process panel">
      <h5><%= t('how_it_works.panel_title_7') %></h5>
      <p><%= t('how_it_works.panel_body_7') %></p>
    </div>
  </div>

  <div class="large-3 columns">
    <div class="site-process panel">
      <h5><%= t('how_it_works.panel_title_8') %></h5>
      <p><%= t('how_it_works.panel_body_8') %></p>
    </div>
  </div>
</div>

<div class="row">
  <div class="large-12 columns">
    <div class="site-tour panel">
      <ul class="accordion" data-accordion data-allow-all-closed="true">
        <li class="accordion-item is-active" data-accordion-item>
          <a href="#tour-step-account" class="accordion-title"><%= t('how_it_works.manage_account') %></a>
          <div class="accordion-content" data-tab-content id="tour-step-account">
            <p><%= t('how_it_works.manage_account_body') %></p>
          </div>
        </li>
        <li class="accordion-item" data-accordion-item>
          <a href="#tour-step-1" class="accordion-title"><%= t('how_it_works.numero1') %></a>
          <div class="accordion-content" data-tab-content id="tour-step-1">
            <p><%= t('how_it_works.numero1_body') %></p>
          </div>
        </li>
        <li class="accordion-item" data-accordion-item>
          <a href="#tour-step-2" class="accordion-title"><%= t('how_it_works.numero2') %></a>
          <div class="accordion-content" data-tab-content id="tour-step-2">
            <p><%= t('how_it_works.numero2_body') %></p>
          </div>
        </li>
        <li class="accordion-item" data-accordion-item>
          <a href="#tour-step-3" class="accordion-title"><%= t('how_it_works.numero3') %></a>
          <div class="accordion-content" data-tab-content id="tour-step-3">
            <p><%= t('how_it_works.numero3_body') %></p>
          </div>
        </li>
        <li class="accordion-item" data-accordion-item>
          <a href="#tour-step-4" class="accordion-title"><%= t('how_it_works.numero4') %></a>
          <div class="accordion-content" data-tab-content id="tour-step-4">
            <p><%= t('how_it_works.numero4_body') %></p>
          </div>
        </li>
      </ul>
    </div>
  </div>
</div>
