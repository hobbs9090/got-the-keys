<% title t("ui.offers.show.title", reference: @offer.public_reference) %>

<section class="page-hero">
  <div>
    <p class="page-hero__eyebrow"><%= t("ui.offers.show.eyebrow") %></p>
    <h1><%= @offer.public_reference %></h1>
    <p><%= t("ui.offers.show.hero_body") %></p>
  </div>

  <div class="page-hero__meta">
    <span class="<%= offer_status_badge_class(@offer.status) %>"><%= t("ui.offers.statuses.#{@offer.status}") %></span>
  </div>
</section>

<section class="property-layout">
  <%= render "shared/member_confirmation",
             testid: "offer-confirmation",
             summary_title: t("ui.offers.show.summary_title"),
             note_title: t("ui.common.customer_notes"),
             note: @offer.notes,
             rows: [
               [t("ui.common.property"), link_to(@offer.property.address_line_1, property_path(@offer.property))],
               [t("ui.offers.fields.amount"), number_to_currency(@offer.amount, unit: "£", precision: 0)],
               [t("ui.common.customer"), safe_join([@offer.buyer_name, tag.br, @offer.buyer_email, (@offer.buyer_phone.present? ? safe_join([tag.br, @offer.buyer_phone]) : nil)].compact)],
               [t("ui.offers.fields.chain_position"), @offer.chain_position]
             ] %>

  <aside class="property-booking-panel">
    <h2><%= t("ui.offers.show.manage_title") %></h2>
    <p><%= t("ui.offers.show.manage_body") %></p>
    <div class="form-actions">
      <%= link_to t("ui.offers.show.back_to_property"), property_path(@offer.property), class: "button primary expanded" %>
      <% if user_signed_in? && @offer.withdrawable? && @offer.buyer_email.to_s.casecmp?(current_user.email.to_s) %>
        <%= button_to t("ui.offers.show.withdraw_offer"),
                      withdraw_property_offer_path(@offer.property, @offer),
                      method: :patch,
                      class: "button alert hollow expanded",
                      data: { turbo: false, testid: "withdraw-offer-button" } %>
      <% end %>
    </div>

    <h2><%= t("ui.offers.show.timeline_title") %></h2>
    <ol class="timeline" data-testid="offer-timeline">
      <% @offer.timeline.each do |event| %>
        <li>
          <strong><%= t("ui.offers.statuses.#{event.event_type}", default: event.event_type.tr("_", " ").humanize) %></strong>
          <span><%= formatted_date_time(event.occurred_at) %></span>
          <p><%= event.message %></p>
        </li>
      <% end %>
    </ol>
  </aside>
</section>
