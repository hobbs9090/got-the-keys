<% title t("ui.offers.title", address: @property.address_line_1) %>

<section class="property-layout">
  <article class="property-panel">
    <p class="section-heading__eyebrow"><%= t("ui.offers.eyebrow") %></p>
    <h1><%= t("ui.offers.heading", address: @property.address_line_1) %></h1>
    <p><%= t("ui.offers.body") %></p>

    <%= form_with model: [@property, @offer], data: { testid: "property-offer-form" } do |f| %>
      <%= render "shared/errors", object: @offer %>

      <div class="form-grid">
        <div>
          <%= f.label :buyer_name, t("ui.common.full_name"), **form_label_options(@offer, :buyer_name) %>
          <%= f.text_field :buyer_name, required: true, maxlength: 100, data: { testid: "offer-buyer-name" }, **form_control_options(@offer, :buyer_name) %>
          <%= field_error_messages(@offer, :buyer_name) %>
        </div>
        <div>
          <%= f.label :buyer_email, t("ui.common.email_address"), **form_label_options(@offer, :buyer_email) %>
          <%= f.email_field :buyer_email, required: true, data: { testid: "offer-buyer-email" }, **form_control_options(@offer, :buyer_email) %>
          <%= field_error_messages(@offer, :buyer_email) %>
        </div>
        <div>
          <%= f.label :buyer_phone, t("ui.common.phone_number"), **form_label_options(@offer, :buyer_phone) %>
          <%= f.telephone_field :buyer_phone, required: true, data: { testid: "offer-buyer-phone" }, **form_control_options(@offer, :buyer_phone) %>
          <%= field_error_messages(@offer, :buyer_phone) %>
        </div>
        <div>
          <%= f.label :amount, t("ui.offers.fields.amount"), **form_label_options(@offer, :amount) %>
          <div class="offer-amount-stepper" data-testid="offer-amount-stepper">
            <%= f.text_field :amount,
                             value: (@offer.amount.present? ? number_with_delimiter(@offer.amount, delimiter: ",") : nil),
                             inputmode: "numeric",
                             maxlength: 15,
                             pattern: "[0-9,\\s]*",
                             required: true,
                             data: {
                               testid: "offer-amount",
                               offer_amount_input: true,
                               offer_amount_step: 1000,
                               validation_pattern_message: t("ui.validation.number")
                             },
                             **form_control_options(@offer, :amount) %>
            <div class="offer-amount-stepper__buttons">
              <button type="button"
                      class="offer-amount-stepper__button"
                      aria-label="Increase offer amount"
                      data-testid="offer-amount-increase"
                      data-offer-amount-increase>
                +
              </button>
              <button type="button"
                      class="offer-amount-stepper__button"
                      aria-label="Decrease offer amount"
                      data-testid="offer-amount-decrease"
                      data-offer-amount-decrease>
                -
              </button>
            </div>
          </div>
          <%= field_error_messages(@offer, :amount) %>
        </div>
        <div class="form-grid__full">
          <%= f.label :chain_position, t("ui.offers.fields.chain_position"), **form_label_options(@offer, :chain_position) %>
          <%= f.text_field :chain_position, placeholder: t("ui.offers.fields.chain_position_placeholder"), maxlength: 120, data: { testid: "offer-chain-position" }, **form_control_options(@offer, :chain_position) %>
          <%= field_error_messages(@offer, :chain_position) %>
        </div>
        <div class="form-grid__full">
          <%= f.label :notes, t("ui.offers.fields.notes"), **form_label_options(@offer, :notes) %>
          <%= f.text_area :notes, rows: 6, maxlength: 3000, data: { testid: "offer-notes" }, **form_control_options(@offer, :notes) %>
          <%= field_error_messages(@offer, :notes) %>
        </div>
      </div>

      <div class="form-actions">
        <%= f.submit t("ui.offers.submit"), class: "button primary", data: { testid: "submit-offer-button" } %>
        <%= link_to t("ui.appointments.new.back_to_property"), property_path(@property), class: "button hollow secondary" %>
      </div>
    <% end %>
  </article>

  <%= render "property_summary", property: @property %>
</section>
