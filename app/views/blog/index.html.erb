<% title t('blog.title') %>
<%
topic_tags = [
  t('blog.topic_1'),
  t('blog.topic_2'),
  t('blog.topic_3'),
  t('blog.topic_4'),
  t('blog.topic_5'),
  t('blog.topic_6')
]

editorial_points = [
  t('blog.editorial_point_1'),
  t('blog.editorial_point_2'),
  t('blog.editorial_point_3')
]
%>

<section class="page-hero blog-hero">
  <div class="blog-hero__content">
    <p class="page-hero__eyebrow"><%= t('blog.hero_eyebrow') %></p>
    <h1><%= t('blog.hero_title') %></h1>
    <p class="blog-hero__copy"><%= t('blog.hero_body') %></p>

    <div class="blog-hero__actions">
      <%= link_to t('blog.primary_cta'), properties_path, class: 'button primary large' %>
      <%= link_to t('blog.secondary_cta'), contact_us_path, class: 'button secondary hollow large' %>
    </div>
  </div>

  <aside class="site-card blog-hero__panel">
    <span class="badge badge--neutral"><%= t('blog.hero_panel_badge') %></span>
    <h2><%= t('blog.hero_panel_title') %></h2>
    <ul class="blog-hero__checklist no-bullet">
      <li><%= t('blog.hero_panel_point_1') %></li>
      <li><%= t('blog.hero_panel_point_2') %></li>
      <li><%= t('blog.hero_panel_point_3') %></li>
    </ul>
  </aside>
</section>

<section class="blog-layout">
  <div class="blog-main">
    <article class="site-card blog-feature" data-testid="blog-featured-post">
      <div class="blog-feature__media">
        <%= link_to blog_path(@featured_post[:slug]), class: "blog-feature__image-link", aria: { label: @featured_post[:title] } do %>
          <%= pixel_density_image_tag(@featured_post[:image][0], retina_source: @featured_post[:image][1], class: 'blog-feature__image', alt: @featured_post[:title]) %>
        <% end %>
      </div>

      <div class="blog-feature__body">
        <div class="blog-feature__meta">
          <span class="badge badge--accent"><%= @featured_post[:category] %></span>
          <span><%= @featured_post[:read_time] %></span>
        </div>

        <h2><%= link_to @featured_post[:title], blog_path(@featured_post[:slug]) %></h2>
        <p class="blog-feature__byline"><%= @featured_post[:byline] %></p>

        <div class="blog-feature__content">
          <div class="blog-feature__copy">
            <% @featured_post[:paragraphs].first(4).each do |paragraph| %>
              <p><%= paragraph %></p>
            <% end %>
            <p><%= link_to t('blog.read_full_post'), blog_path(@featured_post[:slug]), class: "blog-read-link" %></p>
          </div>

          <aside class="blog-feature__takeaways">
            <p class="section-heading__eyebrow"><%= t('blog.takeaways_eyebrow') %></p>
            <h3><%= t('blog.takeaways_title') %></h3>
            <ul class="blog-takeaway-list no-bullet">
              <% @featured_post[:takeaways].each do |item| %>
                <li><%= item %></li>
              <% end %>
            </ul>
          </aside>
        </div>
      </div>
    </article>

    <section class="blog-story-grid" aria-labelledby="blog-story-grid-title">
      <header class="blog-story-grid__header">
        <p class="section-heading__eyebrow"><%= t('blog.story_grid_eyebrow') %></p>
        <h2 id="blog-story-grid-title"><%= t('blog.story_grid_title') %></h2>
        <p class="blog-story-grid__intro"><%= t('blog.story_grid_body') %></p>
      </header>

      <div class="blog-story-grid__cards">
        <% @story_posts.each do |story| %>
          <article class="site-card blog-story-card" data-testid="blog-story-card">
            <div class="blog-story-card__media">
              <%= link_to blog_path(story[:slug]), aria: { label: story[:title] } do %>
                <%= pixel_density_image_tag(story[:image][0], retina_source: story[:image][1], class: 'blog-story-card__image', alt: story[:title]) %>
              <% end %>
            </div>

            <div class="blog-story-card__body">
              <div class="blog-story-card__meta">
                <span class="badge badge--neutral"><%= story[:category] %></span>
                <span><%= story[:read_time] %></span>
              </div>
              <h3><%= link_to story[:title], blog_path(story[:slug]) %></h3>
              <p><%= story[:excerpt] %></p>
              <p><%= link_to t('blog.read_full_post'), blog_path(story[:slug]), class: "blog-read-link" %></p>
            </div>
          </article>
        <% end %>
      </div>
    </section>
  </div>

  <aside class="blog-sidebar">
    <section class="site-card blog-sidebar__topics">
      <p class="section-heading__eyebrow"><%= t('blog.topics_eyebrow') %></p>
      <h2><%= t('blog.topics_title') %></h2>

      <div class="blog-topic-cloud">
        <% topic_tags.each do |topic| %>
          <span class="badge badge--neutral"><%= topic %></span>
        <% end %>
      </div>
    </section>

    <section class="site-card blog-sidebar__editorial">
      <p class="section-heading__eyebrow"><%= t('blog.editorial_eyebrow') %></p>
      <h2><%= t('blog.editorial_title') %></h2>
      <ol class="timeline">
        <% editorial_points.each do |point| %>
          <li><p><%= point %></p></li>
        <% end %>
      </ol>
    </section>

    <section class="site-card blog-sidebar__cta">
      <p class="section-heading__eyebrow"><%= t('blog.cta_eyebrow') %></p>
      <h2><%= t('blog.cta_title') %></h2>
      <p><%= t('blog.cta_body') %></p>

      <div class="blog-sidebar__actions">
        <%= link_to t('blog.cta_primary'), contact_us_path, class: 'button primary expanded' %>
        <%= link_to t('blog.cta_secondary'), properties_path, class: 'button secondary hollow expanded' %>
      </div>
    </section>
  </aside>
</section>
