<script type="text/javascript">

    function drawChart() {
        var data = google.visualization.arrayToDataTable([
            ['<%= t('statistics.language') %>', '<%= t('total') %>'],
            ['<%= t('for_sale.header') %>', <%= @total_for_sale %>],
            ['<%= t('for_rent.title') %>', <%= @total_for_rent %>]
        ]);

        var options = {
            title: '<%= t('charts.sale_vs_rent') %>',
            fontSize: 14,
            chartArea: {left: "10%", top: "20%", width: "80%", height: "70%"},
            backgroundColor: {strokeWidth: 2, stroke: '#D9D9D9'},
            colors: ['2BA6CB', '2E6AA0']
        };

        var chart = new google.visualization.PieChart(document.getElementById('rent_vs_sale_chart'));
        chart.draw(data, options);
    }

    $(document).ready(function () {
        drawChart();
    });

</script>

<div id="rent_vs_sale_chart" style="width: 428px; height: 260px;"></div>