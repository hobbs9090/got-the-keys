<% title t('statistics.title') %>

<section class="page-hero statistics-hero">
  <div>
    <p class="section-heading__eyebrow"><%= t('statistics.title') %></p>
    <h1><%= t('statistics.title') %></h1>
  </div>
</section>

<section class="statistics-grid statistics-grid--summary">
  <article class="statistics-panel">
    <%= render 'statistics/property_totals' %>
  </article>

  <article class="statistics-panel">
    <%= render 'statistics/property_sizes' %>
  </article>

  <article class="statistics-panel">
    <%= render 'statistics/website_statistics' %>
  </article>
</section>

<section class="statistics-grid">
  <article class="statistics-panel">
    <%= render 'statistics/english_vs_chinese_chart' %>
  </article>

  <article class="statistics-panel">
    <%= render 'statistics/property_size_chart' %>
  </article>

  <article class="statistics-panel">
    <%= render 'statistics/geographical_activity_chart' %>
  </article>

  <article class="statistics-panel">
    <%= render 'statistics/sale_vs_rent_chart' %>
  </article>
</section>
