<%= statistics_chart_tag(
      chart_id: "activity_chart",
      chart_type: "geo",
      data: [
        ["Country", "Popularity"],
        ["United Kingdom", @total_number_en_users],
        ["China", @total_number_zh_users]
      ],
      options: {
        title: t('charts.english_vs_chinese'),
        fontSize: 14,
        backgroundColor: { strokeWidth: 2, stroke: "#D9D9D9" }
      }
    ) %>
