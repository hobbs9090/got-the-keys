<%= statistics_chart_tag(
      chart_id: "property_size_chart",
      chart_type: "bar",
      data: [
        [t('bedrooms'), t('total')],
        [t('studio_flat'), @total_0_bedrooms],
        ["1 #{t('charts.bed')}", @total_1_bedrooms],
        ["2 #{t('charts.bed')}", @total_2_bedrooms],
        ["3 #{t('charts.bed')}", @total_3_bedrooms],
        ["4 #{t('charts.bed')}", @total_4_bedrooms],
        ["5 #{t('charts.bed')}", @total_5_bedrooms],
        ["6+ #{t('charts.bed')}", @total_6_plus_bedrooms]
      ],
      options: {
        title: t('statistics.property_sizes'),
        fontSize: 14,
        backgroundColor: { strokeWidth: 2, stroke: "#D9D9D9" },
        colors: ["#2BA6CB"]
      }
    ) %>
