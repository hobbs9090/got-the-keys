<script type="text/javascript">

    function drawChart() {
        var data = google.visualization.arrayToDataTable([
            ['<%= t('bedrooms') %>', '<%= t('total') %>'],
            ['<%= t('studio_flat') %>', <%= @total_0_bedrooms %>],
            ['1 <%= t('charts.bed') %>', <%= @total_1_bedrooms %>],
            ['2 <%= t('charts.bed') %>', <%= @total_2_bedrooms %>],
            ['3 <%= t('charts.bed') %>', <%= @total_3_bedrooms %>],
            ['4 <%= t('charts.bed') %>', <%= @total_4_bedrooms %>],
            ['5 <%= t('charts.bed') %>', <%= @total_5_bedrooms %>],
            ['6+ <%= t('charts.bed') %>', <%= @total_6_plus_bedrooms %>]
        ]);

        var options = {
            title: '<%= t('statistics.property_sizes') %>',
            fontSize: 14,
            backgroundColor: {strokeWidth: 2, stroke: '#D9D9D9'},
            colors: ['2ba6cb']
        };

        var chart = new google.visualization.BarChart(document.getElementById('property_size_chart'));
        chart.draw(data, options);
    }

    $(document).ready(function(){
        drawChart();
    });

</script>

<div id="property_size_chart" style="width: 428px; height: 260px;"></div>