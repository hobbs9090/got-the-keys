<% title t('search.title') %>

<section class="page-hero">
  <div>
    <p class="page-hero__eyebrow">Property search</p>
    <h1>Search listings and booking availability together</h1>
    <p>Find realistic happy paths, empty states, and pagination scenarios for QA automation practice.</p>
  </div>

  <div class="page-hero__meta">
    <strong><%= number_with_delimiter(@number_search_results.count, delimiter: ",") %></strong>
    <span>results</span>
  </div>
</section>

<section class="page-section">
  <%= render "searches/simple_search" %>
</section>

<section class="page-section">
  <%= paginate @properties %>
  <%= render "properties/property" %>
  <%= paginate @properties %>
</section>
