<% title t('search.title') %>

<section class="page-hero">
  <div>
    <p class="page-hero__eyebrow"><%= t("ui.search.eyebrow") %></p>
    <h1><%= t("ui.search.hero_title") %></h1>
    <p><%= t("ui.search.hero_body") %></p>
  </div>

  <div class="page-hero__meta">
    <strong><%= number_with_delimiter(@number_search_results.count, delimiter: ",") %></strong>
    <span><%= t("ui.search.results_count", count: @number_search_results.count) %></span>
  </div>
</section>

<section class="page-section">
  <%= render "searches/simple_search" %>
</section>

<section class="page-section">
  <%= paginate @properties %>
  <%= render "properties/property" %>
  <%= paginate @properties %>
</section>
