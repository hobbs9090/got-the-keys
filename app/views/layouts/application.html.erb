<!DOCTYPE html>
<html lang="<%= I18n.locale %>" data-theme-preference="system">
  <head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= content_for?(:title) ? yield(:title) : t('gotthekeys.gotthekeys') %></title>
    <%= favicon_link_tag "favicon-house.svg", rel: "icon", type: "image/svg+xml", sizes: "any" %>
    <%= favicon_link_tag "/favicon.png", rel: "icon", type: "image/png", sizes: "32x32" %>
    <%= favicon_link_tag "/favicon.ico", rel: "shortcut icon", type: "image/x-icon" %>
    <%= favicon_link_tag "/apple-touch-icon.png", rel: "apple-touch-icon", type: "image/png", sizes: "180x180" %>
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>
    <%= tag.meta name: "turbo-cache-control", content: "no-preview" %>
    <%= javascript_tag theme_preference_bootstrap_script, nonce: true %>
    <%= stylesheet_link_tag "public", media: "all", "data-turbo-track" => "reload" %>
    <%= javascript_include_tag "public", "data-turbo-track" => "reload", defer: true %>
  </head>

  <body class="site-shell <%= controller_path.tr('/', '-') %><%= " welcome--from-admin" if homepage_from_admin_referrer? %>"
        data-native-validation-messages="<%= json_escape(native_validation_messages.to_json) %>">
    <a class="skip-link" href="#main-content"><%= t("ui.common.skip_to_content", default: "Skip to main content") %></a>
    <div class="site-background" aria-hidden="true"></div>
    <%= render "layouts/header" %>
    <%= render "layouts/flashes" %>

    <main class="site-main" id="main-content" tabindex="-1">
      <%= yield %>
    </main>

    <%= render "layouts/footer" %>
    <%= render "layouts/cookie_consent" %>
  </body>
</html>
