<!DOCTYPE html>
<html lang="<%= I18n.locale %>">
  <head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= content_for?(:title) ? yield(:title) : t("ui.admin.layout.title", app_name: t("gotthekeys.gotthekeys")) %></title>
    <%= favicon_link_tag "favicon-house.svg", rel: "icon", type: "image/svg+xml", sizes: "any" %>
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>
    <%= stylesheet_link_tag "application", media: "all", "data-turbo-track" => "reload" %>
    <%= javascript_include_tag "application", "data-turbo-track" => "reload", defer: true %>
  </head>

  <body class="admin-shell">
    <div class="admin-layout">
      <aside class="admin-sidebar" data-testid="admin-sidebar">
        <div class="admin-sidebar__brand">
          <%= link_to root_path, class: "admin-sidebar__brand-link" do %>
            <span class="admin-sidebar__eyebrow"><%= t("ui.admin.layout.sidebar_eyebrow") %></span>
            <strong><%= render "layouts/gotthekeys", class_name: "marketing-wordmark--admin", variant: :dark, width: 190 %></strong>
          <% end %>
        </div>

        <%= render "layouts/admin_navigation" %>
      </aside>

      <div class="admin-content-wrap">
        <header class="admin-topbar">
          <div>
            <p class="admin-topbar__label"><%= t("ui.admin.layout.active_demo_scenario") %></p>
            <strong data-testid="active-demo-scenario"><%= translated_demo_scenario_key(active_demo_scenario_key) %></strong>
          </div>

          <div class="admin-topbar__actions">
            <span class="admin-topbar__user" title="<%= current_admin.email %>"><%= current_admin.email %></span>
            <%= link_to t("ui.admin.layout.view_site"), root_path, class: "button secondary hollow admin-topbar__action" %>
            <%= link_to t("ui.site_header.sign_out"), destroy_admin_session_path, class: "button alert hollow admin-topbar__action", data: { turbo_method: :delete } %>
          </div>
        </header>

        <%= render "layouts/flashes" %>

        <main class="admin-main">
          <%= yield %>
        </main>
      </div>
    </div>

    <%= render "layouts/cookie_consent" %>
  </body>
</html>
