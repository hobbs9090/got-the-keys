<!DOCTYPE html>
<html lang="<%= I18n.locale %>" data-theme-preference="system">
  <head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= page_title %></title>
    <%= tag.meta name: "description", content: page_meta_description %>
    <%= tag.meta name: "robots", content: page_meta_robots %>
    <%= tag.link rel: "canonical", href: page_canonical_url if page_canonical_url.present? %>
    <%= favicon_link_tag "favicon-house.svg", rel: "icon", type: "image/svg+xml", sizes: "any" %>
    <%= favicon_link_tag "/favicon.png", rel: "icon", type: "image/png", sizes: "32x32" %>
    <%= favicon_link_tag "/favicon.ico", rel: "shortcut icon", type: "image/x-icon" %>
    <%= favicon_link_tag "/apple-touch-icon.png", rel: "apple-touch-icon", type: "image/png", sizes: "180x180" %>
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>
    <%= tag.link rel: "preconnect", href: "https://fonts.googleapis.com" %>
    <%= tag.link rel: "preconnect", href: "https://fonts.gstatic.com", crossorigin: true %>
    <%= async_external_stylesheet_tag "https://fonts.googleapis.com/css2?family=Fraunces:opsz,wght@9..144,600;9..144,700&family=Manrope:wght@400;500;600;700;800&display=swap" %>
    <%= javascript_tag theme_preference_bootstrap_script, nonce: true %>
    <%= stylesheet_link_tag "admin", media: "all", "data-turbo-track" => "reload" %>
    <%= javascript_include_tag "admin", "data-turbo-track" => "reload", defer: true %>
  </head>

  <body class="admin-shell"
        data-native-validation-messages="<%= json_escape(native_validation_messages.to_json) %>">
    <div class="admin-layout">
      <aside class="admin-sidebar" data-testid="admin-sidebar">
        <div class="admin-sidebar__brand">
          <%= link_to root_path, class: "admin-sidebar__brand-link" do %>
            <span class="admin-sidebar__eyebrow"><%= t("ui.site_header.eyebrow") %></span>
            <strong><%= render "layouts/gotthekeys", class_name: "marketing-wordmark--header", variant: :dark, width: 228 %></strong>
          <% end %>
        </div>

        <%= render "layouts/admin_navigation" %>
      </aside>

      <div class="admin-content-wrap">
        <div class="admin-topbar-wrap">
          <header class="admin-topbar">
            <div class="admin-topbar__main">
              <% account_summary = header_account_summary %>
              <div class="site-header__actions admin-topbar__session">
                <div class="site-header__actions-top">
                  <div class="site-header__account" data-testid="admin-account-summary">
                    <div class="site-header__account-heading">
                      <span class="site-header__account-eyebrow"><%= account_summary[:eyebrow] %></span>
                      <strong class="site-header__account-name"><%= account_summary[:name] %></strong>
                    </div>
                    <span class="site-header__account-detail" title="<%= account_summary[:detail] %>"><%= account_summary[:detail] %></span>
                  </div>

                  <%= render "layouts/language_dropdown" %>
                  <%= render "layouts/theme_toggle", control_id: "admin_theme_preference" %>
                </div>

                <div class="site-header__actions-row">
                  <div class="site-header__button-group admin-topbar__actions">
                    <%= link_to t("ui.admin.layout.view_site"), root_path, class: "button primary admin-topbar__action" %>
                    <%= link_to t("ui.site_header.sign_out"), destroy_admin_session_path, class: "button alert hollow admin-topbar__action", data: { turbo_method: :delete } %>
                  </div>
                </div>
              </div>
            </div>
          </header>
        </div>

        <%= render "layouts/flashes" %>

        <div class="admin-main" id="admin-main-content" tabindex="-1">
          <%= yield %>
        </div>
      </div>
    </div>

    <%= render "layouts/cookie_consent" %>
  </body>
</html>
