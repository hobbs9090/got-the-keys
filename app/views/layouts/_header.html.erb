<header class="site-header" data-testid="site-header">
  <div class="site-header__inner">
    <%= link_to root_path, class: "site-brand", data: { testid: "home-link" } do %>
      <span class="site-brand__eyebrow">Property and Booking Platform</span>
      <span class="site-brand__wordmark"><%= render "layouts/gotthekeys", class_name: "marketing-wordmark--header", width: 228 %></span>
    <% end %>

    <nav class="site-nav" aria-label="Primary" data-testid="site-nav">
      <%= link_to t('welcome.title'), root_path, class: ("is-active" if current_page?(root_path)) %>
      <%= link_to t('properties.title'), properties_path, class: ("is-active" if controller_name == "properties") %>
      <%= link_to t('for_sale.title'), for_sale_index_path, class: ("is-active" if controller_name == "for_sale") %>
      <%= link_to t('for_rent.title'), for_rent_index_path, class: ("is-active" if controller_name == "for_rent") %>
      <%= link_to t('search.title'), searches_path, class: ("is-active" if controller_name == "searches") %>
    </nav>

    <div class="site-header__actions">
      <div class="site-header__languages">
        <%= link_to "EN", new_language_path(language: "en"), class: ("is-active" unless chinese_locale?) %>
        <%= link_to "中文", new_language_path(language: "zh"), class: ("is-active" if chinese_locale?) %>
      </div>

      <% if admin_signed_in? %>
        <%= link_to "Bookings", admin_bookings_path, class: "button primary", data: { testid: "admin-bookings-entry-link" } %>
        <%= link_to "Sign out", destroy_admin_session_path, class: "button alert hollow", data: { turbo_method: :delete } %>
      <% elsif user_signed_in? %>
        <%= link_to "Add property", new_property_path, class: "button primary", data: { testid: "add-property-link" } %>
        <%= link_to "Profile", edit_user_registration_path, class: "button hollow" %>
        <%= link_to "Sign out", destroy_user_session_path, class: "button alert hollow", data: { turbo_method: :delete } %>
      <% else %>
        <%= link_to "Register", new_user_registration_path, class: "button secondary hollow", id: "register" %>
        <%= link_to "Sign in", new_user_session_path, class: "button primary", id: "sign_in" %>
      <% end %>
    </div>
  </div>
</header>
