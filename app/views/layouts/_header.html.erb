<header class="site-header" data-testid="site-header">
  <div class="site-header__inner">
    <%= link_to root_path, class: "site-brand", data: { testid: "home-link" } do %>
      <span class="site-brand__eyebrow"><%= t("ui.site_header.eyebrow") %></span>
      <span class="site-brand__wordmark"><%= render "layouts/gotthekeys", class_name: "marketing-wordmark--header", width: 228 %></span>
    <% end %>

    <nav class="site-nav" aria-label="Primary" data-testid="site-nav">
      <%= link_to t('for_sale.title'), for_sale_index_path, class: ("is-active" if controller_name == "for_sale") %>
      <%= link_to t('for_rent.title'), for_rent_index_path, class: ("is-active" if controller_name == "for_rent") %>
      <%= link_to t('search.title'), searches_path, class: ("is-active" if controller_name == "searches") %>
    </nav>

    <div class="site-header__actions">
      <div class="language-dropdown" data-testid="language-dropdown">
        <%= form_with url: new_language_path, method: :get, local: true, data: { turbo: false }, html: { class: "language-dropdown__form" } do %>
          <%= label_tag "site-header-language", language_switcher_label, class: "language-dropdown__label" %>
          <div class="language-dropdown__field">
            <%= select_tag :language,
                           options_for_select(language_options, I18n.locale.to_s),
                           id: "site-header-language",
                           class: "language-dropdown__select",
                           onchange: "this.form.submit()" %>
          </div>
        <% end %>
      </div>

      <% if admin_signed_in? %>
        <%= link_to t("ui.site_header.admin_bookings"), admin_bookings_path, class: "button primary", data: { testid: "admin-bookings-entry-link" } %>
        <%= link_to t("ui.site_header.sign_out"), destroy_admin_session_path, class: "button alert hollow", data: { turbo_method: :delete } %>
      <% elsif user_signed_in? %>
        <%= link_to t("ui.site_header.add_property"), new_property_path, class: "button primary", data: { testid: "add-property-link" } %>
        <%= link_to t("ui.site_header.profile"), edit_user_registration_path, class: "button hollow" %>
        <%= link_to t("ui.site_header.sign_out"), destroy_user_session_path, class: "button alert hollow", data: { turbo_method: :delete } %>
      <% else %>
        <%= link_to t("ui.site_header.register"), new_user_registration_path, class: "button secondary hollow", id: "register" %>
        <%= link_to t("ui.site_header.sign_in"), new_user_session_path, class: "button primary", id: "sign_in" %>
      <% end %>
    </div>
  </div>
</header>
