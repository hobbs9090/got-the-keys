<% control_id = local_assigns.fetch(:control_id, "theme_preference") %>
<% toggle_label = t("ui.theme_toggle.label", default: "Theme") %>
<% default_label = theme_preference_options.find { |_label, value| value == "system" }&.first || theme_preference_options.first&.first || "System" %>

<div class="theme-toggle" data-theme-toggle data-theme-toggle-label="<%= toggle_label %>" data-testid="theme-toggle">
  <label class="show-for-sr" for="<%= control_id %>"><%= toggle_label %></label>

  <details class="theme-toggle__details">
    <summary class="theme-toggle__summary" data-theme-preference-summary aria-label="<%= "#{toggle_label}: #{default_label}" %>">
      <span class="theme-toggle__summary-value">
        <span class="theme-toggle__summary-code" data-theme-preference-label><%= default_label %></span>
      </span>
    </summary>

    <div class="theme-toggle__menu" aria-label="<%= toggle_label %>">
      <% theme_preference_options.each do |label, value| %>
        <button type="button"
                class="theme-toggle__option<%= " is-active" if value == "system" %>"
                data-testid="theme-option-<%= value %>"
                data-theme-preference-option="<%= value %>"
                aria-pressed="<%= value == "system" %>">
          <span><%= label %></span>
        </button>
      <% end %>
    </div>
  </details>

  <%= select_tag control_id,
                 options_for_select(theme_preference_options, "system"),
                 class: "show-for-sr theme-toggle__native",
                 data: { theme_preference_select: true },
                 aria: { label: toggle_label } %>
</div>
