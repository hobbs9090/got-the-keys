<%= render :partial => "devise/shared/sign_in_title" %>

<div class="row">

  <div class="large-9 columns centered">

    <%= render :partial => "devise/shared/sign_in_message" %>

    <%= form_for(resource, :as => resource_name, :url => session_path(resource_name), :html => { data: { turbo: false } }) do |f| %>
        <fieldset>
          <ol>
            <li class="required">
              <%= f.label :email %>
              <%= f.email_field :email, autofocus: true, required: true, autocomplete: "email" %>
            </li>
            <li class="required">
              <%= f.label :password %>
              <%= f.password_field :password, required: true, autocomplete: "current-password" %>
            </li>
            <% if devise_mapping.rememberable? -%>
                <div><%= f.check_box :remember_me %> <%= f.label :remember_me %></div>
            <% end -%>
          </ol>
          <p>
            <%= f.submit t('devise.views.sessions.new.submit') %>
          </p>
        </fieldset>
    <% end %>

    <%= render :partial => "devise/shared/links" %>

  </div>

  <%= render "layouts/sidebar" %>

</div>
