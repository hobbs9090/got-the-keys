<% admin_sign_in = request.fullpath.match?(/^\/admins/) %>
<% session_copy_key = admin_sign_in ? "devise.views.sessions.admin" : "devise.views.sessions.new" %>
<% session_copy = ->(key) { t("#{session_copy_key}.#{key}", default: t("devise.views.sessions.new.#{key}")) } %>
<% session_title = admin_sign_in ? t('devise.views.links.sign_in_as_admin') : session_copy.call("title") %>
<% admin_two_factor_challenge = admin_sign_in && @admin_two_factor_challenge_token.present? %>
<%
  admin_otp_prompt =
    if admin_two_factor_challenge
      true
    elsif admin_sign_in && BookingConfiguration.current.admin_two_factor_optional? && resource.email.present?
      Admin.find_for_database_authentication(email: resource.email.to_s)&.two_factor_enrolled?
    else
      false
    end
%>
<% title session_title %>

<section class="auth-shell auth-shell--signin">
  <aside class="site-card auth-panel auth-panel--signin">
    <p class="section-heading__eyebrow"><%= session_copy.call("hero_badge") %></p>
    <h1><%= session_copy.call("hero_title") %></h1>
    <p class="auth-panel__lead"><%= session_copy.call("hero_intro") %></p>
    <p><%= session_copy.call("paragraph_1") %></p>

    <div class="auth-panel__callout">
      <p><%= session_copy.call("paragraph_2") %></p>
      <% if devise_mapping.registerable? %>
        <%= link_to t('devise.views.sessions.new.create_account'), new_registration_path(resource_name, return_to: pending_return_to_path, save_property_id: pending_save_property_id), class: "button secondary hollow" %>
      <% else %>
        <%= link_to t('devise.views.links.sign_in_as_member'), new_user_session_path, class: "button secondary hollow" %>
      <% end %>
    </div>
  </aside>

  <section class="site-card auth-form-card auth-form-card--signin">
    <div class="auth-form-card__header">
      <div>
        <p class="section-heading__eyebrow"><%= session_copy.call("form_badge") %></p>
        <h2 class="auth-form-card__title"><%= session_title %></h2>
      </div>
      <% if admin_two_factor_challenge %>
        <p class="auth-form-card__intro"><%= t("devise.views.sessions.new.admin_two_factor_challenge_hint", default: "Password verified. Enter your code to continue.") %></p>
      <% else %>
        <p class="auth-form-card__intro"><%= session_copy.call("form_intro") %></p>
      <% end %>
    </div>

    <%= form_for(resource, as: resource_name, url: session_path(resource_name), html: { class: "stacked-form auth-form", data: { turbo: false, testid: "sign-in-form" } }) do |f| %>
      <%= hidden_field_tag :return_to, pending_return_to_path if pending_return_to_path.present? %>
      <%= hidden_field_tag :save_property_id, pending_save_property_id if pending_save_property_id.present? %>
      <%= hidden_field_tag "#{resource_name}[two_factor_challenge_token]", @admin_two_factor_challenge_token if admin_two_factor_challenge %>

      <% if resource.errors[:base].any? %>
        <div class="auth-form__hint" role="alert" aria-live="polite">
          <%= resource.errors[:base].to_sentence %>
        </div>
      <% end %>

      <div class="auth-form__stack">
        <div>
          <%= f.label :email, nil, **form_label_options(resource, :email) %>
          <% if admin_two_factor_challenge %>
            <%= f.email_field :email, readonly: true, required: true, autocomplete: "email", data: { testid: "sign-in-email" }, **form_control_options(resource, :email) %>
          <% else %>
            <%= f.email_field :email, autofocus: true, required: true, autocomplete: "email", data: { testid: "sign-in-email" }, **form_control_options(resource, :email) %>
          <% end %>
          <%= field_error_messages(resource, :email) %>
        </div>

        <% unless admin_two_factor_challenge %>
          <div>
            <%= f.label :password, nil, **form_label_options(resource, :password) %>
            <%= f.password_field :password, required: true, autocomplete: "current-password", data: { testid: "sign-in-password" }, **form_control_options(resource, :password) %>
            <%= field_error_messages(resource, :password) %>
          </div>
        <% end %>

        <% if admin_otp_prompt %>
          <div>
            <%= f.label :otp_attempt, t("devise.views.sessions.new.otp_attempt", default: "Verification code or backup code"), **form_label_options(resource, :otp_attempt) %>
            <%= f.text_field :otp_attempt, autocomplete: "one-time-code", autocapitalize: "off", spellcheck: false, maxlength: 64, data: { testid: "sign-in-otp-attempt" }, **form_control_options(resource, :otp_attempt) %>
            <p class="help-text auth-form__hint"><%= t("devise.views.sessions.new.otp_attempt_hint", default: "Enter an authenticator code or one of your backup codes.") %></p>
            <%= field_error_messages(resource, :otp_attempt) %>
          </div>
        <% end %>

        <% if devise_mapping.rememberable? %>
          <div class="auth-form__checkbox auth-form__checkbox--compact">
            <%= f.check_box :remember_me %>
            <div>
              <%= f.label :remember_me, t('devise.views.sessions.new.remember_me'), class: "checkbox-label" %>
            </div>
          </div>
        <% end %>
      </div>

      <div class="form-actions auth-form__actions">
        <p class="auth-form__note"><%= session_copy.call("support_note") %></p>
        <%= f.submit t('devise.views.sessions.new.submit'), class: "button primary large auth-form__submit", data: { testid: "sign-in-submit" } %>
      </div>
    <% end %>

    <div class="auth-form-card__links">
      <%= render partial: "devise/shared/links" %>
    </div>
  </section>
</section>
