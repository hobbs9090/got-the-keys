<% title t('devise.views.passwords.edit.title') %>

<section class="auth-shell auth-shell--compact">
  <aside class="site-card auth-panel auth-panel--support">
    <%= render "layouts/gotthekeys", class_name: "marketing-wordmark--hero", variant: :theme_aware, width: 240 %>
    <p class="section-heading__eyebrow"><%= t('devise.views.passwords.edit.hero_badge') %></p>
    <h1><%= t('devise.views.passwords.edit.hero_title') %></h1>
    <p class="auth-panel__lead"><%= t('devise.views.passwords.edit.hero_intro') %></p>
    <p><%= t('devise.views.passwords.edit.paragraph_1') %></p>

    <div class="auth-panel__callout">
      <p><%= t('devise.views.passwords.edit.paragraph_2') %></p>
      <%= link_to t('devise.views.passwords.edit.request_new_link'), new_password_path(resource_name), class: "button secondary hollow" %>
    </div>
  </aside>

  <section class="site-card auth-form-card auth-form-card--compact">
    <div class="auth-form-card__header">
      <div>
        <p class="section-heading__eyebrow"><%= t('devise.views.passwords.edit.form_badge') %></p>
        <h2 class="auth-form-card__title"><%= t('devise.views.passwords.edit.title') %></h2>
      </div>
      <p class="auth-form-card__intro"><%= t('devise.views.passwords.edit.form_intro') %></p>
    </div>

    <%= form_for(resource, as: resource_name, url: password_path(resource_name), html: { method: :put, class: "stacked-form auth-form", data: { turbo: false } }) do |f| %>
      <%= devise_error_messages! %>
      <%= f.hidden_field :reset_password_token %>

      <div class="auth-form__stack">
        <div>
          <%= f.label :password, t('devise.views.passwords.edit.new_password'), **form_label_options(resource, :password) %>
          <%= f.password_field :password, autofocus: true, required: true, minlength: 6, autocomplete: "new-password", **form_control_options(resource, :password) %>
          <%= field_error_messages(resource, :password) %>
        </div>

        <div>
          <%= f.label :password_confirmation, t('devise.views.passwords.edit.confirm_new_password'), **form_label_options(resource, :password_confirmation) %>
          <%= f.password_field :password_confirmation, required: true, minlength: 6, autocomplete: "new-password", **form_control_options(resource, :password_confirmation) %>
          <%= field_error_messages(resource, :password_confirmation) %>
        </div>
      </div>

      <div class="form-actions auth-form__actions">
        <p class="auth-form__note"><%= t('devise.views.passwords.edit.support_note') %></p>
        <%= f.submit t('devise.views.passwords.edit.submit'), class: "button primary large auth-form__submit" %>
      </div>
    <% end %>

    <div class="auth-form-card__links">
      <%= render partial: "devise/shared/links" %>
    </div>
  </section>
</section>
