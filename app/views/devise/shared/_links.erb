<ul class="no-bullet">

  <%- if controller_name != 'sessions' %>
      <li>
        <%= link_to t('devise.views.links.sign_in'), new_session_path(resource_name, pending_saved_property_params) %>
      </li>
  <% end -%>

  <%- if devise_mapping.registerable? && controller_name != 'registrations' %>
      <li>
        <%= link_to t('devise.views.links.register'), new_registration_path(resource_name, pending_saved_property_params) %>
      </li>
  <% end -%>

  <%- if devise_mapping.recoverable? && controller_name != 'passwords' %>
      <li>
        <%= link_to t('devise.views.links.forget_pass'), new_password_path(resource_name, pending_saved_property_params) %>
      </li>
  <% end -%>

  <%- if devise_mapping.confirmable? && controller_name != 'confirmations' %>
      <li>
        <%= link_to t('devise.views.links.resend_confirmation'), new_confirmation_path(resource_name) %>
      </li>
  <% end -%>

  <%- if devise_mapping.lockable? && resource_class.unlock_strategy_enabled?(:email) && controller_name != 'unlocks' %>
      <li>
        <%= link_to t('devise.views.links.resend_unlock'), new_unlock_path(resource_name) %>
      </li>
  <% end -%>

  <%- if devise_mapping.omniauthable? %>
      <li>
        <%- resource_class.omniauth_providers.each do |provider| %>
            <%= link_to "Sign in with #{provider.to_s.titleize}", omniauth_authorize_path(resource_name, provider) %>
        <% end -%>
  <% end -%>

  <%- if request.fullpath.match(/^\/users\/sign_in/) -%>
      <li>
        <%= link_to t('devise.views.links.sign_in_as_admin?'), new_admin_session_path %>
      </li>
  <% end -%>

  <%- if request.fullpath.match(/^\/admins/) -%>
      <li>
        <%= link_to t('devise.views.links.sign_in_as_member'), new_user_session_path %>
      </li>
  <% end -%>

</ul>
