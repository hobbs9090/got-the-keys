<% title t('devise.views.registrations.new.title') %>

<section class="auth-shell auth-shell--registration">
  <aside class="site-card auth-panel auth-panel--registration">
    <p class="section-heading__eyebrow"><%= t('devise.views.registrations.new.title') %></p>
    <h1><%= t('devise.views.registrations.new.hero_title') %></h1>
    <p class="auth-panel__lead"><%= t('devise.views.registrations.new.paragraph_1') %></p>
    <p><%= t('devise.views.registrations.new.paragraph_2') %></p>

    <div class="auth-panel__callout">
      <p><%= t('devise.views.registrations.new.paragraph_3') %></p>
      <%= button_tag t('devise.views.registrations.new.read_more'), type: 'button', class: 'button secondary hollow auth-panel__more', data: { modal_trigger: 'registration-explainer' } %>
    </div>
  </aside>

  <section class="site-card auth-form-card auth-form-card--registration">
    <div class="auth-form-card__header">
      <div>
        <p class="section-heading__eyebrow"><%= t('devise.views.registrations.new.setup_badge') %></p>
        <h2 class="auth-form-card__title"><%= t('devise.views.registrations.new.title') %></h2>
      </div>
      <p class="auth-form-card__intro"><%= t('devise.views.registrations.new.form_intro') %></p>
    </div>

    <%= form_for(resource, as: resource_name, url: registration_path(resource_name), html: { class: "stacked-form auth-form", data: { turbo: false } }) do |f| %>
      <%= hidden_field_tag :return_to, pending_return_to_path if pending_return_to_path.present? %>
      <%= hidden_field_tag :save_property_id, pending_save_property_id if pending_save_property_id.present? %>

      <%= devise_error_messages! %>

      <div class="form-grid auth-form__grid">
        <div>
          <%= f.label :first_name, nil, **form_label_options(resource, :first_name) %>
          <%= f.text_field :first_name, autofocus: true, required: true, maxlength: 50, autocomplete: "given-name", **form_control_options(resource, :first_name) %>
          <%= field_error_messages(resource, :first_name) %>
        </div>
        <div>
          <%= f.label :last_name, nil, **form_label_options(resource, :last_name) %>
          <%= f.text_field :last_name, required: true, maxlength: 50, autocomplete: "family-name", **form_control_options(resource, :last_name) %>
          <%= field_error_messages(resource, :last_name) %>
        </div>
        <div class="form-grid__full auth-form__stack auth-form__contact-fields">
          <div>
            <%= f.label :mobile_number, nil, **form_label_options(resource, :mobile_number) %>
            <%= f.text_field :mobile_number, required: true, maxlength: 20, autocomplete: "tel", **form_control_options(resource, :mobile_number) %>
            <%= field_error_messages(resource, :mobile_number) %>
          </div>
          <div>
            <%= f.label :email, nil, **form_label_options(resource, :email) %>
            <%= f.email_field :email, required: true, autocomplete: "email", **form_control_options(resource, :email) %>
            <%= field_error_messages(resource, :email) %>
          </div>
        </div>
        <div>
          <%= f.label :language, nil, **form_label_options(resource, :language) %>
          <%= f.select :language,
                       options_for_select(language_options, resource.language),
                       { prompt: t('properties.pick_one') },
                       form_control_options(resource, :language) %>
          <%= field_error_messages(resource, :language) %>
        </div>
        <div class="form-grid__full auth-form__stack auth-form__password-fields">
          <div>
            <%= f.label :password, nil, **form_label_options(resource, :password) %>
            <%= f.password_field :password, required: true, minlength: 6, autocomplete: "new-password", **form_control_options(resource, :password) %>
            <%= field_error_messages(resource, :password) %>
          </div>
          <div>
            <%= f.label :password_confirmation, nil, **form_label_options(resource, :password_confirmation) %>
            <%= f.password_field :password_confirmation, required: true, minlength: 6, autocomplete: "new-password", **form_control_options(resource, :password_confirmation) %>
            <%= field_error_messages(resource, :password_confirmation) %>
          </div>
        </div>
        <div class="form-grid__full auth-form__checkbox">
          <%= f.check_box :terms_of_service %>
          <div>
            <%= f.label :terms_of_service, nil, class: "checkbox-label" %>
            <%= field_error_messages(resource, :terms_of_service) %>
          </div>
        </div>
      </div>

      <div class="form-actions auth-form__actions">
        <p class="auth-form__note"><%= t('devise.views.registrations.new.paragraph_4') %></p>
        <%= f.submit t('devise.views.links.register'), class: "button primary large auth-form__submit" %>
      </div>
    <% end %>

    <div class="auth-form-card__links">
      <%= render partial: "devise/shared/links" %>
    </div>
  </section>
</section>

<%= render "shared/modal", id: "registration-explainer", title: t('devise.views.registrations.new.why_so_much'), size: "small" do %>
  <p class="lead"><%= t('devise.views.registrations.new.paragraph_1') %></p>
  <p><%= t('devise.views.registrations.new.paragraph_2') %></p>
  <p><%= t('devise.views.registrations.new.paragraph_3') %></p>
  <p><%= t('devise.views.registrations.new.paragraph_4') %></p>
<% end %>
