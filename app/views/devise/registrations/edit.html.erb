<% title t('devise.views.registrations.edit.title') %>

<div class="row">

  <div class="large-9 columns">

    <h4><%= t('devise.views.registrations.edit.title') %> <%= current_user.email %></h4>

    <%= form_for(resource, :as => resource_name, :url => registration_path(resource_name), :html => { :method => :put, data: { turbo: false } }) do |f| %>
        <%= devise_error_messages! %>
        <fieldset>
          <ol>
            <li class="required">
              <%= f.label :first_name, nil, **form_label_options(resource, :first_name) %>
              <%= f.text_field :first_name, autofocus: true, required: true, maxlength: 50, autocomplete: "given-name", **form_control_options(resource, :first_name) %>
              <%= field_error_messages(resource, :first_name) %>
            </li>
            <li class="required">
              <%= f.label :last_name, nil, **form_label_options(resource, :last_name) %>
              <%= f.text_field :last_name, required: true, maxlength: 50, autocomplete: "family-name", **form_control_options(resource, :last_name) %>
              <%= field_error_messages(resource, :last_name) %>
            </li>
            <li class="required">
              <%= f.label :mobile_number, nil, **form_label_options(resource, :mobile_number) %>
              <%= f.text_field :mobile_number, required: true, maxlength: 20, autocomplete: "tel", **form_control_options(resource, :mobile_number) %>
              <%= field_error_messages(resource, :mobile_number) %>
            </li>
            <li class="required">
              <%= f.label :email, nil, **form_label_options(resource, :email) %>
              <%= f.email_field :email, required: true, autocomplete: "email", **form_control_options(resource, :email) %>
              <%= field_error_messages(resource, :email) %>
            </li>
            <li class="required">
              <%= f.label :language, nil, **form_label_options(resource, :language) %>
              <%= f.select :language, available_languages, { prompt: t('properties.pick_one') }, form_control_options(resource, :language) %>
              <%= field_error_messages(resource, :language) %>
            </li>
            <li class="required">
              <%= f.label :password, nil, **form_label_options(resource, :password) %> <i>(leave blank if you don't want to change it)</i><br/>
              <%= f.password_field :password, minlength: 6, autocomplete: "new-password", **form_control_options(resource, :password) %>
              <%= field_error_messages(resource, :password) %>
            </li>
            <li class="required">
              <%= f.label :password_confirmation, nil, **form_label_options(resource, :password_confirmation) %>
              <%= f.password_field :password_confirmation, minlength: 6, autocomplete: "new-password", **form_control_options(resource, :password_confirmation) %>
              <%= field_error_messages(resource, :password_confirmation) %>
            </li>
            <li class="required">
              <%= f.label :current_password, nil, **form_label_options(resource, :current_password) %> <i>(we need your current password to confirm your changes)</i><br/>
              <%= f.password_field :current_password, required: true, autocomplete: "current-password", **form_control_options(resource, :current_password) %>
              <%= field_error_messages(resource, :current_password) %>
            </li>
          </ol>
          <p>
            <%= f.submit t('devise.views.registrations.edit.update') %>
          </p>
        </fieldset>
    <% end %>

    <h4><%= t('devise.views.registrations.edit.cancel_my_account') %></h4>

    <p>
      Unhappy?
      <%= link_to t('devise.views.registrations.edit.cancel_my_account'),
                  registration_path(resource_name),
                  data: {
                    turbo_method: :delete,
                    turbo_confirm: t('devise.views.registrations.edit.are_you_sure')
                  } %>
    </p>

  </div>

  <%= render "layouts/sidebar" %>

</div>
