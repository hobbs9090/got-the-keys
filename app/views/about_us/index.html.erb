<% title t('about_us.title') %>
<%
principles = [
  {
    title: t('about_us.value_1_title'),
    body: t('about_us.value_1_body')
  },
  {
    title: t('about_us.value_2_title'),
    body: t('about_us.value_2_body')
  },
  {
    title: t('about_us.value_3_title'),
    body: t('about_us.value_3_body')
  }
]

owner_controls = [
  t('about_us.control_1'),
  t('about_us.control_2'),
  t('about_us.control_3'),
  t('about_us.control_4')
]
%>

<section class="page-hero about-hero">
  <div class="about-hero__content">
    <p class="page-hero__eyebrow"><%= t('about_us.hero_eyebrow') %></p>
    <h1><%= t('about_us.hero_title') %></h1>
    <p class="about-hero__copy"><%= t('about_us.blurb') %></p>

    <div class="about-hero__actions">
      <%= link_to t('about_us.primary_cta'), properties_path, class: 'button primary large' %>
      <%= link_to t('about_us.secondary_cta'), contact_us_path, class: 'button secondary hollow large' %>
    </div>
  </div>

  <aside class="site-card about-hero__panel">
    <span class="badge badge--neutral"><%= t('about_us.hero_panel_badge') %></span>
    <h2><%= t('about_us.hero_panel_title') %></h2>
    <p><%= t('about_us.hero_panel_body') %></p>

    <ul class="about-hero__checklist no-bullet">
      <li><%= t('about_us.hero_point_1') %></li>
      <li><%= t('about_us.hero_point_2') %></li>
      <li><%= t('about_us.hero_point_3') %></li>
    </ul>
  </aside>
</section>

<section class="about-layout">
  <div class="about-main">
    <article class="site-card about-story" data-testid="about-story-card">
      <div class="about-story__media">
        <%= pixel_density_image_tag('hero_3.jpg', retina_source: 'hero_3@2x.jpg', class: 'about-story__image', alt: t('about_us.header')) %>
      </div>

      <div class="about-story__body">
        <p class="section-heading__eyebrow"><%= t('about_us.story_eyebrow') %></p>
        <h2><%= t('about_us.story_title') %></h2>
        <p><%= t('about_us.paragraph_1') %></p>
        <p><%= t('about_us.paragraph_2') %></p>
      </div>
    </article>

    <section class="about-values" aria-labelledby="about-values-title">
      <div class="section-heading">
        <div>
          <p class="section-heading__eyebrow"><%= t('about_us.values_eyebrow') %></p>
          <h2 id="about-values-title"><%= t('about_us.values_title') %></h2>
        </div>
        <p class="about-values__intro"><%= t('about_us.values_intro') %></p>
      </div>

      <div class="about-values__grid">
        <% principles.each do |principle| %>
          <article class="site-card about-value-card">
            <h3><%= principle[:title] %></h3>
            <p><%= principle[:body] %></p>
          </article>
        <% end %>
      </div>
    </section>
  </div>

  <aside class="about-sidebar">
    <section class="site-card about-sidebar__controls">
      <p class="section-heading__eyebrow"><%= t('about_us.controls_eyebrow') %></p>
      <h2><%= t('about_us.controls_title') %></h2>

      <ul class="about-control-list no-bullet">
        <% owner_controls.each do |control| %>
          <li><%= control %></li>
        <% end %>
      </ul>
    </section>

    <section class="site-card about-sidebar__note">
      <p class="section-heading__eyebrow"><%= t('about_us.note_eyebrow') %></p>
      <h2><%= t('about_us.note_title') %></h2>
      <p><%= t('about_us.paragraph_3') %></p>
    </section>

    <section class="site-card about-sidebar__cta">
      <p class="section-heading__eyebrow"><%= t('about_us.cta_eyebrow') %></p>
      <h2><%= t('about_us.cta_title') %></h2>
      <p><%= t('about_us.cta_body') %></p>

      <div class="about-sidebar__actions">
        <%= link_to t('about_us.cta_primary'), properties_path, class: 'button primary expanded' %>
        <%= link_to t('about_us.cta_secondary'), contact_us_path, class: 'button secondary hollow expanded' %>
      </div>
    </section>
  </aside>
</section>
