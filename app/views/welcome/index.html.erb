<% hero_slides = [
  hero_1_image(loading: "eager", fetchpriority: "high"),
  hero_2_image(loading: "lazy", fetchpriority: "low"),
  hero_3_image(loading: "lazy", fetchpriority: "low"),
  hero_4_image(loading: "lazy", fetchpriority: "low"),
  hero_5_image(loading: "lazy", fetchpriority: "low")
] %>
<% hero_slide_labels = %w[first second third fourth fifth] %>

<%= render "hero_carousel", slides: hero_slides, labels: hero_slide_labels %>

<section class="landing-hero">
  <div class="landing-hero__content">
    <p class="landing-hero__eyebrow"><%= t("ui.welcome.hero_eyebrow") %></p>
    <h1><%= t("ui.welcome.hero_title") %></h1>
    <div class="landing-hero__body">
      <p class="landing-hero__copy"><%= t('welcome.paragraph_1') %> <%= t('welcome.paragraph_2') %></p>

      <div class="landing-hero__actions">
        <%= link_to t("ui.welcome.primary_cta"), properties_path, class: "button primary large", data: { testid: "browse-properties-link" } %>
        <%= link_to t("ui.welcome.admin_cta"), admin_bookings_path, class: "button secondary hollow large" if admin_signed_in? %>
      </div>
    </div>
  </div>
</section>

<%= render "metric_strip", metrics: @site_metrics %>

<section class="page-section">
  <div class="section-heading">
    <div>
      <p class="section-heading__eyebrow"><%= t("ui.welcome.featured_eyebrow") %></p>
      <h2><%= t("ui.welcome.featured_title") %></h2>
    </div>
    <%= link_to t("ui.welcome.featured_action"), properties_path, class: "button hollow secondary" %>
  </div>

  <%= render "properties/property", properties: @featured_properties %>
</section>

<section class="insight-accordion" aria-label="<%= t('ui.welcome.insights_label') %>">
  <details class="insight-accordion__item" open>
    <summary><%= t("welcome.try_today") %></summary>
    <div class="insight-accordion__content">
      <p><%= t('welcome.paragraph_3') %></p>
      <p><%= t('welcome.paragraph_4') %></p>
    </div>
  </details>

  <details class="insight-accordion__item">
    <summary><%= t("ui.welcome.qa_title") %></summary>
    <div class="insight-accordion__content">
      <ul>
        <li><%= t("ui.welcome.qa_points.selectors") %></li>
        <li><%= t("ui.welcome.qa_points.scenarios") %></li>
        <li><%= t("ui.welcome.qa_points.audit") %></li>
      </ul>
    </div>
  </details>

  <details class="insight-accordion__item">
    <summary><%= t("ui.welcome.shared_host_title") %></summary>
    <div class="insight-accordion__content">
      <ul>
        <li><%= t("ui.welcome.shared_host_points.stack") %></li>
        <li><%= t("ui.welcome.shared_host_points.dependencies") %></li>
        <li><%= t("ui.welcome.shared_host_points.enhancement") %></li>
      </ul>
    </div>
  </details>
</section>
