<section class="landing-showcase">
  <div class="orbit site-hero site-hero--full-bleed" role="region" aria-label="<%= t('welcome.title') %>" data-orbit data-auto-play="true">
    <ul class="orbit-container">
      <button class="orbit-previous" aria-label="Previous slide" type="button">
        <span class="show-for-sr">Previous slide</span>&#9664;&#65038;
      </button>
      <button class="orbit-next" aria-label="Next slide" type="button">
        <span class="show-for-sr">Next slide</span>&#9654;&#65038;
      </button>
      <li class="is-active orbit-slide"><%= hero_1_image %></li>
      <li class="orbit-slide"><%= hero_2_image %></li>
      <li class="orbit-slide"><%= hero_3_image %></li>
    </ul>
    <nav class="orbit-bullets">
      <button class="is-active" data-slide="0"><span class="show-for-sr">First slide</span></button>
      <button data-slide="1"><span class="show-for-sr">Second slide</span></button>
      <button data-slide="2"><span class="show-for-sr">Third slide</span></button>
    </nav>
  </div>
</section>

<section class="landing-hero">
  <div class="landing-hero__content">
    <div class="landing-hero__brand">
      <%= render "layouts/gotthekeys", class_name: "marketing-wordmark--hero", decorative: true, width: 248 %>
    </div>
    <p class="landing-hero__eyebrow">Modern property discovery and appointment booking</p>
    <h1>Give buyers and tenants a polished website while giving QA teams a deterministic automation harness.</h1>
    <p class="landing-hero__copy"><%= t('welcome.paragraph_1') %> <%= t('welcome.paragraph_2') %></p>

    <div class="landing-hero__actions">
      <%= link_to "Browse properties", properties_path, class: "button primary large", data: { testid: "browse-properties-link" } %>
      <%= link_to "Open bookings desk", admin_bookings_path, class: "button secondary hollow large" if admin_signed_in? %>
    </div>
  </div>
</section>

<section class="metric-strip">
  <% @site_metrics.each do |label, value| %>
    <article class="metric-card">
      <strong><%= number_with_delimiter(value, delimiter: ",") %></strong>
      <span><%= label.to_s.humanize %></span>
    </article>
  <% end %>
</section>

<section class="page-section">
  <div class="section-heading">
    <div>
      <p class="section-heading__eyebrow">Featured listings</p>
      <h2>Credible, responsive property cards with booking hooks built in</h2>
    </div>
    <%= link_to "See the full catalogue", properties_path, class: "button hollow secondary" %>
  </div>

  <%= render "properties/property", properties: @featured_properties %>
</section>

<section class="insight-accordion" aria-label="Platform insights">
  <details class="insight-accordion__item" open>
    <summary>Why teams use it</summary>
    <div class="insight-accordion__content">
      <p><%= t('welcome.paragraph_3') %></p>
      <p><%= t('welcome.paragraph_4') %></p>
    </div>
  </details>

  <details class="insight-accordion__item">
    <summary>Built for QA training</summary>
    <div class="insight-accordion__content">
      <ul>
        <li>Stable semantic selectors on the critical booking and admin controls.</li>
        <li>Deterministic demo scenarios for happy paths, conflicts, empty states, and high-volume searches.</li>
        <li>Visible audit trails and notification logs that make status transitions easy to verify.</li>
      </ul>
    </div>
  </details>

  <details class="insight-accordion__item">
    <summary>Shared-host friendly</summary>
    <div class="insight-accordion__content">
      <ul>
        <li>Server-rendered Rails under Apache + Passenger.</li>
        <li>No Redis, Sidekiq, Docker, or always-on worker assumptions.</li>
        <li>Progressive enhancement with Foundation, Turbo, and conventional forms.</li>
      </ul>
    </div>
  </details>
</section>
